@namespace PaceLetics.AthleteModule.Components
@using MudBlazor
@inject IStringLocalizer<AthleteResources> L

<MudStack Spacing="3" Class="pl-pace-comparison">
    @foreach (var p in Items)
    {
        <MudPaper Class="@($"pa-4 pl-pace-card pl-pace-comparison-card pl-pace-zone-{p.ZoneKey}")" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap:12px;">
                <MudStack Spacing="2" Style="min-width:0;flex:1;">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold">@p.Title</MudText>

                    <div class="pl-pace-comparison-values">
                        <div class="pl-pace-comparison-value">
                            <MudText Typo="Typo.caption" Class="pl-pace-comparison-label">
                                @L["PaceComparison_Daniels"]
                            </MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">
                                @p.DanielsPaceText
                            </MudText>
                        </div>

                        <div class="pl-pace-comparison-value">
                            <MudText Typo="Typo.caption" Class="pl-pace-comparison-label">
                                @L["PaceComparison_CriticalSpeed"]
                            </MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">
                                @p.CriticalSpeedPaceText
                            </MudText>
                        </div>
                    </div>

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @p.Description
                    </MudText>
                </MudStack>

                <div class="pl-pace-zone-mark" aria-hidden="true">
                    @p.Code
                </div>
            </MudStack>
        </MudPaper>
    }
</MudStack>
