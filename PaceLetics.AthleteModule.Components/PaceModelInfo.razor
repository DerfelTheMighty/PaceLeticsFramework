@namespace PaceLetics.AthleteModule.Components
@using MudBlazor
@inject IStringLocalizer<AthleteResources> L

<MudStack Spacing="3">
    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["PaceModelInfo_Rationale_Title"]</MudText>
            <MudText Typo="Typo.body2">
                @L["PaceModelInfo_Rationale_PaceProxy_Text"]
                <MudLink Href="https://link.springer.com/article/10.1007/s40279-026-02410-x" Target="_blank">[1]</MudLink>
            </MudText>
            <MudText Typo="Typo.body2">
                @L["PaceModelInfo_Rationale_Adaptation_Text"]
                <MudLink Href="https://paulogentil.com/pdf/Time%20Course%20of%20Changes%20in%20Muscle%20and%20Tendon%20Properties%20During%20Strength%20Training%20and%20Detraining.pdf" Target="_blank">[2]</MudLink>
                <MudLink Href="https://www.germanjournalsportsmedicine.com/archive/archive-2019/issue-4/functional-adaptation-of-connective-tissue-by-training/" Target="_blank">[3]</MudLink>
                <MudLink Href="https://pubmed.ncbi.nlm.nih.gov/33635519/" Target="_blank">[5]</MudLink>
            </MudText>
            <MudText Typo="Typo.body2">@L["PaceModelInfo_Rationale_Remaining_Text"]</MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <img src="/images/diagrams/adaptation-timeline.svg"
             alt="@L["PaceModelInfo_AdaptationDiagramAlt"]"
             style="display:block;width:100%;height:auto;border-radius:8px;" />
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <img src="/images/diagrams/mechanical-load-vs-pace.svg"
             alt="@L["PaceModelInfo_MechanicalLoadDiagramAlt"]"
             style="display:block;width:100%;height:auto;border-radius:8px;" />
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["PaceModelInfo_LoadAdaptation_Title"]</MudText>
            <MudText Typo="Typo.body2">
                @L["PaceModelInfo_LoadAdaptation_Tendon_Text"]
                <MudLink Href="https://link.springer.com/article/10.1186/s40798-015-0009-9" Target="_blank">[4]</MudLink>
            </MudText>
            <MudText Typo="Typo.body2">@L["PaceModelInfo_LoadAdaptation_Diagram_Text"]</MudText>
            <MudText Typo="Typo.body2">
                @L["PaceModelInfo_LoadAdaptation_Workload_Text"]
                <MudLink Href="https://pubmed.ncbi.nlm.nih.gov/33635519/" Target="_blank">[5]</MudLink>
            </MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <img src="/images/diagrams/load-adaptation-window.svg"
             alt="@L["PaceModelInfo_LoadAdaptationDiagramAlt"]"
             style="display:block;width:100%;height:auto;border-radius:8px;" />
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["PaceModelInfo_Daniels_Title"]</MudText>
            <MudText Typo="Typo.body2">@L["PaceModelInfo_Daniels_Text"]</MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["PaceModelInfo_Cs_Title"]</MudText>
            <MudText Typo="Typo.body2">@L["PaceModelInfo_Cs_Text"]</MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["PaceModelInfo_Calculation_Title"]</MudText>
            <MudText Typo="Typo.body2">@L["PaceModelInfo_Calculation_Text"]</MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <img src="/images/diagrams/pace-model-belastungskurve.svg"
             alt="@L["PaceModelInfo_DiagramAlt"]"
             style="display:block;width:100%;height:auto;border-radius:8px;" />
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["PaceModelInfo_References_Title"]</MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://link.springer.com/article/10.1007/s40279-026-02410-x" Target="_blank">
                    @L["PaceModelInfo_Anderson_Title"]
                </MudLink>
                @L["PaceModelInfo_Anderson_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://pmc.ncbi.nlm.nih.gov/articles/PMC11933073/" Target="_blank">
                    @L["PaceModelInfo_Lipkova_Title"]
                </MudLink>
                @L["PaceModelInfo_Lipkova_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://pubmed.ncbi.nlm.nih.gov/28490537/" Target="_blank">
                    @L["PaceModelInfo_Hawley_Title"]
                </MudLink>
                @L["PaceModelInfo_Hawley_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://pubmed.ncbi.nlm.nih.gov/27748956/" Target="_blank">
                    @L["PaceModelInfo_MacInnis_Title"]
                </MudLink>
                @L["PaceModelInfo_MacInnis_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://paulogentil.com/pdf/Time%20Course%20of%20Changes%20in%20Muscle%20and%20Tendon%20Properties%20During%20Strength%20Training%20and%20Detraining.pdf" Target="_blank">
                    @L["PaceModelInfo_Kubo_Title"]
                </MudLink>
                @L["PaceModelInfo_Kubo_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://www.germanjournalsportsmedicine.com/archive/archive-2019/issue-4/functional-adaptation-of-connective-tissue-by-training/" Target="_blank">
                    @L["PaceModelInfo_Bohm_Title"]
                </MudLink>
                @L["PaceModelInfo_Bohm_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://link.springer.com/article/10.1186/s40798-015-0009-9" Target="_blank">
                    @L["PaceModelInfo_Bohm2015_Title"]
                </MudLink>
                @L["PaceModelInfo_Bohm2015_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://www.frontiersin.org/journals/bioengineering-and-biotechnology/articles/10.3389/fbioe.2020.533391/full" Target="_blank">
                    @L["PaceModelInfo_Papagiannaki_Title"]
                </MudLink>
                @L["PaceModelInfo_Papagiannaki_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://www.frontiersin.org/journals/bioengineering-and-biotechnology/articles/10.3389/fbioe.2024.1378284/full" Target="_blank">
                    @L["PaceModelInfo_Jiang_Title"]
                </MudLink>
                @L["PaceModelInfo_Jiang_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://www.frontiersin.org/journals/psychology/articles/10.3389/fpsyg.2019.03026/full" Target="_blank">
                    @L["PaceModelInfo_Billat_Title"]
                </MudLink>
                @L["PaceModelInfo_Billat_Text"]
            </MudText>

            <MudText Typo="Typo.body2">
                <MudLink Href="https://pubmed.ncbi.nlm.nih.gov/33635519/" Target="_blank">
                    @L["PaceModelInfo_Warden_Title"]
                </MudLink>
                @L["PaceModelInfo_Warden_Text"]
            </MudText>
        </MudStack>
    </MudPaper>
</MudStack>
