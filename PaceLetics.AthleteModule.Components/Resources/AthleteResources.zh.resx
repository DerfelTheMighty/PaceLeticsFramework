  <data name="PaceModelInfo_Daniels_Text" xml:space="preserve"><value>Daniels/VDOT &#x6A21;&#x578B;&#x6E90;&#x81EA; Jack Daniels &#x548C; Jimmy Gilbert &#x7684;&#x7814;&#x7A76;&#xFF0C;&#x5176;&#x6210;&#x679C;&#x4E8E; 1979 &#x5E74;&#x4EE5; Oxygen Power: Performance Tables for Distance Runners &#x51FA;&#x7248;&#x3002;VDOT &#x4E0D;&#x662F;&#x76F4;&#x63A5;&#x6D4B;&#x5F97;&#x7684; VO2max&#xFF0C;&#x800C;&#x662F;&#x7531;&#x5B9E;&#x9645;&#x8DD1;&#x6B65;&#x8868;&#x73B0;&#x63A8;&#x5BFC;&#x7684;&#x6709;&#x6548;&#x6216;&#x4F2A; VO2max&#x3002;&#x4E00;&#x4E2A;&#x6BD4;&#x8D5B;&#x6210;&#x7EE9;&#x4F1A;&#x901A;&#x8FC7;&#x8DD1;&#x901F;&#x3001;&#x8DD1;&#x6B65;&#x7684;&#x6444;&#x6C27;&#x6210;&#x672C;&#xFF0C;&#x4EE5;&#x53CA;&#x8BE5;&#x65F6;&#x957F;&#x5185;&#x53EF;&#x7EF4;&#x6301;&#x7684; VO2max &#x6BD4;&#x4F8B;&#x8F6C;&#x6362;&#x4E3A;&#x5355;&#x4E00;&#x80FD;&#x529B;&#x503C;&#x3002;&#x56E0;&#x6B64;&#xFF0C;&#x8BE5;&#x6A21;&#x578B;&#x5728;&#x4E00;&#x4E2A;&#x5B9E;&#x7528;&#x6307;&#x6807;&#x4E2D;&#x7EFC;&#x5408;&#x4E86;&#x6709;&#x6C27;&#x80FD;&#x529B;&#x3001;&#x8DD1;&#x6B65;&#x7ECF;&#x6D4E;&#x6027;&#x548C;&#x6BD4;&#x8D5B;&#x6267;&#x884C;&#x3002;&#x5F53;&#x8F93;&#x5165;&#x6570;&#x636E;&#x8DB3;&#x591F;&#x65B0;&#x3001;&#x5C3D;&#x529B;&#x4E14;&#x80FD;&#x4EE3;&#x8868;&#x8FD0;&#x52A8;&#x5458;&#x7279;&#x5F81;&#x65F6;&#xFF0C;&#x5B83;&#x5BF9;&#x7B49;&#x6548;&#x6210;&#x7EE9;&#x548C;&#x8BAD;&#x7EC3;&#x914D;&#x901F;&#x7684;&#x5EFA;&#x6A21;&#x8F83;&#x597D;&#xFF1B;&#x5728;&#x7279;&#x6B8A;&#x4E13;&#x9879;&#x3001;&#x5F88;&#x77ED;&#x6D4B;&#x8BD5;&#x3001;&#x9AD8;&#x6E29;&#x3001;&#x9AD8;&#x6D77;&#x62D4;&#x3001;&#x8D8A;&#x91CE;&#x8DEF;&#x7EBF;&#x6216;&#x914D;&#x901F;&#x5931;&#x8861;&#x65F6;&#x51C6;&#x786E;&#x6027;&#x4F1A;&#x4E0B;&#x964D;&#x3002;</value></data>
