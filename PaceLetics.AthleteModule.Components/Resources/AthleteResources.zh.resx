  <data name="PaceModelInfo_Calculation_Text" xml:space="preserve"><value>&#x6240;&#x6709;&#x5185;&#x90E8;&#x8BA1;&#x7B97;&#x90FD;&#x4F7F;&#x7528;&#x901F;&#x5EA6;&#xFF0C;&#x56E0;&#x4E3A;&#x76F4;&#x63A5;&#x5BF9;&#x914D;&#x901F;&#x4F7F;&#x7528;&#x767E;&#x5206;&#x6BD4;&#x4F1A;&#x4EA7;&#x751F;&#x53CD;&#x5411;&#x6548;&#x679C;&#x3002;Daniels &#x6A21;&#x578B;&#x4F1A;&#x5C06;&#x8F93;&#x5165;&#x6210;&#x7EE9;&#x4E0E; VDOT &#x8868;&#x5339;&#x914D;&#xFF0C;&#x6700;&#x63A5;&#x8FD1;&#x7684;&#x8868;&#x503C;&#x8FD4;&#x56DE; Daniels PaceModel&#x3002;CS &#x5219;&#x76F4;&#x63A5;&#x4F7F;&#x7528;&#x53EF;&#x7528;&#x8DD1;&#x6B65;&#x6570;&#x636E;&#xFF1A;&#x5355;&#x6B21; 1200 m &#x6D4B;&#x8BD5;&#x5F97;&#x5230; CS = 0.90 * v1200 &#x548C; Repetition = v1200&#x3002;&#x5982;&#x679C;&#x540C;&#x65F6;&#x6709; 1200 m &#x548C; 3600 m&#xFF0C;&#x5219;&#x8BA1;&#x7B97; CS = (3600 - 1200) / (t3600 - t1200) &#x548C; D' = 1200 - CS * t1200&#x3002;&#x591A;&#x4E2A;&#x8DDD;&#x79BB;&#x65F6;&#xFF0C;&#x6211;&#x4EEC;&#x7528;&#x56DE;&#x5F52;&#x4F30;&#x8BA1; distance = D' + CS * time&#x3002;&#x7136;&#x540E;&#x6309;&#x76F8;&#x5BF9; CS &#x7684;&#x901F;&#x5EA6;&#x56E0;&#x5B50;&#x751F;&#x6210;&#x533A;&#x95F4;&#xFF1A;Easy 87%&#xFF0C;Marathon 94%&#xFF0C;Threshold 102%&#xFF0C;Interval 109%&#xFF1B;Repetition &#x4F18;&#x5148;&#x4F7F;&#x7528; 1200 m &#x901F;&#x5EA6;&#xFF0C;&#x5426;&#x5219;&#x4F7F;&#x7528; CS &#x7684; 111%&#x3002;</value></data>
