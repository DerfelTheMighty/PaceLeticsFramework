  <data name="PaceModelInfo_Cs_Text" xml:space="preserve"><value>Critical Speed (CS) &#x662F; critical power &#x6982;&#x5FF5;&#x5728;&#x8DD1;&#x6B65;&#x4E2D;&#x7684;&#x7279;&#x5B9A;&#x5F62;&#x5F0F;&#x3002;&#x5B83;&#x63CF;&#x8FF0;&#x8DDD;&#x79BB;-&#x65F6;&#x95F4;&#x5173;&#x7CFB;&#x7684;&#x6E10;&#x8FD1;&#x901F;&#x5EA6;&#xFF0C;&#x5E76;&#x5728;&#x751F;&#x7406;&#x5B66;&#x4E0A;&#x88AB;&#x89E3;&#x91CA;&#x4E3A; heavy &#x4E0E; severe intensity &#x4E4B;&#x95F4;&#x7684;&#x8FB9;&#x754C;&#xFF1A;&#x4F4E;&#x4E8E; CS &#x65F6;&#x66F4;&#x53EF;&#x80FD;&#x8FBE;&#x5230;&#x4EE3;&#x8C22;&#x7A33;&#x6001;&#xFF1B;&#x9AD8;&#x4E8E; CS &#x65F6;&#xFF0C;&#x75B2;&#x52B3;&#x76F8;&#x5173;&#x6307;&#x6807;&#x4F1A;&#x6301;&#x7EED;&#x4E0A;&#x5347;&#xFF0C;&#x76F4;&#x5230;&#x5FC5;&#x987B;&#x505C;&#x6B62;&#x6216;&#x964D;&#x4F4E;&#x901F;&#x5EA6;&#x3002;&#x9AD8;&#x4E8E; CS &#x7684;&#x6709;&#x9650;&#x8DDD;&#x79BB;&#x80FD;&#x529B;&#x88AB;&#x5EFA;&#x6A21;&#x4E3A; D'&#x3002;Anderson et al. (2026) &#x7EFC;&#x8FF0;&#x4E86;&#x8DD1;&#x6B65;&#x4E2D; CS &#x548C; D' &#x7684;&#x6D4B;&#x91CF;&#x4E0E;&#x5EFA;&#x6A21;&#x65B9;&#x6CD5;&#xFF0C;&#x8BA4;&#x4E3A; CS &#x662F;&#x5F3A;&#x5EA6;&#x533A;&#x57DF;&#x95F4;&#x7ECF;&#x9A8C;&#x8BC1;&#x7684;&#x8FB9;&#x754C;&#xFF0C;&#x4F46;&#x4E5F;&#x6307;&#x51FA;&#x5B83;&#x53D7;&#x6D4B;&#x8BD5;&#x534F;&#x8BAE;&#x5F71;&#x54CD;&#xFF0C;D' &#x6062;&#x590D;&#x673A;&#x5236;&#x4ECD;&#x6709;&#x95EE;&#x9898;&#x672A;&#x89E3;&#x3002;Lipkova et al. (2025) &#x6307;&#x51FA;&#xFF0C;&#x5728;&#x6761;&#x4EF6;&#x548C;&#x5206;&#x6790;&#x6807;&#x51C6;&#x5316;&#x65F6;&#xFF0C;time trials &#x548C; 3-minute all-out test &#x662F;&#x5B9E;&#x7528;&#x7684;&#x7530;&#x91CE;&#x6D4B;&#x8BD5;&#x65B9;&#x6CD5;&#x3002;</value></data>
