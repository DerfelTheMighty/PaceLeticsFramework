  <data name="PaceModelInfo_Calculation_Text" xml:space="preserve"><value>&#x62A;&#x62C;&#x631;&#x649; &#x643;&#x644; &#x627;&#x644;&#x62D;&#x633;&#x627;&#x628;&#x627;&#x62A; &#x62F;&#x627;&#x62E;&#x644;&#x64A;&#x627; &#x628;&#x627;&#x644;&#x633;&#x631;&#x639;&#x629;&#x60C; &#x644;&#x623;&#x646; &#x627;&#x644;&#x646;&#x633;&#x628; &#x639;&#x644;&#x649; pace &#x62A;&#x646;&#x639;&#x643;&#x633;. &#x641;&#x64A; Daniels &#x62A;&#x642;&#x627;&#x631;&#x646; &#x627;&#x644;&#x646;&#x62A;&#x64A;&#x62C;&#x629; &#x628;&#x62C;&#x62F;&#x648;&#x644; VDOT &#x648;&#x64A;&#x639;&#x64A;&#x62F; &#x623;&#x642;&#x631;&#x628; &#x645;&#x62F;&#x62E;&#x644; Daniels PaceModel. &#x641;&#x64A; CS &#x646;&#x633;&#x62A;&#x62E;&#x62F;&#x645; &#x628;&#x64A;&#x627;&#x646;&#x627;&#x62A; &#x627;&#x644;&#x631;&#x643;&#x636; &#x645;&#x628;&#x627;&#x634;&#x631;&#x629;: &#x627;&#x62E;&#x62A;&#x628;&#x627;&#x631; 1200 &#x645; &#x64A;&#x639;&#x637;&#x64A; CS = 0.90 * v1200 &#x648; Repetition = v1200. &#x625;&#x630;&#x627; &#x648;&#x62C;&#x62F; 1200 &#x645; &#x648; 3600 &#x645; &#x646;&#x62D;&#x633;&#x628; CS = (3600 - 1200) / (t3600 - t1200) &#x648; D' = 1200 - CS * t1200. &#x645;&#x639; &#x639;&#x62F;&#x629; &#x645;&#x633;&#x627;&#x641;&#x627;&#x62A; &#x646;&#x642;&#x62F;&#x631; distance = D' + CS * time &#x628;&#x627;&#x644;&#x627;&#x646;&#x62D;&#x62F;&#x627;&#x631;. &#x62A;&#x633;&#x62A;&#x62E;&#x631;&#x62C; &#x627;&#x644;&#x645;&#x646;&#x627;&#x637;&#x642; &#x645;&#x646; CS: Easy 87%&#x60C; Marathon 94%&#x60C; Threshold 102%&#x60C; Interval 109%&#x60C; &#x648; Repetition &#x64A;&#x633;&#x62A;&#x62E;&#x62F;&#x645; &#x633;&#x631;&#x639;&#x629; 1200 &#x645; &#x623;&#x648; 111% &#x645;&#x646; CS.</value></data>
