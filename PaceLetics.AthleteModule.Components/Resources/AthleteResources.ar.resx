  <data name="PaceModelInfo_Daniels_Text" xml:space="preserve"><value>&#x646;&#x645;&#x648;&#x630;&#x62C; Daniels/VDOT &#x64A;&#x639;&#x648;&#x62F; &#x625;&#x644;&#x649; &#x639;&#x645;&#x644; Jack Daniels &#x648; Jimmy Gilbert &#x627;&#x644;&#x645;&#x646;&#x634;&#x648;&#x631; &#x639;&#x627;&#x645; 1979 &#x628;&#x639;&#x646;&#x648;&#x627;&#x646; Oxygen Power: Performance Tables for Distance Runners. &#x642;&#x64A;&#x645;&#x629; VDOT &#x644;&#x64A;&#x633;&#x62A; VO2max &#x645;&#x642;&#x627;&#x633;&#x629; &#x645;&#x628;&#x627;&#x634;&#x631;&#x629;&#x60C; &#x628;&#x644; VO2max &#x641;&#x639;&#x627;&#x644;&#x629; &#x623;&#x648; &#x634;&#x628;&#x647; &#x641;&#x633;&#x64A;&#x648;&#x644;&#x648;&#x62C;&#x64A;&#x629; &#x645;&#x633;&#x62A;&#x646;&#x62A;&#x62C;&#x629; &#x645;&#x646; &#x623;&#x62F;&#x627;&#x621; &#x627;&#x644;&#x631;&#x643;&#x636; &#x627;&#x644;&#x641;&#x639;&#x644;&#x64A;. &#x64A;&#x62A;&#x645; &#x62A;&#x62D;&#x648;&#x64A;&#x644; &#x646;&#x62A;&#x64A;&#x62C;&#x629; &#x627;&#x644;&#x633;&#x628;&#x627;&#x642; &#x625;&#x644;&#x649; &#x645;&#x624;&#x634;&#x631; &#x648;&#x627;&#x62D;&#x62F; &#x639;&#x628;&#x631; &#x627;&#x644;&#x633;&#x631;&#x639;&#x629;&#x60C; &#x648;&#x643;&#x644;&#x641;&#x629; &#x627;&#x644;&#x623;&#x643;&#x633;&#x62C;&#x64A;&#x646; &#x644;&#x644;&#x631;&#x643;&#x636;&#x60C; &#x648;&#x646;&#x633;&#x628;&#x629; VO2max &#x627;&#x644;&#x642;&#x627;&#x628;&#x644;&#x629; &#x644;&#x644;&#x627;&#x633;&#x62A;&#x645;&#x631;&#x627;&#x631; &#x644;&#x62A;&#x644;&#x643; &#x627;&#x644;&#x645;&#x62F;&#x629;. &#x644;&#x630;&#x644;&#x643; &#x64A;&#x62C;&#x645;&#x639; &#x627;&#x644;&#x646;&#x645;&#x648;&#x630;&#x62C; &#x628;&#x64A;&#x646; &#x627;&#x644;&#x642;&#x62F;&#x631;&#x629; &#x627;&#x644;&#x647;&#x648;&#x627;&#x626;&#x64A;&#x629;&#x60C; &#x648;&#x627;&#x642;&#x62A;&#x635;&#x627;&#x62F; &#x627;&#x644;&#x631;&#x643;&#x636;&#x60C; &#x648;&#x62A;&#x646;&#x641;&#x64A;&#x630; &#x627;&#x644;&#x633;&#x628;&#x627;&#x642;. &#x64A;&#x643;&#x648;&#x646; &#x623;&#x62F;&#x642; &#x639;&#x646;&#x62F;&#x645;&#x627; &#x62A;&#x643;&#x648;&#x646; &#x627;&#x644;&#x645;&#x62F;&#x62E;&#x644;&#x627;&#x62A; &#x62D;&#x62F;&#x64A;&#x62B;&#x629;&#x60C; &#x642;&#x635;&#x648;&#x649;&#x60C; &#x648;&#x645;&#x645;&#x62B;&#x644;&#x629; &#x644;&#x645;&#x644;&#x641; &#x627;&#x644;&#x631;&#x64A;&#x627;&#x636;&#x64A;.</value></data>
  <data name="PaceModelInfo_Cs_Title" xml:space="preserve"><value>Critical Speed</value></data>
  <data name="PaceModelInfo_Cs_Text" xml:space="preserve"><value>Critical Speed (CS) &#x647;&#x648; &#x627;&#x644;&#x62A;&#x637;&#x628;&#x64A;&#x642; &#x627;&#x644;&#x62E;&#x627;&#x635; &#x628;&#x627;&#x644;&#x631;&#x643;&#x636; &#x644;&#x645;&#x641;&#x647;&#x648;&#x645; critical power. &#x64A;&#x635;&#x641; &#x627;&#x644;&#x633;&#x631;&#x639;&#x629; &#x627;&#x644;&#x62A;&#x642;&#x627;&#x631;&#x628;&#x64A;&#x629; &#x644;&#x639;&#x644;&#x627;&#x642;&#x629; &#x627;&#x644;&#x645;&#x633;&#x627;&#x641;&#x629; &#x628;&#x627;&#x644;&#x632;&#x645;&#x646;&#x60C; &#x648;&#x64A;&#x641;&#x633;&#x631; &#x641;&#x633;&#x64A;&#x648;&#x644;&#x648;&#x62C;&#x64A;&#x627; &#x643;&#x62D;&#x62F; &#x628;&#x64A;&#x646; heavy &#x648; severe intensity: &#x62F;&#x648;&#x646; CS &#x64A;&#x643;&#x648;&#x646; &#x627;&#x644;&#x62B;&#x628;&#x627;&#x62A; &#x627;&#x644;&#x623;&#x64A;&#x636;&#x64A; &#x623;&#x643;&#x62B;&#x631; &#x627;&#x62D;&#x62A;&#x645;&#x627;&#x644;&#x627;&#x60C; &#x648;&#x641;&#x648;&#x642;&#x647; &#x62A;&#x631;&#x62A;&#x641;&#x639; &#x645;&#x624;&#x634;&#x631;&#x627;&#x62A; &#x627;&#x644;&#x62A;&#x639;&#x628; &#x62D;&#x62A;&#x649; &#x64A;&#x644;&#x632;&#x645; &#x625;&#x64A;&#x642;&#x627;&#x641; &#x627;&#x644;&#x62C;&#x647;&#x62F; &#x623;&#x648; &#x62E;&#x641;&#x636; &#x627;&#x644;&#x633;&#x631;&#x639;&#x629;. &#x627;&#x644;&#x633;&#x639;&#x629; &#x627;&#x644;&#x645;&#x62D;&#x62F;&#x648;&#x62F;&#x629; &#x641;&#x648;&#x642; CS &#x62A;&#x645;&#x62B;&#x644; &#x628;&#x640; D'. Anderson et al. (2026) &#x64A;&#x644;&#x62E;&#x635;&#x648;&#x646; &#x637;&#x631;&#x642; &#x642;&#x64A;&#x627;&#x633; &#x648;&#x646;&#x645;&#x630;&#x62C;&#x629; CS &#x648; D' &#x641;&#x64A; &#x627;&#x644;&#x631;&#x643;&#x636;&#x60C; &#x648;&#x64A;&#x634;&#x64A;&#x631;&#x648;&#x646; &#x625;&#x644;&#x649; &#x623;&#x646; CS &#x62D;&#x62F; &#x645;&#x62A;&#x62D;&#x642;&#x642; &#x628;&#x64A;&#x646; &#x645;&#x62C;&#x627;&#x644;&#x627;&#x62A; &#x627;&#x644;&#x634;&#x62F;&#x629;. Lipkova et al. (2025) &#x64A;&#x648;&#x636