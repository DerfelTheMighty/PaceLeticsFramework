  <data name="PaceModelInfo_Daniels_Title" xml:space="preserve"><value>Daniels/VDOT</value></data>
  <data name="PaceModelInfo_Daniels_Text" xml:space="preserve"><value>&#x645;&#x62F;&#x644; Daniels/VDOT &#x628;&#x647; &#x6A9;&#x627;&#x631; Jack Daniels &#x648; Jimmy Gilbert &#x628;&#x631;&#x645;&#x6CC;&#x200C;&#x6AF;&#x631;&#x62F;&#x62F; &#x6A9;&#x647; &#x62F;&#x631; &#x633;&#x627;&#x644; 1979 &#x628;&#x627; &#x646;&#x627;&#x645; Oxygen Power: Performance Tables for Distance Runners &#x645;&#x646;&#x62A;&#x634;&#x631; &#x634;&#x62F;. VDOT &#x6CC;&#x6A9; VO2max &#x645;&#x633;&#x62A;&#x642;&#x6CC;&#x645;&#x627; &#x627;&#x646;&#x62F;&#x627;&#x632;&#x647;&#x200C;&#x6AF;&#x6CC;&#x631;&#x6CC;&#x200C;&#x634;&#x62F;&#x647; &#x646;&#x6CC;&#x633;&#x62A;&#x60C; &#x628;&#x644;&#x6A9;&#x647; VO2max &#x645;&#x648;&#x62B;&#x631; &#x6CC;&#x627; pseudo-VO2max &#x627;&#x633;&#x62A; &#x6A9;&#x647; &#x627;&#x632; &#x639;&#x645;&#x644;&#x6A9;&#x631;&#x62F; &#x648;&#x627;&#x642;&#x639;&#x6CC; &#x62F;&#x648; &#x627;&#x633;&#x62A;&#x646;&#x628;&#x627;&#x637; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x62F;. &#x6CC;&#x6A9; &#x646;&#x62A;&#x6CC;&#x62C;&#x647; &#x645;&#x633;&#x627;&#x628;&#x642;&#x647; &#x627;&#x632; &#x637;&#x631;&#x6CC;&#x642; &#x633;&#x631;&#x639;&#x62A;&#x60C; &#x647;&#x632;&#x6CC;&#x646;&#x647; &#x627;&#x6A9;&#x633;&#x6CC;&#x698;&#x646; &#x62F;&#x648; &#x648; &#x633;&#x647;&#x645; VO2max &#x642;&#x627;&#x628;&#x644; &#x62D;&#x641;&#x638; &#x62F;&#x631; &#x622;&#x646; &#x645;&#x62F;&#x62A; &#x628;&#x647; &#x6CC;&#x6A9; &#x634;&#x627;&#x62E;&#x635; &#x639;&#x645;&#x644;&#x6A9;&#x631;&#x62F;&#x6CC; &#x62A;&#x628;&#x62F;&#x6CC;&#x644; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x62F;. &#x627;&#x6CC;&#x646; &#x645;&#x62F;&#x644; &#x638;&#x631;&#x641;&#x6CC;&#x62A; &#x647;&#x648;&#x627;&#x632;&#x6CC;&#x60C; &#x627;&#x642;&#x62A;&#x635;&#x627;&#x62F; &#x62F;&#x648; &#x648; &#x627;&#x62C;&#x631;&#x627;&#x6CC; &#x645;&#x633;&#x627;&#x628;&#x642;&#x647; &#x631;&#x627; &#x62F;&#x631; &#x6CC;&#x6A9; &#x634;&#x627;&#x62E;&#x635; &#x6A9;&#x627;&#x631;&#x628;&#x631;&#x62F;&#x6CC; &#x62C;&#x645;&#x639; &#x645;&#x6CC;&#x200C;&#x6A9;&#x646;&#x62F;. &#x62F;&#x642;&#x62A; &#x622;&#x646; &#x632;&#x645;&#x627;&#x646;&#x6CC; &#x628;&#x647;&#x62A;&#x631; &#x627;&#x633;&#x62A; &#x6A9;&#x647; &#x648;&#x631;&#x648;&#x62F;&#x6CC; &#x62C;&#x62F;&#x6CC;&#x62F;&#x60C; &#x62D;&#x62F;&#x627;&#x6A9;&#x62B;&#x631;&#x6CC; &#x648; &#x646;&#x645;&#x627;&#x6CC;&#x646;&#x62F;&#x647; &#x647;&#x645;&#x627;&#x646; &#x648;&#x631;&#x632;&#x634;&#x6A9;&#x627;&#x631; &#x628;&#x627;&#x634;&#x62F;.</value></data>
  <data name="PaceModelInfo_Cs_Title" xml:space="preserve"><value>Critical Speed</value></data>
  <data name="PaceModelInfo_Cs_Text" xml:space="preserve"><value>Critical Speed (CS) &#x646;&#x633;&#x62E;&#x647; &#x645;&#x62E;&#x635;&#x648;&#x635; &#x62F;&#x648; &#x627;&#x632; &#x645;&#x641;&#x647;&#x648;&#x645; critical power &#x627;&#x633;&#x62A;. &#x627;&#x6CC;&#x646; &#x645;&#x642;&#x62F;&#x627;&#x631; &#x633;&#x631;&#x639;&#x62A; &#x645;&#x62C;&#x627;&#x646;&#x628;&#x6CC; &#x631;&#x627;&#x628;&#x637;&#x647; &#x645;&#x633;&#x627;&#x641;&#x62A;-&#x632;&#x645;&#x627;&#x646; &#x631;&#x627; &#x62A;&#x648;&#x635;&#x6CC;&#x641; &#x645;&#x6CC;&#x200C;&#x6A9;&#x646;&#x62F; &#x648; &#x627;&#x632; &#x646;&#x638;&#x631; &#x641;&#x6CC;&#x632;&#x6CC;&#x648;&#x644;&#x648;&#x698;&#x6CC;&#x6A9; &#x645;&#x631;&#x632; &#x628;&#x6CC;&#x646; heavy &#x648; severe intensity &#x62A;&#x644;&#x642;&#x6CC; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x62F;. &#x632;&#x6CC;&#x631; CS &#x62B;&#x628;&#x627;&#x62A; &#x645;&#x62A;&#x627;&#x628;&#x648;&#x644;&#x6CC;&#x6A9; &#x645;&#x62D;&#x62A;&#x645;&#x644;&#x200C;&#x62A;&#x631; &#x627;&#x633;&#x62A;&#x61B; &#x628;&#x627;&#x644;&#x627;&#x6CC; CS &#x646;&#x634;&#x627;&#x646;&#x647;&#x200C;&#x647;&#x627;&#x6CC; &#x62E;&#x633;&#x62A;&#x6AF;&#x6CC; &#x628;&#x647; &#x637;&#x648;&#x631; &#x641;&#x632;&#x627;&#x6CC;&#x646;&#x62F;&#x647; &#x631;&#x634;&#x62F; &#x645;&#x6CC;&#x200C;&#x6A9;&#x646;&#x646;&#x62F; &#x62A;&#x627; &#x62C;&#x647;&#x62F; &#x642;&#x637;&#x639; &#x6CC;&#x627; &#x633;&#x631;&#x639;&#x62A; &#x6A9;&#x645; &#x634;&#x648;&#x62F;. &#x638;&#x631;&#x641;&#x6CC;&#x62A; &#x645;&#x62D;&#x62F;&#x648;&#x62F; &#x628;&#x627;&#x644;&#x627;&#x6CC; CS &#x628;&#x627; D' &#x645;&#x62F;&#x644; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x62F;. Anderson et al. (2026) &#x631;&#x648;&#x634;&#x200C;&#x647;&#x627;&#x6CC; &#x627;&#x646;&#x62F;&#x627;&#x632;&#x647;&#x200C;&#x6AF;&#x6CC;&#x631;&#x6CC; &#x648; &#x645;&#x62F;&#x644;&#x200C;&#x633;&#x627;&#x632;&#x6CC; CS &#x648; D' &#x631;&#x627; &#x62F;&#x631; &#x62F;&#x648; &#x645;&#x631;&#x648;&#x631; &#x645;&#x6CC;&#x200C;&#x6A9;&#x646;&#x646;&#x62F;. Lipkova et al. (2025) &#x646;&#x634;&#x627;&#x646; &#x645;&#x6CC;&#x200C;&#x62F;&#x647;&#x646;&#x62F; &#x6A9;&#x647; time trial &#x648; 3MT &#x62F;&#x631; &#x635;&#x648;&#x631;&#x62A; &#x627;&#x633;&#x62A;&#x627;&#x646;&#x62F;&#x627;&#x631;&#x62F; &#x628;&#x648;&#x62F;&#x646; &#x634;&#x631;&#x627;&#x6CC;&#x637; &#x631;&#x648;&#x634;&#x200C;&#x647;&#x627;&#x6CC; &#x645;&#x6CC;&#x62F;&#x627;&#x646;&#x6CC; &#x6A9;&#x627;&#x631;&#x628;&#x631;&#x62F;&#x6CC; &#x647;&#x633;&#x62A;&#x646;&#x62F;.</value></data>
  <data name="PaceModelInfo_Calculation_Title" xml:space="preserve"><value>&#x62A;&#x628;&#x62F;&#x6CC;&#x644; &#x62F;&#x631; PaceLetics</value></data>
  <data name="PaceModelInfo_Calculation_Text" xml:space="preserve"><value>&#x647;&#x645;&#x647; &#x645;&#x62D;&#x627;&#x633;&#x628;&#x627;&#x62A; &#x62F;&#x627;&#x62E;&#x644;&#x6CC; &#x628;&#x627; &#x633;&#x631;&#x639;&#x62A; &#x627;&#x646;&#x62C;&#x627;&#x645; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x62F;&#x60C; &#x686;&#x648;&#x646; &#x62F;&#x631;&#x635;&#x62F;&#x647;&#x627; &#x631;&#x648;&#x6CC; pace &#x645;&#x639;&#x6A9;&#x648;&#x633; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x646;&#x62F;. &#x628;&#x631;&#x627;&#x6CC; Daniels &#x639;&#x645;&#x644;&#x6A9;&#x631;&#x62F; &#x628;&#x627; &#x62C;&#x62F;&#x648;&#x644; VDOT &#x62A;&#x637;&#x628;&#x6CC;&#x642; &#x62F;&#x627;&#x62F;&#x647; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x62F;. &#x628;&#x631;&#x627;&#x6CC; CS &#x627;&#x632; &#x62F;&#x627;&#x62F;&#x647;&#x200C;&#x647;&#x627;&#x6CC; &#x62F;&#x648; &#x645;&#x633;&#x62A;&#x642;&#x6CC;&#x645; &#x627;&#x633;&#x62A;&#x641;&#x627;&#x62F;&#x647; &#x645;&#x6CC;&#x200C;&#x6A9;&#x646;&#x6CC;&#x645;: &#x6CC;&#x6A9; &#x622;&#x632;&#x645;&#x648;&#x646; 1200 &#x645;&#x62A;&#x631; CS = 0.90 * v1200 &#x648; Repetition = v1200 &#x645;&#x6CC;&#x200C;&#x62F;&#x647;&#x62F;. &#x627;&#x6AF;&#x631; 1200 &#x648; 3600 &#x645;&#x62A;&#x631; &#x645;&#x648;&#x62C;&#x648;&#x62F; &#x628;&#x627;&#x634;&#x62F;&#x60C; CS = (3600 - 1200) / (t3600 - t1200) &#x648; D' = 1200 - CS * t1200 &#x645;&#x62D;&#x627;&#x633;&#x628;&#x647; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x62F;. &#x628;&#x627; &#x686;&#x646;&#x62F; &#x645;&#x633;&#x627;&#x641;&#x62A;&#x60C; &#x631;&#x627;&#x628;&#x637;&#x647; distance = D' + CS * time &#x628;&#x627; &#x631;&#x6AF;&#x631;&#x633;&#x6CC;&#x648;&#x646; &#x628;&#x631;&#x622;&#x648;&#x631;&#x62F; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x62F;. &#x645;&#x646;&#x627;&#x637;&#x642; &#x646;&#x633;&#x628;&#x62A; &#x628;&#x647; CS &#x633;&#x627;&#x62E;&#x62A;&#x647; &#x645;&#x6CC;&#x200C;&#x634;&#x648;&#x646;&#x62F;: Easy 87%&#x60C; Marathon 94%&#x60C; Threshold 102%&#x60C; Interval 109%&#x60C; &#x648; Repetition &#x633;&#x631;&#x639;&#x62A; 1200 &#x645;&#x62A;&#x631; &#x6CC;&#x627; 111% CS &#x631;&#x627; &#x645;&#x6CC;&#x200C;&#x6AF;&#x6CC;&#x631;&#x62F;.</value></data>
