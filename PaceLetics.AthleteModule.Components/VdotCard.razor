
@using MudBlazor;
@namespace PaceLetics.AthleteModule.Components
@inject IStringLocalizer<AthleteResources> L

<MudCard Class="d-flex flex-column align-center pa-4" Style="text-align:center;">

    <div class="d-flex justify-center">
        <MudChart T="double"
                  ChartOptions="@(new DonutChartOptions
                  {
                      ChartPalette = new[] { "var(--mud-palette-primary)", "var(--mud-palette-secondary)" },
                  })"
                  ChartType="ChartType.Donut"
                  Width="260px"
                  Height="260px"
                  @bind-SelectedIndex="_index"
                  ChartSeries="@Data.AsChartDataSet()">

            <CustomGraphics>
                <text x="50%"
                      y="42%"
                      text-anchor="middle"
                      fill="var(--mud-palette-text-secondary)"
                      font-family="Helvetica"
                      font-size="16"
                      font-weight="500">
                    @L["VdotCard_Title"]
                </text>

                <text x="50%"
                      y="60%"
                      text-anchor="middle"
                      fill="var(--mud-palette-text-primary)"
                      font-family="Helvetica"
                      font-size="48">
                    @Data[0]
                </text>
            </CustomGraphics>

        </MudChart>
    </div>

    <MudText Align="Align.Center" Class="mt-4">
        @L["VdotCard_Description"]
    </MudText>
</MudCard>



