@using MudBlazor


@namespace PaceLetics.TrainingModule.Components.Workouts
@inject IStringLocalizer<WorkoutResources> L

<MudDialog>
    <DialogContent>
        <MudGrid Justify="Justify.Center" Style="align-items: center;">
            <MudImage> </MudImage>
        </MudGrid>
        
    </DialogContent>
    <DialogActions>
        <MudTooltip Text="@L["FinishedDialog_Confirm"]">
            <MudIconButton Icon="@Icons.Material.Filled.Check"
                           Color="Color.Primary"
                           OnClick="Submit"
                           aria-label="@L["FinishedDialog_Confirm"]" />
        </MudTooltip>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    void Submit() => MudDialog.Close(DialogResult.Ok(true));
}
