@using MudBlazor
@using PaceLetics.TrainingModule.CodeBase.Workouts.Enums
@using PaceLetics.TrainingModule.CodeBase.Workouts.Interfaces

@inject IStringLocalizer<WorkoutResources> L

<MudPaper Elevation="1" Class="pa-4" Style="height:100%; border-radius:16px;">
    <!-- Header -->
    <div class="d-flex align-center justify-space-between">
        <MudText Typo="Typo.h4">@Exercise?.Name</MudText>
        <MudChip T="Level" Color="Color.Info" Variant="Variant.Filled">@Exercise?.Level</MudChip>
    </div>

    <!-- Bild gross -->
    <div style="height:260px; max-width:520px; margin:16px auto; display:flex; align-items:center; justify-content:center;">
        <img src="@GetImagePath(Exercise?.ImageFilename)"
             alt="@Exercise?.Name"
             loading="lazy"
             decoding="async"
             style="max-width:100%; max-height:100%; width:auto; height:auto; object-fit:contain; display:block;" />
    </div>

    <!-- Description -->
    <MudText Typo="Typo.body1" Align="Align.Center" Style="opacity:.85">
        @Exercise?.Description
    </MudText>

    <!-- CTA unten -->
    <div class="d-flex justify-center mt-4">
        <MudTooltip Text="@L["WorkoutNow_Details"]">
            <MudIconButton Icon="@Icons.Material.Filled.Info"
                           Color="Color.Primary"
                           OnClick="@OnOpenDetails"
                           aria-label="@L["WorkoutNow_Details"]" />
        </MudTooltip>
    </div>
</MudPaper>

@code {
    [Parameter] public IExerciseInfo? Exercise { get; set; }
    [Parameter] public EventCallback OnOpenDetails { get; set; }
    
    private static string GetImagePath(string? imagefile)
    {
        return string.IsNullOrWhiteSpace(imagefile)
            ? "images/exercises/plank_base.png"
            : "images/exercises/" + imagefile;
    }
}
