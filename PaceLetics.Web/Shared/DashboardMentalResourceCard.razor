@using System.Linq
@using PaceLetics.Web.Pages.Athletes
@inject IStringLocalizer<Dashboard> L

<MudPaper Elevation="0" Class="pa-4 pl-panel pl-mental-resource-card">
    <MudStack Spacing="3">
        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Spacing="3"
                  Wrap="Wrap.Wrap"
                  Class="pl-mental-resource-header">
            <MentalResourceIcon Label="@IconLabel" />

            <MudStack Spacing="1" Class="pl-mental-resource-copy">
                <MudText Typo="Typo.caption" Class="pl-mental-resource-kicker">@L["MentalResource_Kicker"]</MudText>
                <MudText Typo="Typo.h6">@L["MentalResource_Title"]</MudText>
                <MudText Typo="Typo.body2" Class="pl-dashboard-muted">@L["MentalResource_Lead"]</MudText>
            </MudStack>
        </MudStack>

        <MudDivider />

        <div class="pl-mental-resource-steps">
            @foreach (var step in Steps.Select((item, index) => new { item, index }))
            {
                <div class="pl-mental-resource-step">
                    <span class="pl-mental-resource-step-number">@($"{step.index + 1:00}")</span>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@L[step.item.TitleKey]</MudText>
                        <MudText Typo="Typo.body2" Class="pl-dashboard-muted">@L[step.item.TextKey]</MudText>
                    </MudStack>
                </div>
            }
        </div>
    </MudStack>
</MudPaper>

@code {
    private string IconLabel => L["MentalResource_IconLabel"].Value;

    private static readonly MentalResourceStep[] Steps =
    [
        new("MentalResource_StepEffectTitle", "MentalResource_StepEffectText"),
        new("MentalResource_StepFragileTitle", "MentalResource_StepFragileText"),
        new("MentalResource_StepRiskTitle", "MentalResource_StepRiskText"),
        new("MentalResource_StepConsequenceTitle", "MentalResource_StepConsequenceText"),
        new("MentalResource_StepAppTitle", "MentalResource_StepAppText")
    ];

    private sealed record MentalResourceStep(string TitleKey, string TextKey);
}
