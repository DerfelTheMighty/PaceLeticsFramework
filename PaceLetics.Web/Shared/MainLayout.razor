@inherits LayoutComponentBase
@implements IDisposable
@using MudBlazor
@inject ThemePreferenceService ThemePreferences
@inject IStringLocalizer<NavMenu> NavL
@inject NavigationManager Navigation

<MudThemeProvider @ref="_themeProvider"
                  Theme="@ThemePreferences.CurrentTheme"
                  IsDarkMode="@ThemePreferences.IsDarkMode" />

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<PageTitle>PaceLetics</PageTitle>

<MudLayout Class="@GetLayoutClass()" Style="@GetThemeStyle()">
    <MudAppBar Elevation="1">

        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       Class="pl-desktop-only"
                       aria-label="@NavL["NavigationMenu"]"
                       OnClick="@((e) => DrawerToggle())" />
        @if (GetBackHref() is { } backHref)
        {
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           Color="Color.Inherit"
                           Class="pl-mobile-back"
                           aria-label="@NavL["Back"]"
                           OnClick="@(() => Navigation.NavigateTo(backHref))" />
        }
        <MudText Align="Align.Start" Class="pl-appbar-title">@GetAppBarTitle()</MudText>
        <MudSpacer />
        <AthleteMessageFeedButton />
        <LoginDisplay />

    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Breakpoint="Breakpoint.Md"
               Elevation="2"
               Class="pl-desktop-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="margin-top: 24px;">
        <div class="pl-main-content">
            @Body
        </div>
    </MudMainContent>

    <BottomNavBar />
    <LoadingHost />
    <AcademyInfoHost />
    <PublicUserNamePrompt />
</MudLayout>

@code {
    private bool _drawerOpen;
    private MudThemeProvider? _themeProvider;

    protected override void OnInitialized()
    {
        ThemePreferences.Changed += OnThemePreferenceChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _themeProvider is null)
            return;

        var systemPrefersDarkMode = await _themeProvider.GetSystemDarkModeAsync();
        await ThemePreferences.InitializeAsync(systemPrefersDarkMode);
        await _themeProvider.WatchSystemDarkModeAsync(ThemePreferences.SetSystemPrefersDarkModeAsync);
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private string GetLayoutClass()
    {
        var themeClass = ThemePreferences.ThemeName switch
        {
            AppThemeName.PaceLetics => "pl-synthwave-layout",
            AppThemeName.Ocean => "pl-ocean-layout",
            AppThemeName.Forest => "pl-forest-layout",
            AppThemeName.Wildflowers => "pl-wildflowers-layout",
            AppThemeName.CoteDAzur => "pl-cote-dazur-layout",
            AppThemeName.DarkRomance => "pl-dark-romance-layout",
            AppThemeName.Maritime => "pl-maritime-layout",
            AppThemeName.Tropical => "pl-tropical-layout",
            _ => string.Empty
        };

        return IsWorkoutRoute()
            ? $"{themeClass} pl-workout-route".Trim()
            : themeClass;
    }

    private bool IsWorkoutRoute() => Navigation.ToBaseRelativePath(Navigation.Uri)
        .Split('?', '#')[0]
        .Trim('/')
        .Equals("workouts/workoutroom", StringComparison.OrdinalIgnoreCase);

    private string CurrentPath => Navigation.ToBaseRelativePath(Navigation.Uri)
        .Split('?', '#')[0]
        .Trim('/');

    private string GetAppBarTitle()
    {
        var path = CurrentPath;
        if (string.IsNullOrEmpty(path)) return NavL["Nav_Today"];
        if (path.StartsWith("athletes/plan", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("athletes/session", StringComparison.OrdinalIgnoreCase)) return NavL["Nav_Plan"];
        if (path.StartsWith("workouts", StringComparison.OrdinalIgnoreCase)) return NavL["Nav_Train"];
        if (path.StartsWith("athletes/data", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("athletes/race", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("athletes/pace", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("athletes/analyses", StringComparison.OrdinalIgnoreCase)) return NavL["Nav_Progress"];
        if (path.StartsWith("trainers", StringComparison.OrdinalIgnoreCase)) return NavL["TrainerArea"];
        if (path.StartsWith("athletes/settings", StringComparison.OrdinalIgnoreCase)) return NavL["Settings"];
        return NavL["Nav_More"];
    }

    private string? GetBackHref()
    {
        var path = CurrentPath;
        if (path.StartsWith("athletes/session/", StringComparison.OrdinalIgnoreCase)) return "/Athletes/plan";
        if (path.StartsWith("athletes/analyses/", StringComparison.OrdinalIgnoreCase)) return "/Athletes/data-analyses?section=running-form";
        return null;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args) =>
        _ = InvokeAsync(StateHasChanged);

    private string GetThemeStyle()
    {
        var theme = ThemePreferences.CurrentThemeDefinition;
        var zones = theme.PaceZones;
        var styles = new List<string>
        {
            $"--pl-pace-free:{zones.Free}",
            $"--pl-pace-recovery:{zones.Recovery}",
            $"--pl-pace-easy:{zones.Easy}",
            $"--pl-pace-marathon:{zones.Marathon}",
            $"--pl-pace-threshold:{zones.Threshold}",
            $"--pl-pace-intervall:{zones.Intervall}",
            $"--pl-pace-repetition:{zones.Repetition}"
        };

        if (UsesPastelSurfaces(theme.Name))
        {
            styles.Add("--pl-pageheader-background:var(--mud-palette-background-gray)");
            styles.Add("--pl-panel-background:var(--mud-palette-surface)");
            styles.Add("--pl-accent-soft-base:var(--mud-palette-background-gray)");
            styles.Add("--pl-metric-tile-accent:22%");
            styles.Add("--pl-feed-tile-accent:18%");
            styles.Add("--pl-feed-tile-unread-accent:28%");
            styles.Add("--pl-card-accent:18%");
            styles.Add("--pl-course-detail-accent:16%");
            styles.Add("--pl-icon-accent:30%");
        }

        if (theme.Name == AppThemeName.Tropical)
        {
            styles.Add("--pl-pageheader-background:rgba(255,255,255,.58)");
            styles.Add("--pl-panel-background:rgba(255,255,255,.66)");
            styles.Add("--pl-accent-soft-base:rgba(204,241,223,.5)");
            styles.Add("--pl-card-accent:14%");
            styles.Add("--pl-feed-tile-accent:14%");
            styles.Add("--pl-feed-tile-unread-accent:22%");
            styles.Add("--pl-course-detail-accent:12%");
            styles.Add("--pl-icon-accent:24%");
        }

        return string.Join(";", styles);
    }

    private static bool UsesPastelSurfaces(AppThemeName themeName)
    {
        return themeName is AppThemeName.Forest
            or AppThemeName.Wildflowers
            or AppThemeName.CoteDAzur
            or AppThemeName.DarkRomance
            or AppThemeName.Maritime
            or AppThemeName.Tropical;
    }

    private void OnThemePreferenceChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemePreferences.Changed -= OnThemePreferenceChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
