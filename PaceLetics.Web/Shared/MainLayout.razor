@inherits LayoutComponentBase
@implements IDisposable
@using MudBlazor
@inject ThemePreferenceService ThemePreferences
@inject IStringLocalizer<MainLayout> L

<MudThemeProvider @ref="_themeProvider"
                  Theme="@ThemePreferences.CurrentTheme"
                  IsDarkMode="@ThemePreferences.IsDarkMode" />

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<PageTitle>PaceLetics</PageTitle>

<MudLayout Style="@GetThemeStyle()">
    <MudAppBar Elevation="1">

        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@((e) => DrawerToggle())" />
        <MudText Align="Align.Start">PaceLetics - Team Running</MudText>
        <MudSpacer />
        <AthleteMessageFeedButton />
        <MudMenu Icon="@GetThemeMenuIcon()"
                 Color="Color.Inherit"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <MudMenuItem Disabled="true">
                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Theme"]</MudText>
            </MudMenuItem>
            @foreach (var theme in ThemePreferences.Themes)
            {
                <MudMenuItem OnClick="@(() => ThemePreferences.SetThemeAsync(theme.Name))">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="min-width:180px;">
                        <MudIcon Icon="@theme.Icon" Size="Size.Small" />
                        <MudText>@GetThemeName(theme.Name)</MudText>
                        <MudSpacer />
                        @if (ThemePreferences.ThemeName == theme.Name)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                        }
                    </MudStack>
                </MudMenuItem>
            }
        </MudMenu>
        <CultureSelector />
        <LoginDisplay />

    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="margin-top: 24px;">
        @Body
    </MudMainContent>

    <LoadingHost />
</MudLayout>

@code {
    private bool _drawerOpen;
    private MudThemeProvider? _themeProvider;

    protected override void OnInitialized()
    {
        ThemePreferences.Changed += OnThemePreferenceChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _themeProvider is null)
            return;

        var systemPrefersDarkMode = await _themeProvider.GetSystemDarkModeAsync();
        await ThemePreferences.InitializeAsync(systemPrefersDarkMode);
        await _themeProvider.WatchSystemDarkModeAsync(ThemePreferences.SetSystemPrefersDarkModeAsync);
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private string GetThemeMenuIcon()
    {
        return ThemePreferences.CurrentThemeDefinition.Icon;
    }

    private string GetThemeName(AppThemeName themeName)
    {
        return AppThemeCatalog.GetThemeDefinition(themeName).DisplayName;
    }

    private string GetThemeStyle()
    {
        var theme = ThemePreferences.CurrentThemeDefinition;
        var zones = theme.PaceZones;
        var styles = new List<string>
        {
            $"--pl-pace-free:{zones.Free}",
            $"--pl-pace-recovery:{zones.Recovery}",
            $"--pl-pace-easy:{zones.Easy}",
            $"--pl-pace-marathon:{zones.Marathon}",
            $"--pl-pace-threshold:{zones.Threshold}",
            $"--pl-pace-intervall:{zones.Intervall}",
            $"--pl-pace-repetition:{zones.Repetition}"
        };

        if (UsesPastelSurfaces(theme.Name))
        {
            styles.Add("--pl-pageheader-background:var(--mud-palette-background-gray)");
            styles.Add("--pl-panel-background:var(--mud-palette-surface)");
            styles.Add("--pl-accent-soft-base:var(--mud-palette-background-gray)");
            styles.Add("--pl-metric-tile-accent:22%");
            styles.Add("--pl-feed-tile-accent:18%");
            styles.Add("--pl-feed-tile-unread-accent:28%");
            styles.Add("--pl-card-accent:18%");
            styles.Add("--pl-course-detail-accent:16%");
            styles.Add("--pl-icon-accent:30%");
        }

        return string.Join(";", styles);
    }

    private static bool UsesPastelSurfaces(AppThemeName themeName)
    {
        return themeName is AppThemeName.Forest
            or AppThemeName.Wildflowers
            or AppThemeName.Afterglow
            or AppThemeName.DarkRomance
            or AppThemeName.Maritime
            or AppThemeName.Tropical
            or AppThemeName.GoldenHour;
    }

    private void OnThemePreferenceChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemePreferences.Changed -= OnThemePreferenceChanged;
    }
}
