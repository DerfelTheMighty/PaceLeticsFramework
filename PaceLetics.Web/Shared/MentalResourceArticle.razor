@using PaceLetics.Web.Pages.Athletes
@inject IStringLocalizer<Dashboard> L

<MudStack Spacing="3">
    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="gap:12px;">
                <MentalResourceIcon Class="pl-mental-resource-icon--article-header" />
                <div>
                    <MudText Typo="Typo.overline">@L["MentalResource_Kicker"]</MudText>
                    <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["MentalResource_Title"]</MudText>
                </div>
            </MudStack>
            <MudText Typo="Typo.body2">
                @L["MentalResource_Lead"]
            </MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["MentalResource_StepEffectTitle"]</MudText>
            <MudText Typo="Typo.body2">
                @L["MentalResource_ResearchIntro"]
                @L["MentalResource_ResearchOswald"]
                <a class="pl-citation" href="@Sources[0].Url" target="_blank" rel="noopener noreferrer">[1]</a>
                @L["MentalResource_ResearchPereira"]
                <a class="pl-citation" href="@Sources[1].Url" target="_blank" rel="noopener noreferrer">[2]</a>
                @L["MentalResource_ResearchActivityReviews"]
                <a class="pl-citation" href="@Sources[2].Url" target="_blank" rel="noopener noreferrer">[3]</a>
                <a class="pl-citation" href="@Sources[3].Url" target="_blank" rel="noopener noreferrer">[4]</a>
                @L["MentalResource_ResearchCochrane"]
                <a class="pl-citation" href="@Sources[4].Url" target="_blank" rel="noopener noreferrer">[5]</a>
                @L["MentalResource_ResearchProspective"]
                <a class="pl-citation" href="@Sources[5].Url" target="_blank" rel="noopener noreferrer">[6]</a>
                @L["MentalResource_ResearchConclusion"]
            </MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">@L["MentalResource_SourcesTitle"]</MudText>
            <div class="pl-source-list">
            @foreach (var source in Sources)
            {
                <MudText Typo="Typo.caption" Class="pl-source-row">
                    <span class="pl-source-number">[@source.Number]</span>
                    <a href="@source.Url" target="_blank" rel="noopener noreferrer">@L[source.TitleKey]</a>
                </MudText>
            }
            </div>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private static readonly SourceRow[] Sources =
    {
        new("1", "MentalResource_SourceOswald", "https://doi.org/10.3390/ijerph17218059"),
        new("2", "MentalResource_SourcePereira", "https://doi.org/10.3389/fpsyg.2021.624783"),
        new("3", "MentalResource_SourceSingh", "https://doi.org/10.1136/bjsports-2022-106195"),
        new("4", "MentalResource_SourceNoetel", "https://doi.org/10.1136/bmj-2023-075847"),
        new("5", "MentalResource_SourceCochrane", "https://doi.org/10.1002/14651858.CD004366.pub7"),
        new("6", "MentalResource_SourcePearce", "https://doi.org/10.1001/jamapsychiatry.2022.0609")
    };

    private sealed record SourceRow(string Number, string TitleKey, string Url);
}
