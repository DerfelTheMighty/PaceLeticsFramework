@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IAchievementService AchievementService

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (string.IsNullOrWhiteSpace(_userId))
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Bitte melde dich an, um deine Achievements zu sehen.</MudAlert>
}
else
{
    <MudStack Spacing="4">
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.subtitle1">Freigeschaltet</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">@_awards.Count</MudChip>
            </MudStack>

            @if (_awards.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Noch keine Achievements freigeschaltet. Hake Trainingseinheiten ab oder schliesse Workouts ab.
                </MudAlert>
            }
            else
            {
                <div class="pl-achievement-grid">
                    @foreach (var award in _awards)
                    {
                        <MudPaper Elevation="0" Class="pa-4 pl-course-detail pl-achievement-card">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <AchievementIcon Icon="@award.IconSnapshot" Size="Size.Large" Title="@award.TitleSnapshot" />
                                <MudStack Spacing="0" Style="min-width:0;">
                                    <MudText Typo="Typo.subtitle2">@award.TitleSnapshot</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@award.DescriptionSnapshot</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@($"Freigeschaltet am {award.AwardedAt:dd.MM.yyyy}")</MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                </div>
            }
        </MudStack>

        @if (_openDefinitions.Count > 0)
        {
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1">Noch offen</MudText>
                <div class="pl-achievement-grid">
                    @foreach (var definition in _openDefinitions)
                    {
                        <MudPaper Elevation="0" Class="pa-4 pl-course-detail pl-achievement-card">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <AchievementIcon Icon="@definition.Icon" Size="Size.Large" Title="@definition.Title" Muted="true" />
                                <MudStack Spacing="0" Style="min-width:0;">
                                    <MudText Typo="Typo.subtitle2">@definition.Title</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@definition.Description</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@DescribeRules(definition)</MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                </div>
            </MudStack>
        }
    </MudStack>
}

@code {
    private string? _userId;
    private bool _isLoading = true;
    private List<AthleteAchievementDocument> _awards = new();
    private List<AchievementDefinitionDocument> _openDefinitions = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
            _userId = authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier"))?.Value;

            if (!string.IsNullOrWhiteSpace(_userId))
            {
                _awards = (await AchievementService.GetAwardsForAthleteAsync(_userId)).ToList();
                var awardedIds = _awards
                    .Select(award => award.AchievementDefinitionId)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);

                _openDefinitions = (await AchievementService.GetDefinitionsAsync())
                    .Where(definition => !awardedIds.Contains(definition.Id))
                    .ToList();
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string DescribeRules(AchievementDefinitionDocument definition)
    {
        if (definition.Rules.Count == 0)
            return "Keine Regel hinterlegt";

        return string.Join(" + ", definition.Rules.Select(DescribeRule));
    }

    private static string DescribeRule(AchievementRuleDocument rule)
    {
        return rule.RuleType switch
        {
            AchievementRuleTypes.TrainingSessionCompleted when rule.SessionIds.Count > 0 =>
                $"{rule.SessionIds.Count} bestimmte Einheit(en) abhaken",
            AchievementRuleTypes.TrainingSessionCompleted => "Eine Trainingseinheit abhaken",
            AchievementRuleTypes.TrainingSessionCount => $"{rule.TargetCount} Trainingseinheit(en) abhaken",
            AchievementRuleTypes.TrainingPlanCompleted => "Einen Trainingsplan vollstaendig abhaken",
            AchievementRuleTypes.WorkoutCompleted => "Ein Workout abschliessen",
            AchievementRuleTypes.WorkoutCount => $"{rule.TargetCount} Workout(s) abschliessen",
            AchievementRuleTypes.CourseEventCompleted => "An einem Kurstermin erfolgreich teilnehmen",
            AchievementRuleTypes.CourseCompleted => "Einen Kurs erfolgreich abschliessen",
            _ => "Regel erfuellen"
        };
    }
}
