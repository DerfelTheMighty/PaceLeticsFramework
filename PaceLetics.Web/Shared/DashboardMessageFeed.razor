@using PaceLetics.CoreModule.Infrastructure.Models
@inject IStringLocalizer<DashboardMessageFeed> L

<MudStack Spacing="2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.body2">@L["FeedTitle"]</MudText>

        <MudChip T="string"
                 Size="Size.Small"
                 Variant="Variant.Filled"
                 Color="Color.Primary">
            @Messages.Count
        </MudChip>
    </MudStack>

    @if (Messages.Count == 0)
    {
        <DashboardNewsFeedTile
            Title="@L["NoMessages"]"
            Icon="@Icons.Material.Filled.CheckCircle"
            Severity="Severity.Success" />
    }
    else
    {
        <MudStack Spacing="1">
            @foreach (var message in Messages)
            {
                <DashboardNewsFeedTile
                    Title="@L[message.TitleKey]"
                    Detail="@L[message.BodyKey, message.BodyArguments.ToArray()]"
                    Icon="@message.Icon"
                    Severity="@message.Severity"
                    Href="@message.ActionHref" />
            }
        </MudStack>
    }
</MudStack>

@code {
    [Parameter]
    public IReadOnlyList<AthleteMessage> Messages { get; set; } = Array.Empty<AthleteMessage>();
}