@using PaceLetics.CoreModule.Infrastructure.Models
@inject IStringLocalizer<DashboardMessageFeed> L

<MudPaper Elevation="0"
          Class="pa-4"
          Style="border-radius:20px; border:1px solid var(--mud-palette-lines-default); background:linear-gradient(180deg, var(--mud-palette-surface), var(--mud-palette-background));">

    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudAvatar Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.Campaign" Size="Size.Small" />
                </MudAvatar>

                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle2">@L["FeedTitle"]</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Aktuelle Hinweise für dein Training
                    </MudText>
                </MudStack>
            </MudStack>

            <MudBadge Content="@Messages.Count"
                      Color="Color.Primary"
                      Overlap="false">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsNone"
                         Color="Color.Secondary" />
            </MudBadge>
        </MudStack>

        <MudDivider />

        @if (Messages.Count == 0)
        {
            <DashboardNewsFeedTile Title="@L["NoMessages"]"
                                   Icon="@Icons.Material.Filled.CheckCircle"
                                   Severity="Severity.Success" />
        }
        else
        {
            <MudStack Spacing="1">
                @foreach (var message in Messages)
                {
                    <DashboardNewsFeedTile Title="@L[message.TitleKey]"
                                           Detail="@L[message.BodyKey, message.BodyArguments.ToArray()]"
                                           Icon="@message.Icon"
                                           Severity="@message.Severity"
                                           Href="@message.ActionHref" />
                }
            </MudStack>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<AthleteMessage> Messages { get; set; } = Array.Empty<AthleteMessage>();
}