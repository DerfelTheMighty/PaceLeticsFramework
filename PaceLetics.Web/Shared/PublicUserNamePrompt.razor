@using System.Security.Claims
@using System.Text.RegularExpressions
@using AthleteDataAccessLibrary.Contracts
@using Microsoft.AspNetCore.Identity
@using PaceLetics.AthleteModule.CodeBase.Models
@using PaceLetics.Web.Data
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAthleteData AthleteData
@inject UserManager<ApplicationUser> UserManager
@inject ISnackbar Snackbar
@inject IStringLocalizer<PublicUserNamePrompt> L

@if (_isVisible)
{
    <div class="pl-public-username-prompt">
        <MudPaper Elevation="8" Class="pl-public-username-prompt__panel pa-4">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">@L["Title"]</MudText>
                </MudStack>

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @L["Text"]
                </MudText>

                <MudTextField T="string"
                              Label="@L["PublicUserName"]"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Disabled="@_isSaving"
                              HelperText="@L["HelpText"]"
                              Error="@(!string.IsNullOrWhiteSpace(_validationMessage))"
                              ErrorText="@_validationMessage"
                              @bind-Value="_publicUserName"
                              OnKeyDown="OnKeyDownAsync" />

                <MudStack Row="true" Justify="Justify.FlexEnd" Style="gap:8px; flex-wrap:wrap;">
                    <MudButton Variant="Variant.Text"
                               Disabled="@_isSaving"
                               OnClick="Dismiss">
                        @L["Cancel"]
                    </MudButton>
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               Disabled="@_isSaving"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="SaveAsync">
                        @L["Save"]
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    private ApplicationUser? _user;
    private AthleteModel? _athlete;
    private IReadOnlyList<string> _roles = Array.Empty<string>();
    private string _publicUserName = string.Empty;
    private string? _validationMessage;
    private bool _isVisible;
    private bool _isSaving;
    private bool _isDismissed;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        if (_isDismissed)
            return;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated != true)
                return;

            _user = await UserManager.GetUserAsync(authState.User);
            if (_user is null)
                return;

            _roles = (await UserManager.GetRolesAsync(_user)).ToList();
            _athlete = await AthleteData.GetAthlete(_user.Id);
            var userName = await UserManager.GetUserNameAsync(_user) ?? string.Empty;
            var email = await UserManager.GetEmailAsync(_user) ?? authState.User.FindFirstValue(ClaimTypes.Email) ?? string.Empty;

            if (!IsMissingPublicUserName(_athlete?.PublicProfile, userName, email))
                return;

            _publicUserName = SuggestPublicUserName(_athlete?.Name, userName, email);
            _isVisible = true;
        }
        catch
        {
            _isVisible = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_user is null)
            return;

        _validationMessage = null;
        var publicUserName = _publicUserName.Trim();
        if (string.IsNullOrWhiteSpace(publicUserName))
        {
            _validationMessage = L["Required"];
            return;
        }

        if (!IsPublicUserNameFormatValid(publicUserName))
        {
            _validationMessage = L["InvalidCharacters"];
            return;
        }

        _isSaving = true;
        try
        {
            if (await PublicUserNameExistsAsync(publicUserName, _user.Id))
            {
                _validationMessage = L["AlreadyTaken"];
                return;
            }

            var userName = await UserManager.GetUserNameAsync(_user) ?? _user.Id;
            _athlete ??= new AthleteModel
            {
                Id = _user.Id,
                Name = userName
            };

            var currentProfile = _athlete.PublicProfile ?? new PublicProfileModel();
            _athlete.PublicProfile = new PublicProfileModel
            {
                PublicUserName = publicUserName,
                NormalizedPublicUserName = NormalizePublicUserName(publicUserName),
                ProfileImageUrl = currentProfile.ProfileImageUrl,
                IsProfileVisible = currentProfile.IsProfileVisible,
                PublicRole = string.IsNullOrWhiteSpace(currentProfile.PublicRole) || currentProfile.PublicRole == "NA"
                    ? GetPublicRole(_roles)
                    : currentProfile.PublicRole
            };

            if (string.IsNullOrWhiteSpace(_athlete.Name) || _athlete.Name == "NA" || IsEmailLike(_athlete.Name))
                _athlete.Name = publicUserName;

            await AthleteData.UpdateAthlete(_athlete);
            _isVisible = false;
            Snackbar.Add(L["Saved"], Severity.Success);
        }
        catch (Exception ex)
        {
            _validationMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private Task OnKeyDownAsync(KeyboardEventArgs args)
    {
        return args.Key == "Enter"
            ? SaveAsync()
            : Task.CompletedTask;
    }

    private void Dismiss()
    {
        _isDismissed = true;
        _isVisible = false;
    }

    private async Task<bool> PublicUserNameExistsAsync(string publicUserName, string exceptUserId)
    {
        var normalizedPublicUserName = NormalizePublicUserName(publicUserName);
        var athletes = await AthleteData.GetAthletes();
        return athletes.Any(athlete =>
            athlete.Id != exceptUserId
            && athlete.PublicProfile is not null
            && string.Equals(
                athlete.PublicProfile.NormalizedPublicUserName,
                normalizedPublicUserName,
                StringComparison.Ordinal));
    }

    private static bool IsMissingPublicUserName(PublicProfileModel? publicProfile, string userName, string email)
    {
        var value = publicProfile?.PublicUserName?.Trim();
        return string.IsNullOrWhiteSpace(value)
            || value.Equals("NA", StringComparison.OrdinalIgnoreCase)
            || IsEmailLike(value)
            || (!string.IsNullOrWhiteSpace(email) && value.Equals(email, StringComparison.OrdinalIgnoreCase))
            || (IsEmailLike(userName) && value.Equals(userName, StringComparison.OrdinalIgnoreCase));
    }

    private static string SuggestPublicUserName(string? athleteName, string userName, string email)
    {
        var candidate = !string.IsNullOrWhiteSpace(athleteName) && athleteName != "NA" && !IsEmailLike(athleteName)
            ? athleteName
            : userName;

        if (string.IsNullOrWhiteSpace(candidate) || IsEmailLike(candidate) || candidate.Equals(email, StringComparison.OrdinalIgnoreCase))
            return string.Empty;

        return Regex.Replace(candidate.Trim(), @"[^A-Za-z0-9._-]+", "-").Trim('-');
    }

    private static string GetPublicRole(IReadOnlyList<string> roles)
    {
        return roles.Contains(ApplicationRoles.Trainer)
            ? ApplicationRoles.Trainer
            : ApplicationRoles.Athlete;
    }

    private static string NormalizePublicUserName(string value)
    {
        return value.Trim().ToUpperInvariant();
    }

    private static bool IsPublicUserNameFormatValid(string value)
    {
        return Regex.IsMatch(value, @"\A[A-Za-z0-9._-]+\z");
    }

    private static bool IsEmailLike(string? value)
    {
        return !string.IsNullOrWhiteSpace(value) && value.Contains('@');
    }
}
