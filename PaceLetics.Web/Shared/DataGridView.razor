@using PaceLetics.AthleteModule.CodeBase.Models;
@using PaceLetics.CoreModule.Infrastructure.Interfaces
@using PaceLetics.CoreModule.Infrastructure.Models
@inject IStringLocalizer<DataGridView> L
@inject ICriticalSpeedService CriticalSpeedService

@if (Athletes == null)
{
    <LoadingScreen Label="@L["Loading"]" />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@L["Name"]</th>
                <th>Critical Speed</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var athlete in Athletes)
            {
                <tr>
                    <td>@athlete.Name</td>
                    <td>@GetCriticalSpeed(athlete)</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter]
    public IList<AthleteModel> Athletes{ get; set; } = new List<AthleteModel>();

    private string GetCriticalSpeed(AthleteModel athlete)
    {
        var results = athlete.RaceResults?.ToList() ?? [];
        if (athlete.ActiveReferenceResult is not null
            && !results.Any(result => result.DistanceM == athlete.ActiveReferenceResult.DistanceM
                && result.Time == athlete.ActiveReferenceResult.Time
                && result.Date.Date == athlete.ActiveReferenceResult.Date.Date))
        {
            results.Add(athlete.ActiveReferenceResult);
        }

        var model = CriticalSpeedService.Estimate(results);
        return model.IsValid ? $"{model.CriticalSpeedMps:0.00} m/s" : "-";
    }

}
