@using MudBlazor
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<LoginDisplay> L

<AuthorizeView Context="accountContext">
    <Authorized>
        <MudMenu Icon="@Icons.Material.Outlined.AccountBox"
                 Color="Color.Inherit"
                 aria-label="@L["AccountMenu"]"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <MudMenuItem Href="Identity/Account/Manage">
                @L["ManageProfile"]
            </MudMenuItem>
            <MudMenuItem Href="/Athletes/settings">
                @L["Settings"]
            </MudMenuItem>
            <AuthorizeView Roles="@ApplicationRoles.Trainer" Context="trainerContext">
                <Authorized>
                    <MudMenuItem Href="/Trainers">@L["TrainerArea"]</MudMenuItem>
                </Authorized>
            </AuthorizeView>
            <MudDivider />
            <MudMenuItem OnClick="LogOutAsync">
                @L["LogOut"]
            </MudMenuItem>
        </MudMenu>
    </Authorized>
    <NotAuthorized>
        <a href="Identity/Account/Register">@L["Register"]</a>
        <a href="Identity/Account/Login">@L["LogIn"]</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task LogOutAsync()
    {
        await JS.InvokeVoidAsync("eval", """
            (() => {
                const form = document.createElement('form');
                form.method = 'post';
                form.action = '/Identity/Account/Logout';
                document.body.appendChild(form);
                form.submit();
            })()
            """);
    }
}
