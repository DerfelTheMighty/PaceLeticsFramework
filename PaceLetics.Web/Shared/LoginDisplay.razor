@using System.Globalization
@using MudBlazor
@using PaceLetics.Web.Localization
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<LoginDisplay> L

<AuthorizeView>
    <Authorized>
        <MudMenu Icon="@Icons.Material.Outlined.AccountBox"
                 Color="Color.Inherit"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <MudMenuItem Href="Identity/Account/Manage" Icon="@Icons.Material.Outlined.ManageAccounts">
                @L["ManageProfile"]
            </MudMenuItem>
            <MudMenuItem Disabled="true">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="min-width:180px;">
                    <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Language"]</MudText>
                </MudStack>
            </MudMenuItem>
            @foreach (var culture in SupportedCultures.All)
            {
                <MudMenuItem OnClick="@(() => SetCulture(culture.Code))">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="min-width:180px;">
                        <MudText>@culture.NativeName</MudText>
                        <MudSpacer />
                        @if (IsCurrentCulture(culture.Code))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                        }
                    </MudStack>
                </MudMenuItem>
            }
            <MudDivider />
            <MudMenuItem OnClick="LogOutAsync" Icon="@Icons.Material.Outlined.Logout">
                @L["LogOut"]
            </MudMenuItem>
        </MudMenu>
    </Authorized>
    <NotAuthorized>
        <a href="Identity/Account/Register">@L["Register"]</a>
        <a href="Identity/Account/Login">@L["LogIn"]</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool IsCurrentCulture(string culture)
        => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == culture;

    private async Task SetCulture(string culture)
    {
        var cookieValue = $"c={culture}|uic={culture}";
        await JS.InvokeVoidAsync("eval",
            $"document.cookie='.AspNetCore.Culture={cookieValue};path=/;max-age=31536000;samesite=lax'");
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }

    private async Task LogOutAsync()
    {
        await JS.InvokeVoidAsync("eval", """
            (() => {
                const form = document.createElement('form');
                form.method = 'post';
                form.action = '/Identity/Account/Logout';
                document.body.appendChild(form);
                form.submit();
            })()
            """);
    }
}
