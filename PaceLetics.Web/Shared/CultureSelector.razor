@using System.Globalization
@inject NavigationManager Navigation
@inject IJSRuntime JS

<MudMenu Icon="@Icons.Material.Filled.Language"
         Color="Color.Inherit"
         AnchorOrigin="Origin.BottomRight"
         TransformOrigin="Origin.TopRight">
    <MudMenuItem OnClick='() => SetCulture("de")'>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudText>Deutsch</MudText>
            @if (IsCurrentCulture("de"))
            {
                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
            }
        </MudStack>
    </MudMenuItem>
    <MudMenuItem OnClick='() => SetCulture("en")'>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudText>English</MudText>
            @if (IsCurrentCulture("en"))
            {
                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
            }
        </MudStack>
    </MudMenuItem>
</MudMenu>

@code {
    private bool IsCurrentCulture(string culture)
        => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == culture;

    private async Task SetCulture(string culture)
    {
        var cookieValue = $"c={culture}|uic={culture}";
        await JS.InvokeVoidAsync("eval",
            $"document.cookie='.AspNetCore.Culture={cookieValue};path=/;max-age=31536000;samesite=lax'");
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }
}
