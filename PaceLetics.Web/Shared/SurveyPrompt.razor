@inject IStringLocalizer<SurveyPrompt> L

<div class="alert alert-secondary mt-4">
    <span class="oi oi-pencil me-2" aria-hidden="true"></span>
    <strong>@Title</strong>

    <span class="text-nowrap">
        @L["PleaseTakeOur"]
        <a target="_blank" class="font-weight-bold link-dark" href="https://go.microsoft.com/fwlink/?linkid=2186158">@L["BriefSurvey"]</a>
    </span>
    @L["TellUs"]
</div>

@code {
    [Parameter]
    public string? Title { get; set; }
}
