@inject IStringLocalizer<NavMenu> L
@inject NavigationManager Navigation
@implements IDisposable

<nav class="pl-bottom-nav" aria-label="Mobile navigation">
    <NavLink href="/"
             class="@GetItemClass(MobileSection.Dashboard)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.All"
             title="@L["Nav_Dashboard"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Dashboard"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/teams"
             class="@GetItemClass(MobileSection.Teams)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Teams"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Teams"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/courses"
             class="@GetItemClass(MobileSection.Courses)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Courses"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Courses"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/academy"
             class="@GetItemClass(MobileSection.Academy)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Academy"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Academy"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/data-analyses"
             class="@GetItemClass(MobileSection.Data)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_DataAnalyses"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_DataAnalyses"]</span>
        </span>
    </NavLink>
</nav>

@code {
    private enum MobileSection
    {
        Dashboard,
        Teams,
        Courses,
        Academy,
        Data
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private string GetItemClass(MobileSection section)
        => IsSectionActive(section)
            ? "pl-bottom-nav__item pl-bottom-nav__item--active"
            : "pl-bottom-nav__item";

    private bool IsSectionActive(MobileSection section)
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri)
            .Split('?', '#')[0]
            .Trim('/')
            .ToLowerInvariant();

        return section switch
        {
            MobileSection.Dashboard => string.IsNullOrEmpty(path)
                || path.StartsWith("athletes/dashboard")
                || path.StartsWith("workouts/"),
            MobileSection.Teams => path.StartsWith("athletes/teams")
                || path.StartsWith("athletes/groups")
                || path.StartsWith("athletes/mate")
                || path.StartsWith("profiles"),
            MobileSection.Courses => path.StartsWith("athletes/courses")
                || path.StartsWith("athletes/trainingcalendar")
                || path.StartsWith("athletes/trainingplanpage"),
            MobileSection.Academy => path.StartsWith("athletes/academy")
                || path.StartsWith("academy"),
            MobileSection.Data => path.StartsWith("athletes/data-analyses")
                || path.StartsWith("athletes/racepaces")
                || path.StartsWith("athletes/pacezones")
                || path.StartsWith("athletes/analyses"),
            _ => false
        };
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
