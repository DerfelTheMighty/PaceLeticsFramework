@inject IStringLocalizer<NavMenu> L

<nav class="pl-bottom-nav" aria-label="Mobile navigation">
    <NavLink href="/Athletes/dashboard"
             class="pl-bottom-nav__item"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.All"
             title="@L["Nav_Dashboard"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Dashboard"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/teams"
             class="pl-bottom-nav__item"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Teams"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Teams"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/courses"
             class="pl-bottom-nav__item"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Courses"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Courses"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/academy"
             class="pl-bottom-nav__item"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Academy"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Academy"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/data-analyses"
             class="pl-bottom-nav__item"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_DataAnalyses"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_DataAnalyses"]</span>
        </span>
    </NavLink>
</nav>
