@inject IStringLocalizer<NavMenu> L
@inject NavigationManager Navigation
@implements IDisposable

<nav class="pl-bottom-nav" aria-label="@L["MobileNavigation"]">
    <NavLink href="/"
             class="@GetItemClass(MobileSection.Dashboard)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.All"
             title="@L["Nav_Dashboard"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Dashboard"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/plan"
             class="@GetItemClass(MobileSection.Plan)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Plan"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Plan"]</span>
        </span>
    </NavLink>

    <NavLink href="/Workouts/workoutarea"
             class="@GetItemClass(MobileSection.Train, isPrimary: true)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Train"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon pl-bottom-nav__icon--primary" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Train"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/data-analyses"
             class="@GetItemClass(MobileSection.Progress)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_Progress"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_Progress"]</span>
        </span>
    </NavLink>

    <NavLink href="/Athletes/more"
             class="@GetItemClass(MobileSection.More)"
             ActiveClass="pl-bottom-nav__item--active"
             Match="NavLinkMatch.Prefix"
             title="@L["Nav_More"]">
        <span class="pl-bottom-nav__content">
            <span class="pl-bottom-nav__icon" aria-hidden="true">
                <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="Size.Medium" />
            </span>
            <span class="pl-bottom-nav__label">@L["Nav_More"]</span>
        </span>
    </NavLink>
</nav>

@code {
    private enum MobileSection
    {
        Dashboard,
        Plan,
        Train,
        Progress,
        More
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private string GetItemClass(MobileSection section, bool isPrimary = false)
    {
        var classes = new List<string> { "pl-bottom-nav__item" };
        if (isPrimary)
            classes.Add("pl-bottom-nav__item--primary");
        if (IsSectionActive(section))
            classes.Add("pl-bottom-nav__item--active");
        return string.Join(" ", classes);
    }

    private bool IsSectionActive(MobileSection section)
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri)
            .Split('?', '#')[0]
            .Trim('/')
            .ToLowerInvariant();
        var query = new Uri(Navigation.Uri).Query.ToLowerInvariant();
        var isCombinedPlanQuery = path.StartsWith("athletes/courses")
            && (query.Contains("section=plan", StringComparison.Ordinal)
                || query.Contains("section=calendar", StringComparison.Ordinal));

        return section switch
        {
            MobileSection.Dashboard => string.IsNullOrEmpty(path) || path.StartsWith("athletes/dashboard"),
            MobileSection.Plan => path.StartsWith("athletes/plan")
                || path.StartsWith("athletes/session")
                || path.StartsWith("athletes/trainingcalendar")
                || path.StartsWith("athletes/trainingplanpage")
                || isCombinedPlanQuery,
            MobileSection.Train => path.StartsWith("workouts/"),
            MobileSection.Progress => path.StartsWith("athletes/data-analyses")
                || path.StartsWith("athletes/racepaces")
                || path.StartsWith("athletes/pacezones")
                || path.StartsWith("athletes/analyses"),
            MobileSection.More => path.StartsWith("athletes/more")
                || path.StartsWith("athletes/teams")
                || path.StartsWith("athletes/groups")
                || path.StartsWith("athletes/mate")
                || (path.StartsWith("athletes/courses") && !isCombinedPlanQuery)
                || path.StartsWith("athletes/academy")
                || path.StartsWith("athletes/achievements")
                || path.StartsWith("academy")
                || path.StartsWith("profiles"),
            _ => false
        };
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args) =>
        _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}
