@inject IStringLocalizer<NavMenu> L

<MudNavMenu>
    <MudNavLink Href="/"
                Icon="@Icons.Material.Filled.Today"
                Match="NavLinkMatch.All">
        @L["Nav_Today"]
    </MudNavLink>
    <MudNavLink Href="/Athletes/plan"
                Icon="@Icons.Material.Filled.CalendarMonth"
                Match="NavLinkMatch.Prefix">
        @L["Nav_Plan"]
    </MudNavLink>
    <MudNavLink Href="/Workouts/workoutarea"
                Icon="@Icons.Material.Filled.PlayArrow"
                Match="NavLinkMatch.Prefix">
        @L["Nav_Train"]
    </MudNavLink>
    <MudNavLink Href="/Athletes/data-analyses"
                Icon="@Icons.Material.Filled.TrendingUp"
                Match="NavLinkMatch.Prefix">
        @L["Nav_Progress"]
    </MudNavLink>
    <MudNavLink Href="/Athletes/more"
                Icon="@Icons.Material.Filled.MoreHoriz"
                Match="NavLinkMatch.Prefix">
        @L["Nav_More"]
    </MudNavLink>

    <AuthorizeView Roles="@ApplicationRoles.Trainer">
        <Authorized>
            <MudDivider Class="my-2" />
            <MudNavGroup Title="Trainer" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="false">
                <MudNavLink Href="/Trainers/courses" Match="NavLinkMatch.Prefix">@L["Nav_TrainerCourses"]</MudNavLink>
                <MudNavLink Href="/Trainers/groups" Match="NavLinkMatch.Prefix">@L["Nav_Groups"]</MudNavLink>
                <MudNavLink Href="/Trainers/training-plans" Match="NavLinkMatch.Prefix">@L["Nav_TrainingPlan"]</MudNavLink>
                <MudNavLink Href="/Trainers/achievements" Match="NavLinkMatch.Prefix">@L["Nav_Achievements"]</MudNavLink>
                <MudNavLink Href="/Trainers/running-analyses" Match="NavLinkMatch.Prefix">@L["Nav_TrainerRunningAnalyses"]</MudNavLink>
                <MudNavLink Href="/Trainers/workout-catalog" Match="NavLinkMatch.Prefix">@L["Nav_TrainerWorkoutCatalog"]</MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
