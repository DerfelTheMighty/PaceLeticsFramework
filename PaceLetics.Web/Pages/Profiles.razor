@page "/profiles"
@page "/profiles/{PublicUserName}"
@using AthleteDataAccessLibrary.Contracts
@using PaceLetics.AthleteModule.CodeBase.Models
@inject IAthleteData AthleteData
@inject LoadingStateService Loading
@inject IStringLocalizer<Profiles> L

@if (!Embedded)
{
    <PageTitle>@L["PageTitle"]</PageTitle>
}

<MudContainer Class="@ContainerClass" MaxWidth="MaxWidth.Small">
    @if (_selectedProfile is not null)
    {
        <PageHeader Title="@_selectedProfile.PublicUserName" Subtitle="@GetRoleDisplayName(_selectedProfile.PublicRole)">
            <Actions>
                <MudTooltip Text="@L["Back"]">
                    <MudIconButton Href="/profiles"
                                   Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Icon="@Icons.Material.Filled.ArrowBack"
                                   aria-label="@L["Back"]" />
                </MudTooltip>
            </Actions>
        </PageHeader>

        <MudDivider Class="my-4" />

        <MudPaper Elevation="0"
                  Class="pa-4 pl-panel">
            <MudPaper Elevation="2" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    @ProfileAvatar(_selectedProfile, Size.Large)

                    <MudStack Spacing="0" Style="flex:1; min-width:0;">
                        <MudText Typo="Typo.h5">@_selectedProfile.PublicUserName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @GetRoleDisplayName(_selectedProfile.PublicRole)
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudPaper>
    }
    else if (_profileNotFound)
    {
        <PageHeader Title="@L["NotFoundTitle"]" Subtitle="@L["NotFoundSubtitle"]" />

        <MudDivider Class="my-4" />

        <DashboardNewsFeedTile Title="@L["NotFoundTitle"]"
                               Detail="@L["NotFoundDetail"]"
                               Icon="@Icons.Material.Filled.PersonSearch"
                               Severity="Severity.Warning"
                               Href="/profiles" />
    }
    else
    {
        @if (!Embedded)
        {
            <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

            <MudDivider Class="my-4" />
        }

        <MudStack Spacing="4">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6" lg="4">
                    <DashboardMetricTile Label="@L["MetricVisible"]"
                                         Value="@_profiles.Count.ToString()"
                                         Detail="@L["MetricVisibleDetail"]"
                                         Icon="@Icons.Material.Filled.Groups"
                                         Accent="blue" />
                </MudItem>

                <MudItem xs="12" sm="6" lg="4">
                    <DashboardMetricTile Label="@L["MetricTrainers"]"
                                         Value="@_profiles.Count(profile => profile.PublicRole == ApplicationRoles.Trainer).ToString()"
                                         Detail="@L["MetricTrainersDetail"]"
                                         Icon="@Icons.Material.Filled.Verified"
                                         Accent="green" />
                </MudItem>

                <MudItem xs="12" sm="6" lg="4">
                    <DashboardMetricTile Label="@L["MetricAthletes"]"
                                         Value="@_profiles.Count(profile => profile.PublicRole == ApplicationRoles.Athlete).ToString()"
                                         Detail="@L["MetricAthletesDetail"]"
                                         Icon="@Icons.Material.Filled.DirectionsRun"
                                         Accent="orange" />
                </MudItem>
            </MudGrid>

            @if (_profiles.Count == 0)
            {
                <DashboardNewsFeedTile Title="@L["NoProfilesTitle"]"
                                       Detail="@L["NoProfilesDetail"]"
                                       Icon="@Icons.Material.Filled.VisibilityOff"
                                       Severity="Severity.Info"
                                       Href="/Identity/Account/Manage" />
            }
            else
            {
                <MudGrid Spacing="3">
                    @foreach (var profile in _profiles)
                    {
                        <MudItem xs="12">
                            <MudLink Href="@GetProfileHref(profile)" Underline="Underline.None">
                                <MudPaper Elevation="0"
                                          Class="pa-4 pl-panel">
                                    <MudPaper Elevation="2" Class="pa-3">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            @ProfileAvatar(profile, Size.Medium)

                                            <MudStack Spacing="0" Style="flex:1; min-width:0;">
                                                <MudText Typo="Typo.body2">@profile.PublicUserName</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @GetRoleDisplayName(profile.PublicRole)
                                                </MudText>
                                            </MudStack>

                                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward"
                                                     Size="Size.Small"
                                                     Color="Color.Secondary" />
                                        </MudStack>
                                    </MudPaper>
                                </MudPaper>
                            </MudLink>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter]
    public bool Embedded { get; set; }

    [Parameter]
    public string? PublicUserName { get; set; }

    private bool _profileNotFound;
    private List<PublicProfileModel> _profiles = new();
    private PublicProfileModel? _selectedProfile;

    private string ContainerClass => Embedded
        ? "pa-0"
        : "pt-6 px-6 pb-8";

    protected override async Task OnParametersSetAsync()
    {
        await Loading.RunAsync(L["Loading"], async () =>
        {
            _profileNotFound = false;
            _selectedProfile = null;

            _profiles = (await AthleteData.GetPublicAthletes())
                .Select(athlete => athlete.PublicProfile)
                .Where(profile => profile is not null
                    && profile.IsProfileVisible
                    && !string.IsNullOrWhiteSpace(profile.PublicUserName)
                    && profile.PublicUserName != "NA")
                .OrderBy(profile => profile.PublicUserName)
                .ToList();

            if (!string.IsNullOrWhiteSpace(PublicUserName))
            {
                var normalizedPublicUserName = NormalizePublicUserName(PublicUserName);
                _selectedProfile = _profiles.FirstOrDefault(profile =>
                    profile.NormalizedPublicUserName == normalizedPublicUserName);
                _profileNotFound = _selectedProfile is null;
            }
        });
    }

    private static string GetProfileHref(PublicProfileModel profile)
    {
        return $"/profiles/{Uri.EscapeDataString(profile.PublicUserName)}";
    }

    private static string NormalizePublicUserName(string value)
    {
        return value.Trim().ToUpperInvariant();
    }

    private string GetRoleDisplayName(string role)
    {
        return role switch
        {
            ApplicationRoles.Athlete => L["RoleAthlete"],
            ApplicationRoles.Trainer => L["RoleTrainer"],
            _ => role
        };
    }

    private static string GetInitial(PublicProfileModel profile)
    {
        return profile.PublicUserName.Trim().Substring(0, 1).ToUpperInvariant();
    }

    private RenderFragment ProfileAvatar(PublicProfileModel profile, Size size) => @<MudAvatar Size="@size"
                                                                                               Color="Color.Primary"
                                                                                               Variant="Variant.Filled">
        @if (string.IsNullOrWhiteSpace(profile.ProfileImageUrl))
        {
            @GetInitial(profile)
        }
        else
        {
            <MudImage Src="@profile.ProfileImageUrl"
                      Alt="@profile.PublicUserName"
                      Style="width:100%; height:100%; object-fit:cover;" />
        }
    </MudAvatar>;
}
