@page "/"
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Mvc.Localization
@using System.Globalization
@attribute [Authorize]
@namespace PaceLetics.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject IViewLocalizer Localizer
@{
    var textDirection = CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft ? "rtl" : "ltr";
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentCulture.TwoLetterISOLanguageName" dir="@textDirection">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link id="mudex-styles" href="_content/MudBlazor.Extensions/mudBlazorExtensions.min.css" rel="stylesheet">

    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="PaceLetics.Web.styles.css" rel="stylesheet" />
    <link href="css/app-theme.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png"/>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered"
               param-InitialCulture="@CultureInfo.CurrentCulture.Name" />
    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            @Localizer["ProductionError"]
        </environment>
        <environment include="Development">
            @Localizer["DevelopmentError"]
        </environment>
        <a href="" class="reload">@Localizer["Reload"]</a>
        <a class="dismiss">🗙</a>
    </div>
    <script src="_framework/blazor.server.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="~/js/main.js?v=@DateTime.UtcNow.Ticks"></script>
</body>
</html>
