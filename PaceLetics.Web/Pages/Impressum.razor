@page "/impressum"

@using MudBlazor

@inject IStringLocalizer<Impressum> L

<PageTitle>@L["Title"]</PageTitle>

<MudContainer Class="pt-6 px-6 pb-8" MaxWidth="MaxWidth.Small">

    <PageHeader Title="@L["Title"]"
                Subtitle="@L["Intro"]" />

    <MudDivider Class="my-4" />

    <MudStack Spacing="4">

        <section>
            <MudText Typo="Typo.h6">@L["ResponsibleHeading"]</MudText>
            <MudText Typo="Typo.body1">@L["ResponsibleText"] @_model.Name, @_model.Street, @_model.PostalCode @_model.City, @L["Country"].</MudText>
        </section>

        <section>
            <MudText Typo="Typo.h6">@L["TaxHeading"]</MudText>
            <MudText Typo="Typo.body1">@L["VatId"]: @L["VatIdNotProvided"]</MudText>
            <MudText Typo="Typo.body1">@L["RegisterEntry"]: @L["RegisterEntryNotProvided"]</MudText>
        </section>

        <section>
            <MudText Typo="Typo.h6">@L["DisputeHeading"]</MudText>
            <MudText Typo="Typo.body1">@L["DisputeText"]</MudText>
        </section>

        <section>
            <MudText Typo="Typo.h6">@L["LiabilityHeading"]</MudText>
            <MudText Typo="Typo.body1">@L["LiabilityOwnContent"]</MudText>
            <MudText Typo="Typo.body1">@L["LiabilityLinks"]</MudText>
        </section>

        <section>
            <MudText Typo="Typo.h6">@L["CopyrightHeading"]</MudText>
            <MudText Typo="Typo.body1">@L["CopyrightText"]</MudText>
        </section>

        <section>
            <MudText Typo="Typo.h6">@L["PrivacyHeading"]</MudText>
            <MudText Typo="Typo.body1">@L["PrivacyText"]</MudText>
        </section>

        <section>
            <MudText Typo="Typo.h6">@L["ProviderHeading"]</MudText>
            <MudText Typo="Typo.body1">
                <strong>@_model.Name</strong><br />
                @_model.Street<br />
                @_model.PostalCode @_model.City<br />
                @L["Country"]
            </MudText>
            <MudText Typo="Typo.body1" Class="mt-2">
                @L["Phone"]: @_model.PhoneNumber<br />
                @L["EmailLabel"]: <MudLink Href="@($"mailto:{_model.Email}")">@_model.Email</MudLink>
            </MudText>
        </section>

    </MudStack>

</MudContainer>

@code {
    private sealed class ImpressumModel
    {
        public string Name { get; } = "Christoph Otte";
        public string Street { get; } = "Effengrube 7";
        public string PostalCode { get; } = "23552";
        public string City { get; } = "Lübeck";
        public string PhoneNumber { get; } = "0162 6057269";
        public string Email { get; } = "mail@caotte.de";
    }

    private readonly ImpressumModel _model = new();
}
