@page "/Trainers/achievements"
@attribute [Authorize(Roles = ApplicationRoles.Trainer)]
@using PaceLetics.TrainingModule.CodeBase.Workouts.Interfaces
@using PaceLetics.TrainingPlanModule.CodeBase.Models
@using PaceLetics.Web.Services.Courses

@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IAchievementService AchievementService
@inject ITrainingPlanService TrainingPlanService
@inject IWorkoutCatalog WorkoutCatalog
@inject ICourseService CourseService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Achievements> L

<MudContainer Class="pt-6 px-6 pb-8" MaxWidth="MaxWidth.Large">
    <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

    <MudDivider Class="my-4" />

    <MudGrid Spacing="3">
        <MudItem xs="12" md="5">
            <MudPaper Elevation="0" Class="pa-4 pl-course-detail">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.subtitle1">@L["Definitions"]</MudText>
                        <MudTooltip Text="@L["New"]">
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="ResetEditor" aria-label="@L["NewAchievement"]" />
                        </MudTooltip>
                    </MudStack>

                    @if (_isLoading)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                    }
                    else if (_definitions.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["NoAchievements"]</MudText>
                    }
                    else
                    {
                        @foreach (var definition in _definitions)
                        {
                            <MudPaper Elevation="0" Class="pa-3 pl-bottom-sheet-item">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <AchievementIcon Icon="@definition.Icon" Title="@definition.Title" />
                                    <MudStack Spacing="0" Style="min-width:0;flex:1;">
                                        <MudText Typo="Typo.subtitle2">@definition.Title</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@DescribeRules(definition)</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Color="@(definition.IsPublished ? Color.Success : Color.Default)"
                                                     Variant="Variant.Outlined">
                                                @(definition.IsPublished ? L["Published"] : L["Draft"])
                                            </MudChip>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@($"v{definition.Version}")</MudText>
                                        </MudStack>
                                    </MudStack>
                                    <MudTooltip Text="@L["Edit"]">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" OnClick="@(() => Edit(definition))" aria-label="@string.Format(L["EditNamed"], definition.Title)" />
                                    </MudTooltip>
                                </MudStack>
                            </MudPaper>
                        }
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Elevation="0" Class="pa-4 pl-course-detail">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.subtitle1">@(_editingDefinitionId is null ? L["NewAchievement"] : L["EditAchievement"])</MudText>
                        <AchievementIcon Icon="@BuildIcon()" Size="Size.Large" Title="@_title" />
                    </MudStack>

                    <MudTextField @bind-Value="_title" Label="@L["AchievementTitle"]" Variant="Variant.Outlined" Immediate="true" Required="true" />
                    <MudTextField @bind-Value="_description" Label="@L["Description"]" Variant="Variant.Outlined" Lines="3" />
                    <MudSwitch T="bool" @bind-Value="_isPublished" Color="Color.Success" Label="@L["Published"]" />

                    <MudDivider />

                    <MudText Typo="Typo.subtitle2">@L["Icon"]</MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_iconName" Label="@L["Symbol"]" Variant="Variant.Outlined">
                                @foreach (var option in IconOptions)
                                {
                                    <MudSelectItem T="string" Value="@option.Value">@L[$"Icon_{option.Value}"]</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_iconShape" Label="@L["Shape"]" Variant="Variant.Outlined">
                                <MudSelectItem T="string" Value="@("circle")">@L["Round"]</MudSelectItem>
                                <MudSelectItem T="string" Value="@("square")">@L["Square"]</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <ColorTextField Label="@L["Background"]" @bind-Value="_backgroundColor" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <ColorTextField Label="@L["Foreground"]" @bind-Value="_foregroundColor" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <ColorTextField Label="@L["Accent"]" @bind-Value="_accentColor" />
                        </MudItem>
                    </MudGrid>

                    <MudDivider />

                    <MudText Typo="Typo.subtitle2">@L["Rule"]</MudText>
                    <MudSelect T="string" @bind-Value="_ruleType" Label="@L["RuleType"]" Variant="Variant.Outlined">
                        <MudSelectItem T="string" Value="@AchievementRuleTypes.TrainingSessionCompleted">@L["RuleSpecificSession"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@AchievementRuleTypes.TrainingSessionCount">@L["RuleSessionCount"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@AchievementRuleTypes.TrainingPlanCompleted">@L["RulePlan"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@AchievementRuleTypes.WorkoutCompleted">@L["RuleWorkout"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@AchievementRuleTypes.WorkoutCount">@L["RuleWorkoutCount"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@AchievementRuleTypes.CourseEventCompleted">@L["RuleCourseEvent"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@AchievementRuleTypes.CourseCompleted">@L["RuleCourse"]</MudSelectItem>
                    </MudSelect>

                    @if (UsesPlanId)
                    {
                        <MudSelect T="string" Value="@_planId" ValueChanged="OnRulePlanChanged"
                                   Label="@L["TrainingPlan"]" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var plan in _trainingPlans.OrderBy(plan => plan.Name))
                            {
                                <MudSelectItem T="string" Value="@plan.Id">@plan.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    @if (UsesSessionIds)
                    {
                        <MudSelect T="string" MultiSelection="true" @bind-SelectedValues="_selectedSessionIds"
                                   Label="@L["TrainingSessions"]" Variant="Variant.Outlined" Disabled="@(SelectedRulePlan is null)">
                            @foreach (var session in SelectedRulePlan?.Sessions ?? Array.Empty<TrainingSession>())
                            {
                                <MudSelectItem T="string" Value="@session.Id">@($"{session.Date:d} · {session.Name}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    @if (UsesWorkoutId)
                    {
                        <MudSelect T="string" @bind-Value="_workoutId" Label="@L["WorkoutOptional"]" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var workoutId in _workoutIds)
                            {
                                <MudSelectItem T="string" Value="@workoutId">@GetWorkoutLabel(workoutId)</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    @if (UsesCourseId)
                    {
                        <MudSelect T="string" Value="@_courseId" ValueChanged="OnRuleCourseChangedAsync"
                                   Label="@L["CourseOptional"]" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var course in _courses.OrderBy(course => course.Name))
                            {
                                <MudSelectItem T="string" Value="@course.Id">@course.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    @if (UsesCourseEventId)
                    {
                        <MudSelect T="string" @bind-Value="_courseEventId" Label="@L["CourseEventOptional"]"
                                   Variant="Variant.Outlined" Clearable="true" Disabled="@(_courseEvents.Count == 0)">
                            @foreach (var courseEvent in _courseEvents.OrderBy(item => item.StartsAt))
                            {
                                <MudSelectItem T="string" Value="@courseEvent.Id">@($"{courseEvent.StartsAt:g} · {courseEvent.Title}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    @if (UsesTargetCount)
                    {
                        <MudNumericField T="int" @bind-Value="_targetCount" Min="1" Label="@L["TargetCount"]" Variant="Variant.Outlined" />
                    }

                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton Variant="Variant.Outlined" OnClick="ResetEditor">@L["Reset"]</MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="@(_isSaving || string.IsNullOrWhiteSpace(_title))"
                                   OnClick="SaveAsync">
                            @L["Save"]
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private static readonly IReadOnlyList<IconOption> IconOptions = new List<IconOption>
    {
        new("EmojiEvents", "Pokal"),
        new("WorkspacePremium", "Medaille"),
        new("Star", "Stern"),
        new("FitnessCenter", "Workout"),
        new("DirectionsRun", "Laufen"),
        new("EventAvailable", "Termin"),
        new("School", "Kurs"),
        new("Flag", "Ziel"),
        new("Speed", "Tempo"),
        new("LocalFireDepartment", "Serie"),
        new("CheckCircle", "Check")
    };

    private bool _isLoading = true;
    private bool _isSaving;
    private string? _userId;
    private List<AchievementDefinitionDocument> _definitions = new();
    private List<TrainingPlan> _trainingPlans = new();
    private List<CourseDocument> _courses = new();
    private List<CourseEventDocument> _courseEvents = new();
    private List<string> _workoutIds = new();

    private string? _editingDefinitionId;
    private string _title = string.Empty;
    private string _description = string.Empty;
    private bool _isPublished = true;
    private string _iconName = "EmojiEvents";
    private string _iconShape = "circle";
    private string _backgroundColor = "#F59E0B";
    private string _foregroundColor = "#111827";
    private string _accentColor = "#FDE68A";
    private string _ruleType = AchievementRuleTypes.TrainingSessionCount;
    private string _planId = string.Empty;
    private IReadOnlyCollection<string> _selectedSessionIds = new HashSet<string>();
    private string _workoutId = string.Empty;
    private string _courseId = string.Empty;
    private string _courseEventId = string.Empty;
    private int _targetCount = 1;

    private bool UsesPlanId => _ruleType is AchievementRuleTypes.TrainingSessionCompleted
        or AchievementRuleTypes.TrainingSessionCount
        or AchievementRuleTypes.TrainingPlanCompleted;

    private bool UsesSessionIds => _ruleType == AchievementRuleTypes.TrainingSessionCompleted;

    private bool UsesWorkoutId => _ruleType is AchievementRuleTypes.WorkoutCompleted
        or AchievementRuleTypes.WorkoutCount;

    private bool UsesCourseId => _ruleType is AchievementRuleTypes.CourseEventCompleted
        or AchievementRuleTypes.CourseCompleted;

    private bool UsesCourseEventId => _ruleType == AchievementRuleTypes.CourseEventCompleted;

    private bool UsesTargetCount => _ruleType is AchievementRuleTypes.TrainingSessionCount
        or AchievementRuleTypes.WorkoutCount;

    protected override async Task OnInitializedAsync()
    {
        var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier"))?.Value;
        _trainingPlans = TrainingPlanService.LoadTrainingPlans().ToList();
        _workoutIds = WorkoutCatalog.GetWorkoutIds().OrderBy(GetWorkoutLabel).ToList();
        if (!string.IsNullOrWhiteSpace(_userId))
            _courses = (await CourseService.GetCoursesForTrainerAsync(_userId)).ToList();
        await LoadDefinitionsAsync();
    }

    private async Task LoadDefinitionsAsync()
    {
        _isLoading = true;
        try
        {
            _definitions = (await AchievementService.GetDefinitionsAsync(includeUnpublished: true)).ToList();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_userId) || _isSaving)
            return;

        _isSaving = true;
        try
        {
            var request = new AchievementDefinitionRequest
            {
                Id = _editingDefinitionId ?? string.Empty,
                Title = _title,
                Description = _description,
                IsPublished = _isPublished,
                Icon = BuildIcon(),
                Rules = new List<AchievementRuleDocument> { BuildRule() }
            };

            var saved = await AchievementService.SaveDefinitionAsync(request, _userId);
            Snackbar.Add(string.Format(L["SavedNamed"], saved.Title), Severity.Success);
            await LoadDefinitionsAsync();
            Edit(saved);
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Edit(AchievementDefinitionDocument definition)
    {
        definition.Normalize();
        _editingDefinitionId = definition.Id;
        _title = definition.Title;
        _description = definition.Description;
        _isPublished = definition.IsPublished;
        _iconName = definition.Icon.MaterialIcon;
        _iconShape = definition.Icon.Shape;
        _backgroundColor = definition.Icon.BackgroundColor;
        _foregroundColor = definition.Icon.ForegroundColor;
        _accentColor = definition.Icon.AccentColor;

        var rule = definition.Rules.FirstOrDefault() ?? new AchievementRuleDocument();
        rule.Normalize();
        _ruleType = rule.RuleType;
        _planId = rule.PlanId;
        _selectedSessionIds = rule.SessionIds.ToHashSet(StringComparer.OrdinalIgnoreCase);
        _workoutId = rule.WorkoutId;
        _courseId = rule.CourseId;
        _courseEventId = rule.CourseEventId;
        _targetCount = rule.TargetCount;
        _ = LoadCourseEventsAsync();
    }

    private void ResetEditor()
    {
        _editingDefinitionId = null;
        _title = string.Empty;
        _description = string.Empty;
        _isPublished = true;
        _iconName = "EmojiEvents";
        _iconShape = "circle";
        _backgroundColor = "#F59E0B";
        _foregroundColor = "#111827";
        _accentColor = "#FDE68A";
        _ruleType = AchievementRuleTypes.TrainingSessionCount;
        _planId = string.Empty;
        _selectedSessionIds = new HashSet<string>();
        _workoutId = string.Empty;
        _courseId = string.Empty;
        _courseEventId = string.Empty;
        _targetCount = 1;
    }

    private AchievementIconDesignDocument BuildIcon()
    {
        var icon = new AchievementIconDesignDocument
        {
            MaterialIcon = _iconName,
            Shape = _iconShape,
            BackgroundColor = _backgroundColor,
            ForegroundColor = _foregroundColor,
            AccentColor = _accentColor
        };
        icon.Normalize();
        return icon;
    }

    private AchievementRuleDocument BuildRule()
    {
        var rule = new AchievementRuleDocument
        {
            RuleType = _ruleType,
            PlanId = _planId,
            WorkoutId = _workoutId,
            CourseId = _courseId,
            CourseEventId = _courseEventId,
            TargetCount = _targetCount,
            SessionIds = _selectedSessionIds.ToList()
        };
        rule.Normalize();
        return rule;
    }

    private TrainingPlan? SelectedRulePlan => _trainingPlans.FirstOrDefault(plan => plan.Id == _planId);

    private void OnRulePlanChanged(string value)
    {
        _planId = value ?? string.Empty;
        _selectedSessionIds = new HashSet<string>();
    }

    private async Task OnRuleCourseChangedAsync(string value)
    {
        _courseId = value ?? string.Empty;
        _courseEventId = string.Empty;
        await LoadCourseEventsAsync();
    }

    private async Task LoadCourseEventsAsync()
    {
        _courseEvents = string.IsNullOrWhiteSpace(_courseId)
            ? new List<CourseEventDocument>()
            : (await CourseService.GetEventsAsync(_courseId)).ToList();
    }

    private string GetWorkoutLabel(string workoutId)
    {
        var definition = WorkoutCatalog.GetDefinition(workoutId);
        return string.IsNullOrWhiteSpace(definition.Name)
            ? workoutId
            : $"{definition.Name} · {definition.Level}";
    }

    private string DescribeRules(AchievementDefinitionDocument definition)
    {
        if (definition.Rules.Count == 0)
            return L["NoRule"];

        return string.Join(" + ", definition.Rules.Select(DescribeRule));
    }

    private string DescribeRule(AchievementRuleDocument rule)
    {
        return rule.RuleType switch
        {
            AchievementRuleTypes.TrainingSessionCompleted when rule.SessionIds.Count > 0 =>
                string.Format(L["DescribeSpecificSessions"], rule.SessionIds.Count),
            AchievementRuleTypes.TrainingSessionCompleted => L["DescribeSession"],
            AchievementRuleTypes.TrainingSessionCount => string.Format(L["DescribeSessionCount"], rule.TargetCount),
            AchievementRuleTypes.TrainingPlanCompleted => L["DescribePlan"],
            AchievementRuleTypes.WorkoutCompleted => L["DescribeWorkout"],
            AchievementRuleTypes.WorkoutCount => string.Format(L["DescribeWorkoutCount"], rule.TargetCount),
            AchievementRuleTypes.CourseEventCompleted => L["DescribeCourseEvent"],
            AchievementRuleTypes.CourseCompleted => L["DescribeCourse"],
            _ => L["Rule"]
        };
    }

    private sealed record IconOption(string Value, string Label);
}
