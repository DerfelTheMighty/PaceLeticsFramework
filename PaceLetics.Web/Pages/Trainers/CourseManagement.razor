    private IEnumerable<string> GetSelectedBlockSessionIds(string planId)
    {
        var prefix = $"{planId}|";
        return _selectedBlockSessionKeys
            .Where(key => key.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            .Select(key => key[prefix.Length..]);
