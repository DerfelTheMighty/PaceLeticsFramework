    private static List<TrainingPlanBlockDefinition> CreateBlockDefinitions(TrainingPlan plan)
    {
        return plan.Blocks
            .Select(block => new TrainingPlanBlockDefinition
            {
                Id = block.Id,
                Name = block.Name,
                Focus = block.Focus,
                Structure = block.Structure,
                Description = block.Description,
                Order = block.Order,
                SessionIds = block.SessionIds.ToList()
            })
            .ToList();
    }

    private string CreateUniqueBlockId(TrainingPlan plan, string name)
    {
        var baseId = ToSlug(name);
        var candidate = baseId;
        var suffix = 2;
        var existingIds = plan.Blocks.Select(block => block.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);

        while (existingIds.Contains(candidate))
        {
            candidate = $"{baseId}-{suffix}";
            suffix++;
        }

        return candidate;
    }

    private static string ToSlug(string value)
    {
        var characters = value
            .Trim()
            .ToLowerInvariant()
            .Select(character => char.IsLetterOrDigit(character) ? character : '-')
            .ToArray();
        var slug = string.Join("-", new string(characters).Split('-', StringSplitOptions.RemoveEmptyEntries));
        return string.IsNullOrWhiteSpace(slug) ? Guid.NewGuid().ToString("N") : slug;
    }

    private string FormatPlanBlockMeta(TrainingPlan plan, TrainingPlanBlock block)
    {
        var sessions = plan.GetSessionsForBlock(block);
        if (sessions.Count == 0)
            return string.Format(L["PlanBlockSessionCount"], 0);

        var period = sessions.First().Date.Date == sessions.Last().Date.Date
            ? sessions.First().Date.ToString("dd.MM.yyyy")
            : $"{sessions.First().Date:dd.MM.yyyy} - {sessions.Last().Date:dd.MM.yyyy}";

        var parts = new List<string>
        {
            string.Format(L["PlanBlockSessionCount"], sessions.Count),
            period
        };

        if (!string.IsNullOrWhiteSpace(block.Structure))
            parts.Add(block.Structure);

        return string.Join(" · ", parts);
    }

    private string FormatTrainingPlanSession(TrainingSession session)
    {
        var parts = new List<string> { session.Date.ToString("dd.MM.yyyy") };

        if (session.Runs.Count > 0)
            parts.Add($"{session.TotalRunDistance / 1000.0:0.0} km");

        if (session.Workouts.Count > 0)
            parts.Add(string.Format(L["WorkoutCount"], session.Workouts.Count));

        return string.Join(" · ", parts);
    }

