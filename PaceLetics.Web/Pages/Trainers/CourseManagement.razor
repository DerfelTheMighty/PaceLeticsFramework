    private string FormatVisibility(FeedTarget? target)
    {
        var mode = GetVisibilityMode(target);
        if (mode == VisibilityModeGlobal)
            return "Sichtbar für alle";

        var groupId = GetVisibilityGroupId(target);
        var groupName = _groups.FirstOrDefault(group => group.Id == groupId)?.Name ?? groupId;
        return string.IsNullOrWhiteSpace(groupName)
            ? "Sichtbar für Gruppe"
            : $"Sichtbar für Gruppe: {groupName}";
    }

    private static string GetVisibilityMode(FeedTarget? target)
    {
        var normalized = target is null || target.IsEmpty
            ? FeedTarget.Global()
            : target.NormalizeCopy();

        return string.Equals(normalized.TargetType, FeedTargetTypes.Group, StringComparison.OrdinalIgnoreCase)
            ? VisibilityModeGroup
            : VisibilityModeGlobal;
    }

    private static string? GetVisibilityGroupId(FeedTarget? target)
    {
        var normalized = target is null || target.IsEmpty
            ? FeedTarget.Global()
            : target.NormalizeCopy();

        return string.Equals(normalized.TargetType, FeedTargetTypes.Group, StringComparison.OrdinalIgnoreCase)
            ? normalized.TargetId
            : null;
    }

    private static FeedTarget CreateVisibilityTarget(string mode, string? groupId)
    {
        if (mode != VisibilityModeGroup)
            return FeedTarget.Global();

        if (string.IsNullOrWhiteSpace(groupId))
            throw new InvalidOperationException("Bitte wähle eine Gruppe aus.");

        return FeedTarget.Group(groupId);
    }

