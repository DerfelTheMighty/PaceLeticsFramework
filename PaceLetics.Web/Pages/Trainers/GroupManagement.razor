@page "/Trainers/groups"
@attribute [Authorize(Roles = ApplicationRoles.Trainer)]
@using AthleteDataAccessLibrary.Contracts
@using PaceLetics.AthleteModule.CodeBase.Models
@using PaceLetics.Web.Services.Courses
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IGroupService GroupService
@inject IAthleteData AthleteData
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IStringLocalizer<GroupManagement> L

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pt-6 px-6 pb-8" MaxWidth="MaxWidth.Medium">
    <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

    <MudDivider Class="my-4" />

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <RetryAlert Message="@_errorMessage" OnRetry="LoadAsync" Class="mb-4" />
    }

    <MudStack Spacing="4">
        <MudPaper Elevation="1" Class="pa-4">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">@L["NewGroup"]</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudTextField Label="@L["Name"]" @bind-Value="_newGroup.Name" Variant="Variant.Outlined" Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" Label="@L["Join"]" @bind-Value="_newGroup.JoinMode" Variant="Variant.Outlined">
                            <MudSelectItem T="string" Value="@GroupJoinModes.Open">@L["Open"]</MudSelectItem>
                            <MudSelectItem T="string" Value="@GroupJoinModes.ApprovalRequired">@L["ApprovalRequired"]</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="@L["Description"]" @bind-Value="_newGroup.Description" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                </MudGrid>
                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudTooltip Text="@L["CreateGroup"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@string.IsNullOrWhiteSpace(_newGroup.Name)"
                                       OnClick="CreateGroupAsync"
                                       aria-label="@L["CreateGroup"]" />
                    </MudTooltip>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (_groups.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@L["NoGroups"]</MudAlert>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Spacing="3">
                    <MudSelect T="string"
                               Label="@L["Group"]"
                               Value="_selectedGroupId"
                               ValueChanged="OnSelectedGroupChanged"
                               Variant="Variant.Outlined">
                        @foreach (var group in _groups)
                        {
                            <MudSelectItem T="string" Value="@group.Id">@group.Name</MudSelectItem>
                        }
                    </MudSelect>

                    @if (SelectedGroup is not null)
                    {
                        var group = SelectedGroup;
                        var memberships = GetMemberships(group.Id).ToList();
                        var pending = memberships.Where(IsPending).ToList();
                        var active = memberships.Where(IsActive).ToList();

                        <MudDivider />

                        <MudStack Spacing="3">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="@L["Name"]" @bind-Value="_editGroup.Name" Variant="Variant.Outlined" Immediate="true" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="string" Label="@L["Join"]" @bind-Value="_editGroup.JoinMode" Variant="Variant.Outlined">
                                        <MudSelectItem T="string" Value="@GroupJoinModes.Open">@L["Open"]</MudSelectItem>
                                        <MudSelectItem T="string" Value="@GroupJoinModes.ApprovalRequired">@L["ApprovalRequired"]</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField Label="@L["Description"]" @bind-Value="_editGroup.Description" Variant="Variant.Outlined" Lines="3" />
                                </MudItem>
                            </MudGrid>

                            <MudStack Row="true" Justify="Justify.FlexEnd" Style="gap:8px;">
                                <MudTooltip Text="@L["DeleteGroup"]">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   OnClick="@(() => DeleteGroupAsync(group))"
                                                   aria-label="@L["DeleteGroup"]" />
                                </MudTooltip>
                                <MudTooltip Text="@L["SaveChanges"]">
                                    <MudIconButton Icon="@Icons.Material.Filled.Save"
                                                   Color="Color.Primary"
                                                   Variant="Variant.Filled"
                                                   Disabled="@string.IsNullOrWhiteSpace(_editGroup.Name)"
                                                   OnClick="@(() => SaveGroupAsync(group))"
                                                   aria-label="@L["SaveChanges"]" />
                                </MudTooltip>
                            </MudStack>

                            <MudDivider />

                            <MudText Typo="Typo.subtitle2">@L["JoinRequests"]</MudText>
                            @if (pending.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["NoRequests"]</MudText>
                            }
                            else
                            {
                                <MudStack Spacing="1">
                                    @foreach (var membership in pending)
                                    {
                                        <div class="pl-group-row">
                                            <MudText Typo="Typo.body2">@GetAthleteDisplayName(membership.AthleteUserId)</MudText>
                                            <MudStack Row="true" Style="gap:4px;">
                                                <MudTooltip Text="@L["Approve"]">
                                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Check" Color="Color.Success" OnClick="@(() => ApproveAsync(group, membership))" aria-label="@L["Approve"]" />
                                                </MudTooltip>
                                                <MudTooltip Text="@L["Reject"]">
                                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="@(() => RejectAsync(group, membership))" aria-label="@L["Reject"]" />
                                                </MudTooltip>
                                            </MudStack>
                                        </div>
                                    }
                                </MudStack>
                            }

                            <MudText Typo="Typo.subtitle2">@L["Members"]</MudText>
                            @if (active.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["NoMembers"]</MudText>
                            }
                            else
                            {
                                <MudStack Spacing="1">
                                    @foreach (var membership in active)
                                    {
                                        <div class="pl-group-row">
                                            <MudText Typo="Typo.body2">@GetAthleteDisplayName(membership.AthleteUserId)</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@membership.ApprovedAt?.ToString("dd.MM.yyyy")</MudText>
                                        </div>
                                    }
                                </MudStack>
                            }
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

<style>
    .pl-group-row {
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }
</style>

@code {
    private string? _userId;
    private string _displayName = string.Empty;
    private List<GroupDocument> _groups = new();
    private Dictionary<string, IReadOnlyList<GroupMembershipDocument>> _membershipsByGroup = new(StringComparer.OrdinalIgnoreCase);
    private string? _selectedGroupId;
    private GroupCreateRequest _newGroup = new();
    private GroupCreateRequest _editGroup = new();
    private Dictionary<string, string> _athleteDisplayNamesById = new(StringComparer.OrdinalIgnoreCase);
    private string? _errorMessage;

    private GroupDocument? SelectedGroup => _groups.FirstOrDefault(group =>
        string.Equals(group.Id, _selectedGroupId, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier"))?.Value;
        _displayName = authState.User.Identity?.Name ?? _userId ?? string.Empty;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _errorMessage = null;
        try
        {
            _groups = (await GroupService.GetGroupsForTrainerAsync(_userId ?? string.Empty)).ToList();
            var athletes = await AthleteData.GetAthletes();
            _athleteDisplayNamesById = athletes.ToDictionary(
                athlete => athlete.Id,
                athlete => GetDisplayName(athlete, athlete.Id),
                StringComparer.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            _errorMessage = UiErrorMessages.From(ex);
            return;
        }

        if (_groups.Count == 0)
        {
            _selectedGroupId = null;
            _editGroup = new();
            _membershipsByGroup.Clear();
            return;
        }

        if (string.IsNullOrWhiteSpace(_selectedGroupId)
            || _groups.All(group => !string.Equals(group.Id, _selectedGroupId, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedGroupId = _groups.First().Id;
        }

        _membershipsByGroup = new Dictionary<string, IReadOnlyList<GroupMembershipDocument>>(StringComparer.OrdinalIgnoreCase);
        try
        {
            foreach (var group in _groups)
            {
                _membershipsByGroup[group.Id] = await GroupService.GetMembershipsForGroupAsync(group.Id, _userId ?? string.Empty);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = UiErrorMessages.From(ex);
        }

        ApplySelectedGroupToEditDraft();
    }

    private string GetAthleteDisplayName(string athleteUserId) =>
        _athleteDisplayNamesById.TryGetValue(athleteUserId, out var displayName) ? displayName : athleteUserId;

    private static string GetDisplayName(AthleteModel? athlete, string fallback)
    {
        if (!string.IsNullOrWhiteSpace(athlete?.PublicProfile?.PublicUserName) && athlete.PublicProfile.PublicUserName != "NA")
            return athlete.PublicProfile.PublicUserName;
        if (!string.IsNullOrWhiteSpace(athlete?.Name) && athlete.Name != "NA")
            return athlete.Name;
        return fallback;
    }

    private async Task CreateGroupAsync()
    {
        try
        {
            var group = await GroupService.CreateGroupAsync(_newGroup, _userId ?? string.Empty, _displayName);
            _newGroup = new();
            _selectedGroupId = group.Id;
            Snackbar.Add(L["Created"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
    }

    private Task OnSelectedGroupChanged(string groupId)
    {
        _selectedGroupId = groupId;
        ApplySelectedGroupToEditDraft();
        return Task.CompletedTask;
    }

    private async Task SaveGroupAsync(GroupDocument group)
    {
        try
        {
            await GroupService.UpdateGroupAsync(group.Id, _editGroup, _userId ?? string.Empty);
            Snackbar.Add(L["Saved"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
    }

    private async Task DeleteGroupAsync(GroupDocument group)
    {
        var confirmed = await UiConfirmation.AskAsync(DialogService, string.Format(L["DeleteConfirm"], group.Name));
        if (!confirmed)
            return;

        try
        {
            await GroupService.DeleteGroupAsync(group.Id, _userId ?? string.Empty);
            Snackbar.Add(L["Deleted"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
    }

    private async Task ApproveAsync(GroupDocument group, GroupMembershipDocument membership)
    {
        try
        {
            await GroupService.ApproveMembershipAsync(group.Id, membership.AthleteUserId, _userId ?? string.Empty);
            Snackbar.Add(L["Approved"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
    }

    private async Task RejectAsync(GroupDocument group, GroupMembershipDocument membership)
    {
        try
        {
            await GroupService.RejectMembershipAsync(group.Id, membership.AthleteUserId, _userId ?? string.Empty);
            Snackbar.Add(L["Rejected"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
    }

    private IReadOnlyList<GroupMembershipDocument> GetMemberships(string groupId)
    {
        return _membershipsByGroup.TryGetValue(groupId, out var memberships)
            ? memberships
            : Array.Empty<GroupMembershipDocument>();
    }

    private void ApplySelectedGroupToEditDraft()
    {
        var group = SelectedGroup;
        _editGroup = group is null
            ? new GroupCreateRequest()
            : new GroupCreateRequest
            {
                Name = group.Name,
                Description = group.Description,
                JoinMode = group.JoinMode,
                IsPublished = group.IsPublished
            };
    }

    private static bool IsPending(GroupMembershipDocument membership)
    {
        return string.Equals(membership.Status, GroupMembershipStatus.Pending, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsActive(GroupMembershipDocument membership)
    {
        return string.Equals(membership.Status, GroupMembershipStatus.Active, StringComparison.OrdinalIgnoreCase);
    }
}
