@page "/Trainers/running-analyses"
@attribute [Authorize(Roles = ApplicationRoles.Trainer)]
@using Microsoft.Extensions.Options
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Enums
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Interfaces
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Models
@using PaceLetics.RunningAnalysisModule.Infrastructure.GoogleDrive
@using PaceLetics.Web.Services.Courses
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICourseService CourseService
@inject IRunningAnalysisService RunningAnalysisService
@inject IRunningAnalysisRepository RunningAnalysisRepository
@inject NavigationManager Navigation
@inject LoadingStateService Loading
@inject IOptions<GoogleDriveRunningAnalysisOptions> DriveOptions
@inject IStringLocalizer<RunningAnalyses> L

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pl-section-page px-6 pb-8" MaxWidth="MaxWidth.Medium">
    <MudStack Spacing="3">
        <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

        <SectionNav Items="@SectionItems" ActiveKey="@GetSectionKey(_activeSection)" OnSelect="SelectSectionByKey" AriaLabel="@L["Title"]" />

        @if (!HasDriveCredentials)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                @L["DriveCredentialsMissing"]
            </MudAlert>
        }

        @if (!HasCentralDriveFolder)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                @L["DriveRootFolderMissing"]
            </MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <RetryAlert Message="@_errorMessage" OnRetry="LoadAsync" />
        }
        else if (_analyses.Count == 0)
        {
            <ActionableEmptyState Title="@L["EmptyTitle"]"
                                  Detail="@L["EmptyText"]"
                                  ActionText="@L["CreateEvent"]"
                                  Href="/Trainers/courses" />
        }
        else
        {
            <MudDivider />

            @if (_activeSection == RunningAnalysesSection.Recordings)
            {
                <MudStack Spacing="2">
                    @foreach (var analysis in _analyses)
                    {
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap:12px; flex-wrap:wrap;">
                                @RenderAnalysisSummary(analysis)

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Videocam"
                                           OnClick="@(() => OpenRecording(analysis))">
                                    Aufnahme starten
                                </MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
            else if (_activeSection == RunningAnalysesSection.Analyses)
            {
                <MudStack Spacing="2">
                    @foreach (var analysis in _analyses)
                    {
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap:12px; flex-wrap:wrap;">
                                @RenderAnalysisSummary(analysis)

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.RateReview"
                                           Disabled="@(analysis.Status?.RecordedParticipantCount == 0)"
                                           OnClick="@(() => OpenReview(analysis))">
                                    Analyse öffnen
                                </MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
            else
            {
                <MudStack Spacing="3">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        Hier werden lokal gespeicherte Laufaufnahmen später hochgeladen.
                    </MudAlert>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               OnClick="OpenUploadQueue">
                        Uploadqueue öffnen
                    </MudButton>

                    <MudStack Spacing="2">
                        @foreach (var analysis in _analyses)
                        {
                            <MudPaper Elevation="1" Class="pa-4">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap:12px; flex-wrap:wrap;">
                                    @RenderAnalysisSummary(analysis)

                                    @if (analysis.Status is not null)
                                    {
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="@GetUploadStatusColor(analysis.Status)"
                                                 Variant="Variant.Outlined"
                                                 Icon="@Icons.Material.Filled.CloudDone">
                                            @FormatProgress(L["Uploads"].ToString(), analysis.Status.UploadedParticipantCount, analysis.Status.RecordedParticipantCount)
                                        </MudChip>
                                    }
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                </MudStack>
            }
        }
    </MudStack>
</MudContainer>

@code {
    private enum RunningAnalysesSection
    {
        Recordings,
        Analyses,
        UploadQueue
    }

    private string? _userId;
    private string? _errorMessage;
    private IReadOnlyList<RunningAnalysisCourseEvent> _analyses = Array.Empty<RunningAnalysisCourseEvent>();
    private RunningAnalysesSection _activeSection = RunningAnalysesSection.Recordings;
    private IReadOnlyList<SectionNavEntry> SectionItems =>
    [
        new("recordings", L["Recordings"]),
        new("analyses", L["Analyses"]),
        new("uploads", L["UploadQueue"])
    ];

    private bool HasDriveCredentials =>
        !string.IsNullOrWhiteSpace(DriveOptions.Value.ServiceAccountJsonPath)
        || !string.IsNullOrWhiteSpace(DriveOptions.Value.ServiceAccountJson)
        || HasGoogleDriveOAuthCredentials;

    private bool HasGoogleDriveOAuthCredentials =>
        !string.IsNullOrWhiteSpace(DriveOptions.Value.OAuthClientId)
        && !string.IsNullOrWhiteSpace(DriveOptions.Value.OAuthClientSecret)
        && !string.IsNullOrWhiteSpace(DriveOptions.Value.OAuthRefreshToken);

    private bool HasCentralDriveFolder =>
        !string.IsNullOrWhiteSpace(DriveOptions.Value.RootFolderId);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await Loading.RunAsync(L["Loading"], async () =>
        {
            try
            {
                _errorMessage = null;
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                _userId = authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier"))?.Value;

                if (string.IsNullOrWhiteSpace(_userId))
                    throw new InvalidOperationException(L["TrainerNotResolved"]);

                var courses = await CourseService.GetCoursesForTrainerAsync(_userId);
                var analyses = new List<RunningAnalysisCourseEvent>();

                foreach (var course in courses.OrderBy(course => course.Name))
                {
                    var events = await CourseService.GetEventsAsync(course.Id);
                    foreach (var courseEvent in events.Where(IsRunningAnalysisEvent))
                    {
                        analyses.Add(new RunningAnalysisCourseEvent(
                            course,
                            courseEvent,
                            await LoadAnalysisStatusAsync(courseEvent)));
                    }
                }

                _analyses = analyses
                    .OrderBy(analysis => analysis.Event.StartsAt.Date < DateTime.Today ? 1 : 0)
                    .ThenBy(analysis => analysis.Event.StartsAt)
                    .ThenBy(analysis => analysis.Event.Title)
                    .ToList();
            }
            catch (Exception ex)
            {
                _errorMessage = UiErrorMessages.From(ex);
                _analyses = Array.Empty<RunningAnalysisCourseEvent>();
            }
        });
    }

    private static bool IsRunningAnalysisEvent(CourseEventDocument courseEvent)
    {
        return string.Equals(courseEvent.EventType, CourseEventTypes.RunningAnalysis, StringComparison.OrdinalIgnoreCase);
    }

    private async Task<RunningAnalysisListStatus?> LoadAnalysisStatusAsync(CourseEventDocument courseEvent)
    {
        var captureSession = await RunningAnalysisRepository.GetCaptureSessionByExternalEventIdAsync(courseEvent.Id);
        if (captureSession is null)
        {
            return new RunningAnalysisListStatus(
                0,
                0,
                0,
                0);
        }

        var roster = await RunningAnalysisService.GetRosterAsync(captureSession.Id);
        var recordedParticipants = roster
            .Where(HasRecording)
            .ToList();

        return new RunningAnalysisListStatus(
            roster.Count,
            recordedParticipants.Count,
            recordedParticipants.Count(HasUploadedRecording),
            recordedParticipants.Count(HasCompletedReview));
    }

    private void OpenRecording(RunningAnalysisCourseEvent analysis)
    {
        Navigation.NavigateTo($"/Trainers/courses/{analysis.Course.Id}/events/{analysis.Event.Id}/running-analysis");
    }

    private void SelectSection(RunningAnalysesSection section)
    {
        _activeSection = section;
    }

    private static string GetSectionKey(RunningAnalysesSection section) => section switch
    {
        RunningAnalysesSection.Analyses => "analyses",
        RunningAnalysesSection.UploadQueue => "uploads",
        _ => "recordings"
    };

    private void SelectSectionByKey(string key) => SelectSection(key switch
    {
        "analyses" => RunningAnalysesSection.Analyses,
        "uploads" => RunningAnalysesSection.UploadQueue,
        _ => RunningAnalysesSection.Recordings
    });

    private void OpenReview(RunningAnalysisCourseEvent analysis)
    {
        Navigation.NavigateTo($"/Trainers/courses/{analysis.Course.Id}/events/{analysis.Event.Id}/running-analysis/analysis");
    }

    private void OpenUploadQueue()
    {
        Navigation.NavigateTo("/Trainers/running-analysis/uploads");
    }

    private RenderFragment RenderAnalysisSummary(RunningAnalysisCourseEvent analysis) => @<MudStack Spacing="1" Style="min-width:0;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap:8px; flex-wrap:wrap;">
            <MudText Typo="Typo.subtitle1">@analysis.Event.Title</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                @L["RunningAnalysis"]
            </MudChip>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@analysis.Course.Name</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatEventDate(analysis.Event)</MudText>
        @if (!string.IsNullOrWhiteSpace(analysis.Event.Location))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@analysis.Event.Location</MudText>
        }

        @if (analysis.Status is not null)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap:8px; flex-wrap:wrap;">
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@GetRecordingStatusColor(analysis.Status)"
                         Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.Videocam">
                    @FormatProgress(L["Recordings"].ToString(), analysis.Status.RecordedParticipantCount, analysis.Status.ParticipantCount)
                </MudChip>
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@GetUploadStatusColor(analysis.Status)"
                         Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.CloudDone">
                    @FormatProgress(L["Uploads"].ToString(), analysis.Status.UploadedParticipantCount, analysis.Status.RecordedParticipantCount)
                </MudChip>
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@GetReviewStatusColor(analysis.Status)"
                         Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.RateReview">
                    @FormatProgress(L["Review"].ToString(), analysis.Status.CompletedReviewCount, analysis.Status.RecordedParticipantCount)
                </MudChip>
            </MudStack>

            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @FormatParticipantSummary(analysis.Status)
            </MudText>
        }
    </MudStack>;

    private string FormatEventDate(CourseEventDocument courseEvent)
    {
        return string.Format(L["EventDate"], courseEvent.StartsAt, courseEvent.EndsAt);
    }

    private string FormatParticipantSummary(RunningAnalysisListStatus status)
    {
        var missingParticipantCount = Math.Max(0, status.ParticipantCount - status.RecordedParticipantCount);
        var summary = string.Format(
            L["ParticipantSummary"],
            status.ParticipantCount,
            status.RecordedParticipantCount);

        return missingParticipantCount > 0
            ? $"{summary} - {string.Format(L["NotRecorded"], missingParticipantCount)}"
            : summary;
    }

    private string FormatProgress(string label, int current, int total)
    {
        return $"{label} {current}/{total}";
    }

    private static Color GetRecordingStatusColor(RunningAnalysisListStatus status)
    {
        if (status.ParticipantCount == 0)
            return Color.Default;

        return status.RecordedParticipantCount >= status.ParticipantCount
            ? Color.Success
            : Color.Warning;
    }

    private static Color GetUploadStatusColor(RunningAnalysisListStatus status)
    {
        if (status.RecordedParticipantCount == 0)
            return Color.Default;

        return status.UploadedParticipantCount >= status.RecordedParticipantCount
            ? Color.Success
            : Color.Warning;
    }

    private static Color GetReviewStatusColor(RunningAnalysisListStatus status)
    {
        if (status.RecordedParticipantCount == 0)
            return Color.Default;

        return status.CompletedReviewCount >= status.RecordedParticipantCount
            ? Color.Success
            : Color.Info;
    }

    private static bool HasRecording(RunningAnalysisRosterItem participant)
    {
        return participant.RecordingCount > 0
            || !string.IsNullOrWhiteSpace(participant.SideRecordingUrl)
            || !string.IsNullOrWhiteSpace(participant.RearRecordingUrl);
    }

    private static bool HasUploadedRecording(RunningAnalysisRosterItem participant)
    {
        return !string.IsNullOrWhiteSpace(participant.SideRecordingUrl)
            || !string.IsNullOrWhiteSpace(participant.RearRecordingUrl);
    }

    private static bool HasCompletedReview(RunningAnalysisRosterItem participant)
    {
        return participant.ResultStatus == RunningAnalysisResultStatus.Completed;
    }

    private sealed record RunningAnalysisCourseEvent(
        CourseDocument Course,
        CourseEventDocument Event,
        RunningAnalysisListStatus? Status);

    private sealed record RunningAnalysisListStatus(
        int ParticipantCount,
        int RecordedParticipantCount,
        int UploadedParticipantCount,
        int CompletedReviewCount);
}
