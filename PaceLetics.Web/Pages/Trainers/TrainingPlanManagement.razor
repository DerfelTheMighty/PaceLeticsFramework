    private Task RemoveSessionAsync(string sessionId)
    {
        if (SelectedPlan is null)
            return Task.CompletedTask;

        try
        {
            var planId = SelectedPlan.Id;
            var removed = TrainingPlanService.LoadTrainingPlanDefinitions()
                .FirstOrDefault(plan => string.Equals(plan.Id, planId, StringComparison.OrdinalIgnoreCase))?
                .Sessions.FirstOrDefault(session => string.Equals(session.Id, sessionId, StringComparison.OrdinalIgnoreCase));
            TrainingPlanService.RemoveTrainingSession(planId, sessionId);
            _selectedBlockSessionIds.Remove(sessionId);
            ReloadPlans();
            if (removed is not null)
            {
                Undo.Offer(L["SessionRemoved"], L["Undo"], () =>
                {
                    TrainingPlanService.AddTrainingSession(planId, removed);
                    ReloadPlans();
                    return Task.CompletedTask;
                });
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }

        return Task.CompletedTask;
    }

    private void BeginSessionChange(TrainingSession session)
    {
        _editingSessionId = session.Id;
        _editingSessionDate = (session.Appointment.StartsAt ?? session.Date).Date;
        _editingSessionReason = session.Appointment.ChangeReason;
    }

    private void CancelSessionChange()
    {
        _editingSessionId = null;
        _editingSessionDate = null;
        _editingSessionReason = string.Empty;
    }

    private Task SaveSessionChangeAsync()
    {
        if (!CanSaveSessionChange || SelectedPlan is null)
            return Task.CompletedTask;

        try
        {
            var definition = TrainingPlanService.LoadTrainingPlanDefinitions()
                .First(plan => string.Equals(plan.Id, SelectedPlan.Id, StringComparison.OrdinalIgnoreCase))
                .Sessions.First(session => string.Equals(session.Id, _editingSessionId, StringComparison.OrdinalIgnoreCase));
            var planId = SelectedPlan.Id;
            var sessionId = _editingSessionId!;
            var previousDate = definition.Date;
            var previousAppointment = definition.Appointment;
            var newDate = _editingSessionDate!.Value.Date;
            definition.Date = newDate;

            var appointment = definition.Appointment ?? TrainingSessionAppointment.Empty;
            DateTime? startsAt = appointment.StartsAt is { } start ? newDate.Add(start.TimeOfDay) : null;
            DateTime? endsAt = appointment.EndsAt is { } end
                ? newDate.AddDays((end.Date - (appointment.StartsAt?.Date ?? previousDate.Date)).Days).Add(end.TimeOfDay)
                : null;
            definition.Appointment = appointment with
            {
                StartsAt = startsAt,
                EndsAt = endsAt,
                ChangeReason = _editingSessionReason
            };
            TrainingPlanService.UpdateTrainingSession(planId, sessionId, definition);
            ReloadPlans();
            Undo.Offer(L["SessionChanged"], L["Undo"], () =>
            {
                var current = TrainingPlanService.LoadTrainingPlanDefinitions()
                    .First(plan => string.Equals(plan.Id, planId, StringComparison.OrdinalIgnoreCase))
                    .Sessions.First(session => string.Equals(session.Id, sessionId, StringComparison.OrdinalIgnoreCase));
                current.Date = previousDate;
                current.Appointment = previousAppointment;
                TrainingPlanService.UpdateTrainingSession(planId, sessionId, current);
                ReloadPlans();
                return Task.CompletedTask;
            });
            CancelSessionChange();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }

        return Task.CompletedTask;
    }

