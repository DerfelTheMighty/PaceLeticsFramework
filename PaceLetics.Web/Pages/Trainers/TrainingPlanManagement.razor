    private static string FormatPlanMeta(TrainingPlan plan)
    {
        var range = plan.StartDate is null || plan.EndDate is null
            ? "ohne Datum"
            : $"{plan.StartDate:dd.MM.yyyy} - {plan.EndDate:dd.MM.yyyy}";

        return $"{plan.Sessions.Count} Einheiten - {plan.Blocks.Count} Bloecke - {range}";
    }

    private FeedTarget CreatePublicationTarget()
    {
        if (_publicationTargetType == FeedTargetTypes.Global)
            return FeedTarget.Global();

        if (string.IsNullOrWhiteSpace(_publicationTargetId))
            throw new InvalidOperationException("Bitte wähle ein Ziel aus.");

        return _publicationTargetType switch
        {
            FeedTargetTypes.Group => FeedTarget.Group(_publicationTargetId),
            FeedTargetTypes.Course => FeedTarget.Course(_publicationTargetId),
            _ => FeedTarget.Global()
        };
    }

    private IReadOnlyList<PlanPublicationView> BuildPublicationViews(string planId)
    {
        var views = new List<PlanPublicationView>();

        foreach (var publication in _publications.Where(publication =>
                     string.Equals(publication.TrainingPlanId, planId, StringComparison.OrdinalIgnoreCase)))
        {
            var target = publication.Target.NormalizeCopy();
            views.Add(new PlanPublicationView(
                publication.Id,
                publication.TrainingPlanId,
                target.TargetType,
                target.TargetId,
                FormatPublicationTarget(target),
                publication.PublishedAt,
                false));
        }

        foreach (var course in _courses)
        {
            foreach (var publication in course.TrainingPlanPublications.Where(publication =>
                         string.Equals(publication.TrainingPlanId, planId, StringComparison.OrdinalIgnoreCase)))
            {
                views.Add(new PlanPublicationView(
                    $"{course.Id}:{publication.TrainingPlanId}",
                    publication.TrainingPlanId,
                    FeedTargetTypes.Course,
                    course.Id,
                    $"Kurs: {course.Name}",
                    publication.PublishedAt,
                    true));
            }
        }

        return views
            .OrderBy(view => view.TargetType)
            .ThenBy(view => view.Label)
            .ToList();
    }

    private string FormatPublicationTarget(FeedTarget target)
    {
        if (target.IsGlobal)
            return "Alle";

        if (string.Equals(target.TargetType, FeedTargetTypes.Group, StringComparison.OrdinalIgnoreCase))
        {
            var groupName = _groups.FirstOrDefault(group => group.Id == target.TargetId)?.Name ?? target.TargetId;
            return $"Gruppe: {groupName}";
        }

        if (string.Equals(target.TargetType, FeedTargetTypes.Course, StringComparison.OrdinalIgnoreCase))
        {
            var courseName = _courses.FirstOrDefault(course => course.Id == target.TargetId)?.Name ?? target.TargetId;
            return $"Kurs: {courseName}";
        }

        return $"{target.TargetType}: {target.TargetId}";
    }

    private static string FormatSession(TrainingSession session)
    {
        var parts = new List<string> { session.Date.ToString("dd.MM.yyyy") };

        if (session.Runs.Count > 0)
            parts.Add($"{session.TotalRunDistance / 1000.0:0.0} km");

        if (session.Workouts.Count > 0)
            parts.Add($"{session.Workouts.Count} Workout(s)");

        return string.Join(" - ", parts);
    }

    private static string FormatBlock(TrainingPlan plan, TrainingPlanBlock block)
    {
        var sessions = plan.GetSessionsForBlock(block);
        var structure = string.IsNullOrWhiteSpace(block.Structure) ? null : block.Structure;
        return structure is null
            ? $"{sessions.Count} Einheiten"
            : $"{sessions.Count} Einheiten - {structure}";
    }

    private enum SessionDraftKind
    {
        PlannedRun,
        IntervalRun,
        Workout
    }

    private sealed class SessionDraft
    {
        public string Name { get; set; } = string.Empty;
        public DateTime? Date { get; set; }
        public SessionDraftKind Kind { get; set; }
        public int Distance { get; set; }
        public string PaceKey { get; set; } = PaceKeys.Easy;
        public int WarmupDistance { get; set; }
        public int RecoveryDistance { get; set; }
        public int Repetitions { get; set; }
        public string WorkoutId { get; set; } = string.Empty;
        public int Sets { get; set; }
        public int Rounds { get; set; }

        public static SessionDraft CreateDefault()
        {
            return new SessionDraft
            {
                Date = DateTime.Today,
                Kind = SessionDraftKind.PlannedRun,
                Distance = 8_000,
                PaceKey = PaceKeys.Easy,
                WarmupDistance = 2_000,
                RecoveryDistance = 400,
                Repetitions = 6,
                Sets = 1,
                Rounds = 1
            };
        }

        public TrainingSessionDefinition ToDefinition()
        {
            var date = Date?.Date ?? DateTime.Today;
            var definition = new TrainingSessionDefinition
            {
                Name = Name.Trim(),
                Date = date
            };

            if (Kind == SessionDraftKind.PlannedRun)
            {
                definition.Runs.Add(new PlannedSessionDefinition
                {
                    Name = Name.Trim(),
                    Date = date,
                    Sequence =
                    [
                        new RunningSegmentDefinition
                        {
                            Type = SegmentType.Dauerlauf,
                            Distance = Math.Max(1, Distance),
                            PaceKey = PaceKey
                        }
                    ]
                });
            }
            else if (Kind == SessionDraftKind.IntervalRun)
            {
                definition.Runs.Add(new IntervalSessionDefinition
                {
                    Name = Name.Trim(),
                    Date = date,
                    WarmupDistance = Math.Max(0, WarmupDistance),
                    Distances = Enumerable.Repeat(Math.Max(1, Distance), Math.Max(1, Repetitions)).ToList(),
                    Recovery = Enumerable.Repeat(Math.Max(0, RecoveryDistance), Math.Max(1, Repetitions)).ToList(),
                    PaceKeys = [PaceKeys.Intervall],
                    Sets = 1
                });
            }
            else
            {
                definition.Workouts.Add(new WorkoutSessionDefinition(
                    WorkoutId.Trim(),
                    Name.Trim(),
                    Math.Max(1, Sets),
                    Math.Max(1, Rounds)));
            }

            return definition;
        }
    }

    private sealed class BlockDraft
    {
        public string Name { get; set; } = string.Empty;
        public string Focus { get; set; } = string.Empty;
        public string Structure { get; set; } = string.Empty;
    }

    private sealed record PlanPublicationView(
        string Id,
        string TrainingPlanId,
        string TargetType,
        string TargetId,
        string Label,
        DateTime PublishedAt,
        bool IsCoursePublication);
