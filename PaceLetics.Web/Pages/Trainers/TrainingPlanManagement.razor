    private Task RemoveSessionFromBlockAsync(TrainingPlanBlock block, string sessionId)
    {
        if (SelectedPlan is null)
            return Task.CompletedTask;

        try
        {
            var updated = new TrainingPlanBlockDefinition
            {
                Id = block.Id,
                Name = block.Name,
                Focus = block.Focus,
                Structure = block.Structure,
                Description = block.Description,
                Order = block.Order,
                SessionIds = block.SessionIds
                    .Where(id => !string.Equals(id, sessionId, StringComparison.OrdinalIgnoreCase))
                    .ToList()
            };

            if (updated.SessionIds.Count == 0)
                TrainingPlanService.RemoveTrainingPlanBlock(SelectedPlan.Id, block.Id);
            else
                TrainingPlanService.UpdateTrainingPlanBlock(SelectedPlan.Id, block.Id, updated);

            ReloadPlans();
            Snackbar.Add(L["RemovedFromBlock"], Severity.Success);
        }
        catch (Exception ex)
        {
