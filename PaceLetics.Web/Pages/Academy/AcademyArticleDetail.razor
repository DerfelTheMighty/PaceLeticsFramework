@page "/Academy/{ArticleId}"
@page "/Athletes/academy/{ArticleId}"
@attribute [Authorize]
@using PaceLetics.AthleteModule.Components
@using PaceLetics.RunningAnalysisModule.Components
@using PaceLetics.Web.Services.Articles
@inject IArticleService ArticleService
@inject IStringLocalizer<Academy> L
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>@PageTitleText</PageTitle>

<MudContainer Class="pl-section-page px-6 pb-8" MaxWidth="MaxWidth.Medium">
    <div class="pl-academy-article__actions mb-3">
        <MudButton Href="/Athletes/academy"
                   Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            @L["BackToOverview"]
        </MudButton>

        @if (_article is not null)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PictureAsPdf"
                       Disabled="@_isExporting"
                       OnClick="ExportPdfAsync"
                       aria-label="@L["ExportPdf"]">
                @L["ExportPdf"]
            </MudButton>
        }
    </div>

    @if (_article is null)
    {
        <PageHeader Title="@L["NotFoundTitle"]" Subtitle="@L["NotFoundSubtitle"]" />
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
            @L["NotFoundBody"]
        </MudAlert>
    }
    else
    {
        <section id="@ExportRootId" class="pl-academy-article__export" aria-label="@_article.Title">
            <PageHeader Title="@_article.Title" Subtitle="@_article.Summary" />

        <MudStack Spacing="3" Class="mt-4">
            <MudPaper Elevation="0" Class="@GetArticleMetaClass(_article)">
                <MudStack Spacing="2">
                    <div class="pl-academy-article__topline">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="pl-academy-tile__chip">
                            @FormatCategory(_article.Category)
                        </MudChip>

                        @if (_article.Tags.Count > 0)
                        {
                            <div class="pl-academy-article__tags" aria-label="@L["Tags"]">
                                @foreach (var tag in _article.Tags)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@tag</MudChip>
                                }
                            </div>
                        }
                    </div>
                </MudStack>
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(_article.BodyHtml))
            {
                <MudPaper Elevation="0" Class="@GetArticleMetaClass(_article)">
                    <div class="pl-academy-article__markdown">
                        @((MarkupString)_article.BodyHtml)
                    </div>
                </MudPaper>
            }
            else
            {
                @RenderFallbackArticle(_article)
            }
        </MudStack>
        </section>
    }
</MudContainer>

@code {
    private const string ExportRootId = "academy-article-export";
    [Parameter]
    public string? ArticleId { get; set; }

    private Article? _article;
    private bool _isExporting;

    private string PageTitleText => _article?.Title ?? L["PageTitle"];

    protected override void OnParametersSet()
    {
        _article = ArticleService.GetArticle(ArticleId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_article is not null)
        {
            await JS.InvokeVoidAsync("paceleticsAcademy.enhanceTables", ".pl-academy-article__markdown");
        }
    }

    private async Task ExportPdfAsync()
    {
        if (_article is null || _isExporting)
            return;

        _isExporting = true;

        try
        {
            await JS.InvokeVoidAsync(
                "paceleticsAcademy.exportPdf",
                $"#{ExportRootId}",
                $"{_article.Title} - PaceLetics Academy");
        }
        catch (JSException)
        {
            Snackbar.Add(L["ExportPdfError"], Severity.Error);
        }
        finally
        {
            _isExporting = false;
        }
    }

    private string FormatCategory(string category)
    {
        return category switch
        {
            ArticleCategories.Fundamentals => L["CategoryFundamentals"],
            ArticleCategories.RunningAnalysis => L["CategoryRunningAnalysis"],
            ArticleCategories.Training => L["CategoryTraining"],
            _ => category
        };
    }

    private static string GetArticleMetaClass(Article article)
    {
        var accentClass = article.Category switch
        {
            ArticleCategories.Fundamentals => "pl-academy-tile--fundamentals",
            ArticleCategories.RunningAnalysis => "pl-academy-tile--running-analysis",
            ArticleCategories.Training => "pl-academy-tile--training",
            _ => "pl-academy-tile--default"
        };

        return $"pa-3 pl-academy-article {accentClass}";
    }

    private RenderFragment RenderFallbackArticle(Article article) => builder =>
    {
        var sequence = 0;

        builder.OpenComponent<MudPaper>(sequence++);
        builder.AddAttribute(sequence++, "Elevation", 0);
        builder.AddAttribute(sequence++, "Class", GetArticleMetaClass(article));
        builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(paperBuilder =>
        {
            var paperSequence = 0;
            paperBuilder.OpenComponent<MudStack>(paperSequence++);
            paperBuilder.AddAttribute(paperSequence++, "Spacing", 2);
            paperBuilder.AddAttribute(paperSequence++, "ChildContent", (RenderFragment)(stackBuilder =>
            {
                var stackSequence = 0;
                foreach (var block in article.BodyBlocks)
                {
                    stackBuilder.OpenComponent<MudText>(stackSequence++);
                    stackBuilder.AddAttribute(stackSequence++, "Typo", Typo.body1);
                    stackBuilder.AddAttribute(stackSequence++, "Class", "pl-academy-article__body");
                    stackBuilder.AddAttribute(stackSequence++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, block)));
                    stackBuilder.CloseComponent();
                }
            }));
            paperBuilder.CloseComponent();
        }));
        builder.CloseComponent();
    };
}
