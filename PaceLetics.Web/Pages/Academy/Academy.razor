@page "/Academy"
@page "/Athletes/academy"
@attribute [Authorize]
@using PaceLetics.Web.Services.Academy
@inject IAcademyService AcademyService
@inject IStringLocalizer<Academy> L

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pl-section-page px-6 pb-8" MaxWidth="MaxWidth.Large">
    <nav class="pl-section-nav" aria-label="@L["Title"]">
        <button type="button"
                class="@GetSectionButtonClass(null)"
                aria-pressed="@(_selectedCategory is null)"
                @onclick="@(() => SelectCategory(null))">
            <MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Small" />
            <span>@L["TabAll"]</span>
        </button>

        @foreach (var category in _categories)
        {
            <button type="button"
                    class="@GetSectionButtonClass(category)"
                    aria-pressed="@IsCategorySelected(category)"
                    @onclick="@(() => SelectCategory(category))">
                <MudIcon Icon="@GetCategoryIcon(category)" Size="Size.Small" />
                <span>@FormatCategory(category)</span>
            </button>
        }
    </nav>

    <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

    <div class="pl-academy-grid mt-4">
        @foreach (var article in VisibleArticles)
        {
            <a href="@GetArticleHref(article)" class="pl-academy-tile-link" aria-label="@article.Title">
                <MudPaper Elevation="0" Class="@GetArticleTileClass(article)" role="article">
                    <div class="pl-academy-tile__header">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="pl-academy-tile__chip">
                            @FormatCategory(article.Category)
                        </MudChip>
                        <MudText Typo="Typo.subtitle1" Class="pl-academy-tile__title">@article.Title</MudText>
                    </div>

                    <div class="pl-academy-tile__icon" aria-hidden="true">
                        <MudIcon Icon="@GetArticleIcon(article)" />
                    </div>

                    <MudText Typo="Typo.caption" Class="pl-academy-tile__subtitle">@article.Summary</MudText>
                </MudPaper>
            </a>
        }
    </div>
</MudContainer>

@code {
    private IReadOnlyList<AcademyArticle> _articles = Array.Empty<AcademyArticle>();
    private IReadOnlyList<string> _categories = Array.Empty<string>();
    private string? _selectedCategory;

    private IEnumerable<AcademyArticle> VisibleArticles =>
        string.IsNullOrWhiteSpace(_selectedCategory)
            ? _articles
            : _articles.Where(article => string.Equals(article.Category, _selectedCategory, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        _articles = AcademyService.GetArticles();
        _categories = AcademyService.GetCategories();
    }

    private void SelectCategory(string? category)
    {
        _selectedCategory = category;
    }

    private bool IsCategorySelected(string category)
    {
        return string.Equals(_selectedCategory, category, StringComparison.OrdinalIgnoreCase);
    }

    private string GetSectionButtonClass(string? category)
    {
        return (string.IsNullOrWhiteSpace(category) && _selectedCategory is null)
            || (!string.IsNullOrWhiteSpace(category) && IsCategorySelected(category))
            ? "pl-section-nav__item pl-section-nav__item--active"
            : "pl-section-nav__item";
    }

    private string FormatCategory(string category)
    {
        return category switch
        {
            AcademyArticleCategories.Fundamentals => L["CategoryFundamentals"],
            AcademyArticleCategories.RunningAnalysis => L["CategoryRunningAnalysis"],
            _ => category
        };
    }

    private static string GetCategoryIcon(string category)
    {
        return category switch
        {
            AcademyArticleCategories.Fundamentals => Icons.Material.Filled.Psychology,
            AcademyArticleCategories.RunningAnalysis => Icons.Material.Filled.DirectionsRun,
            _ => Icons.Material.Filled.AutoStories
        };
    }

    private static string GetArticleIcon(AcademyArticle article)
    {
        return article.Id switch
        {
            "mental-resource-running" => Icons.Material.Filled.Psychology,
            "running-analysis-intervention-philosophy" => Icons.Material.Filled.DirectionsRun,
            "running-analysis-side-effects" => Icons.Material.Filled.Info,
            "running-analysis-shared-decision" => Icons.Material.Filled.Groups,
            _ => GetCategoryIcon(article.Category)
        };
    }

    private static string GetArticleTileClass(AcademyArticle article)
    {
        var accentClass = article.Category switch
        {
            AcademyArticleCategories.Fundamentals => "pl-academy-tile--fundamentals",
            AcademyArticleCategories.RunningAnalysis => "pl-academy-tile--running-analysis",
            _ => "pl-academy-tile--default"
        };

        return $"pl-academy-tile {accentClass}";
    }

    private static string GetArticleHref(AcademyArticle article)
    {
        return $"/Athletes/academy/{Uri.EscapeDataString(article.Id)}";
    }
}
