@page "/Academy"
@page "/Athletes/academy"
@attribute [Authorize]
@using PaceLetics.Web.Services.Articles
@using PaceLetics.Web.Pages.Workouts
@inject IArticleService ArticleService
@inject IStringLocalizer<Academy> L
@inject NavigationManager Navigation

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pl-section-page px-6 pb-8" MaxWidth="MaxWidth.Large">
    <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

    <nav class="pl-section-nav" aria-label="@L["Title"]">
        <button type="button"
                class="@GetSectionButtonClass(AcademySection.Bib)"
                aria-pressed="@(_activeSection == AcademySection.Bib)"
                @onclick="@(() => SelectSection(AcademySection.Bib))">
            <MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Small" />
            <span>@L["TabBib"]</span>
        </button>
        <button type="button"
                class="@GetSectionButtonClass(AcademySection.Gym)"
                aria-pressed="@(_activeSection == AcademySection.Gym)"
                @onclick="@(() => SelectSection(AcademySection.Gym))">
            <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Size="Size.Small" />
            <span>@L["TabGym"]</span>
        </button>
    </nav>

    <SwipeSection OnSwipeLeft="SelectNextSection" OnSwipeRight="SelectPreviousSection">
        @if (_activeSection == AcademySection.Bib)
        {
            <MudPaper Elevation="0" Class="pa-3 mt-4 pl-panel">
                <MudSelect T="string"
                           Label="@L["FilterLabel"]"
                           Value="_selectedCategory"
                           ValueChanged="SelectCategory"
                           Dense="true"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="string" Value="@AllCategories">@L["TabAll"]</MudSelectItem>
                    @foreach (var category in _categories)
                    {
                        <MudSelectItem T="string" Value="@category">
                            @FormatCategory(category)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>

            <div class="pl-academy-grid mt-4">
                @foreach (var article in VisibleArticles)
                {
                    <a href="@GetArticleHref(article)" class="pl-academy-tile-link" aria-label="@article.Title">
                        <article class="@GetArticleTileClass(article)">
                            <div class="pl-academy-tile__header">
                                <span class="pl-academy-tile__chip">
                                    @FormatCategory(article.Category)
                                </span>
                                <MudText Typo="Typo.subtitle1" Class="pl-academy-tile__title">@article.Title</MudText>
                            </div>

                            <div class="pl-academy-tile__icon" aria-hidden="true">
                                @if (IsMentalResourceArticle(article))
                                {
                                    <MentalResourceIcon />
                                }
                                else if (IsRunningAnalysisArticle(article))
                                {
                                    <RunningAnalysisIcon />
                                }
                                else if (IsTendonAdaptationArticle(article))
                                {
                                    <TendonIcon />
                                }
                                else if (IsInjuredAthletesArticle(article))
                                {
                                    <InjuryIcon />
                                }
                                else
                                {
                                    <MudIcon Icon="@GetArticleIcon(article)" />
                                }
                            </div>

                            <MudText Typo="Typo.caption" Class="pl-academy-tile__subtitle">@article.Summary</MudText>
                        </article>
                    </a>
                }
            </div>
        }
        else
        {
            <MudDivider Class="my-4" />
            <WorkoutArea Embedded="true" />
        }
    </SwipeSection>
</MudContainer>

@code {
    private const string AllCategories = "__all";
    private static readonly AcademySection[] Sections =
    [
        AcademySection.Bib,
        AcademySection.Gym
    ];

    private enum AcademySection
    {
        Bib,
        Gym
    }

    private IReadOnlyList<ArticlePreview> _articles = Array.Empty<ArticlePreview>();
    private IReadOnlyList<string> _categories = Array.Empty<string>();
    private string _selectedCategory = AllCategories;
    private AcademySection _activeSection = AcademySection.Bib;
    private string? _appliedSection;

    [SupplyParameterFromQuery(Name = "section")]
    public string? Section { get; set; }

    private IEnumerable<ArticlePreview> VisibleArticles =>
        string.Equals(_selectedCategory, AllCategories, StringComparison.Ordinal)
            ? _articles
            : _articles.Where(article => string.Equals(article.Category, _selectedCategory, StringComparison.OrdinalIgnoreCase));

    protected override void OnParametersSet()
    {
        if (string.Equals(_appliedSection, Section, StringComparison.OrdinalIgnoreCase))
            return;

        _appliedSection = Section;
        _activeSection = ParseSection(Section);
    }

    protected override void OnInitialized()
    {
        _articles = ArticleService.GetArticlePreviews();
        _categories = ArticleService.GetCategories();
    }

    private void SelectCategory(string category)
    {
        _selectedCategory = string.IsNullOrWhiteSpace(category) ? AllCategories : category;
    }

    private void SelectSection(AcademySection section)
    {
        _activeSection = section;
        Navigation.NavigateTo(GetSectionUri(section), replace: true);
    }

    private void SelectNextSection()
    {
        SelectSection(GetAdjacentSection(1));
    }

    private void SelectPreviousSection()
    {
        SelectSection(GetAdjacentSection(-1));
    }

    private AcademySection GetAdjacentSection(int offset)
    {
        var index = Array.IndexOf(Sections, _activeSection);
        if (index < 0)
            return Sections[0];

        var nextIndex = Math.Clamp(index + offset, 0, Sections.Length - 1);
        return Sections[nextIndex];
    }

    private string GetSectionButtonClass(AcademySection section)
    {
        return _activeSection == section
            ? "pl-section-nav__item pl-section-nav__item--active"
            : "pl-section-nav__item";
    }

    private static AcademySection ParseSection(string? value)
    {
        return value?.Trim().ToLowerInvariant() switch
        {
            "gym" => AcademySection.Gym,
            _ => AcademySection.Bib
        };
    }

    private static string GetSectionUri(AcademySection section)
    {
        return section == AcademySection.Gym
            ? "/Athletes/academy?section=gym"
            : "/Athletes/academy";
    }

    private string FormatCategory(string category)
    {
        return category switch
        {
            ArticleCategories.Fundamentals => L["CategoryFundamentals"],
            ArticleCategories.RunningAnalysis => L["CategoryRunningAnalysis"],
            ArticleCategories.Training => L["CategoryTraining"],
            _ => category
        };
    }

    private static string GetCategoryIcon(string category)
    {
        return category switch
        {
            ArticleCategories.Fundamentals => Icons.Material.Filled.Psychology,
            ArticleCategories.RunningAnalysis => Icons.Material.Filled.DirectionsRun,
            ArticleCategories.Training => Icons.Material.Filled.Speed,
            _ => Icons.Material.Filled.AutoStories
        };
    }

    private static string GetArticleIcon(ArticlePreview article)
    {
        return article.Id switch
        {
            "pace-controlled-training" => Icons.Material.Filled.Speed,
            "berlin-protocol-achilles-tendinopathy" => Icons.Material.Filled.FitnessCenter,
            _ => GetCategoryIcon(article.Category)
        };
    }

    private static bool IsMentalResourceArticle(ArticlePreview article)
    {
        return string.Equals(article.Id, "mental-resource-running", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsRunningAnalysisArticle(ArticlePreview article)
    {
        return string.Equals(article.Id, "evidence-based-running-analysis", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsTendonAdaptationArticle(ArticlePreview article)
    {
        return string.Equals(article.Id, "tendon-adaptation", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsInjuredAthletesArticle(ArticlePreview article)
    {
        return string.Equals(article.Id, "injured-athletes", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetArticleTileClass(ArticlePreview article)
    {
        var accentClass = article.Category switch
        {
            ArticleCategories.Fundamentals => "pl-academy-tile--fundamentals",
            ArticleCategories.RunningAnalysis => "pl-academy-tile--running-analysis",
            ArticleCategories.Training => "pl-academy-tile--training",
            _ => "pl-academy-tile--default"
        };

        return $"pl-academy-tile {accentClass}";
    }

    private static string GetArticleHref(ArticlePreview article)
    {
        return $"/Athletes/academy/{Uri.EscapeDataString(article.Id)}";
    }
}
