@page "/Athletes/trainingintervalls"

@using AthleteDataAccessLibrary.Contracts
@using MudBlazor
@using PaceLetics.AthleteModule.CodeBase.Models
@using PaceLetics.CoreModule.Infrastructure.Constants
@using PaceLetics.CoreModule.Infrastructure.Interfaces
@using PaceLetics.CoreModule.Infrastructure.Models
@using PaceLetics.TrainingModule.CodeBase.Running.Models
@using PaceLetics.Web.Services

@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IAthleteData AthleteData
@inject IDialogService DialogService
@inject LoadingStateService Loading
@inject IStringLocalizer<TrainingIntervalls> L
@inject ITrainingPlanService TrainingPlanService
@inject ICriticalSpeedService CriticalSpeedService

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pt-6 px-6 pb-8" MaxWidth="MaxWidth.Small">

    <PageHeader Title="@L["Title"]"
                Subtitle="@L["Subtitle"]" />

    <MudDivider Class="my-4" />

    <MudStack Spacing="3">

        @if (!_hasCriticalSpeed)
        {
            <MudAlert Severity="Severity.Warning">
                @L["NoRaceWarning"]
            </MudAlert>
        }
        else if (_currentTraining is null)
        {
            <MudAlert Severity="Severity.Info">
                @L["NoTrainings"]
            </MudAlert>
        }
        else
        {
            <MudPaper Class="pa-4 pl-training-panel" Elevation="0">
                <MudStack Spacing="3">

                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap:12px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="min-width:0;">
                            <div class="pl-training-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Medium" />
                            </div>

                            <MudStack Spacing="0" Style="min-width:0;">
                                <MudText Typo="Typo.h6">
                                    @_currentTraining.Name
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    ID: @_currentTraining.Id / @L["PlannedOn"] @_currentTraining.Date.ToString("dd.MM.yyyy")
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudStack>

                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">
                            @_currentTraining.Sets Set(s)
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            @($"{_currentTraining.TotalDistance / 1000.0:0.0} km")
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                            @_currentTraining.Distances.Count Intervall(e)
                        </MudChip>
                    </MudStack>

                    <MudDivider />

                    <MudStack Spacing="0">
                        @foreach (var row in TableRows)
                        {
                            <div class="@GetIntervalRowClass(row)">
                                <div class="pl-training-icon">
                                    <MudIcon Icon="@(row.IsPause ? Icons.Material.Filled.SelfImprovement : Icons.Material.Filled.Speed)"
                                             Size="Size.Small" />
                                </div>

                                <MudStack Spacing="0" Style="min-width:0;">
                                    <MudText Typo="Typo.body2">@GetRowTitle(row)</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @(row.IsPause ? "Recovery" : "Intervall")
                                    </MudText>
                                </MudStack>

                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @($"{GetRowDistance(row)} m")
                                </MudText>
                            </div>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    </MudStack>

</MudContainer>

@code {
    private AthleteModel? _athlete;
    private IntervallSession? _currentTraining;
    private bool _hasCriticalSpeed;

    private record TableRow(bool IsPause, int Index);

    private IEnumerable<TableRow> TableRows =>
        Enumerable.Range(0, _currentTraining!.Distances.Count)
            .SelectMany(i =>
            {
                var list = new List<TableRow> { new(false, i) };
                if (i < _currentTraining.Recovery.Count && _currentTraining.Recovery[i] > 0)
                    list.Add(new(true, i));
                return list;
            });

    private string GetIntervalRowClass(TableRow row)
    {
        return row.IsPause
            ? "pl-interval-row pl-interval-row-muted"
            : "pl-interval-row";
    }

    private int GetRowDistance(TableRow row)
    {
        return row.IsPause
            ? _currentTraining!.Recovery[row.Index]
            : _currentTraining!.Distances[row.Index];
    }

    private string GetRowTitle(TableRow row)
    {
        return row.IsPause
            ? "Pause"
            : PaceKeys.Normalize(_currentTraining!.PaceKeys[row.Index]) ?? PaceKeys.Free;
    }

    protected override async Task OnInitializedAsync()
    {
        await Loading.RunAsync(L["Loading"], async () =>
        {
            var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
            var userID = authState.User.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value;

            if (string.IsNullOrEmpty(userID))
            {
                await DialogService.ShowInformationAsync(
                    L["NotLoggedIn_Title"],
                    L["NotLoggedIn_Message"],
                    Icons.Material.Filled.Error);
                return;
            }

            _athlete = await AthleteData.GetAthlete(userID);

            if (_athlete is null)
                return;

            var results = _athlete.RaceResults?.ToList() ?? [];
            if (_athlete.ActiveReferenceResult is not null
                && !results.Any(result => result.DistanceM == _athlete.ActiveReferenceResult.DistanceM
                    && result.Time == _athlete.ActiveReferenceResult.Time
                    && result.Date.Date == _athlete.ActiveReferenceResult.Date.Date))
            {
                results.Add(_athlete.ActiveReferenceResult);
            }

            var criticalSpeed = CriticalSpeedService.Estimate(results);
            _hasCriticalSpeed = criticalSpeed.IsValid;
            _athlete.PaceModel = criticalSpeed.IsValid
                ? CriticalSpeedService.BuildPaceModel(criticalSpeed)
                : new PaceModel();

            var sessions = TrainingPlanService.LoadLegacySessions()
                .OfType<IntervallSession>()
                .ToList();

            var today = DateTime.Today;
            var upcoming = sessions
                .Where(t => t.Date.Date >= today)
                .OrderBy(t => t.Date)
                .FirstOrDefault();

            _currentTraining = upcoming ?? sessions.OrderByDescending(t => t.Date).FirstOrDefault();
        });


    }

    
}
