@page "/Athletes/trainingplanpage"
@using AthleteDataAccessLibrary.Contracts
@using PaceLetics.AthleteModule.CodeBase.Models
@using PaceLetics.CoreModule.Infrastructure.Constants
@using PaceLetics.CoreModule.Infrastructure.Models
@using PaceLetics.TrainingModule.CodeBase.Running.Models
@using PaceLetics.TrainingModule.Components.Running
@using PaceLetics.TrainingPlanModule.CodeBase.Models
@using PaceLetics.Web.Services
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IAthleteData AthleteData
@inject IDialogService dialogService
@inject IStringLocalizer<TrainingPlanPage> L
@inject ITrainingPlanService TrainingPlanService


<MudContainer Class="pt-6 px-6 pb-8" MaxWidth="MaxWidth.Small">

<PageHeader Title="@L["Title"]"
            Subtitle="@L["Subtitle"]" />

<MudDivider Class="my-4" />

<MudStack Spacing="2" Class="mb-4">
    @if (_plans == null || !_plans.Any())
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            <MudStack Row="true"
                      AlignItems="AlignItems.Center"
                      Justify="Justify.SpaceBetween"
                      Style="width:100%; gap:12px;">
                <MudText Typo="Typo.body2">@L["NoPlans"]</MudText>
                <MudTooltip Text="@L["CourseSelectionLink"]">
                    <MudIconButton Href="/Athletes/courses"
                                   Icon="@Icons.Material.Filled.School"
                                   Color="Color.Primary"
                                   aria-label="@L["CourseSelectionLink"]" />
                </MudTooltip>
            </MudStack>
        </MudAlert>
    }
    else
    {
        <MudPaper Class="pa-3 pl-panel" Elevation="0">
            <MudSelect T="string" Label="@L["SelectPlan"]"
                       Value="_selectedPlanId"
                       ValueChanged="@(async (string id) => await OnPlanChanged(id))"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Immediate="true">
                @foreach (var p in _plans)
                {
                    <MudSelectItem T="string" Value="@p.Id">@p.Name</MudSelectItem>
                }
            </MudSelect>
        </MudPaper>
    }
</MudStack>

<!-- Timeline -->
@if (Plan is not null)
{
    <div style="height: calc(100vh - 300px); overflow:auto; -webkit-overflow-scrolling:touch; padding:0 12px 12px 12px;">
        <MudTimeline TimelineOrientation="TimelineOrientation.Vertical"
                     TimelinePosition="TimelinePosition.Left">

            @foreach (var session in Plan.Sessions)
            {
                var isNext = session.Id == _nextSessionId;

                <MudTimelineItem id="@(isNext ? "next-session" : null)"
                                 Color="@(isNext ? Color.Primary : Color.Surface)"
                                 Elevation="@(isNext ? 26 : 10)"
                                 Size="@(isNext ? Size.Large : Size.Medium)"
                                 Style="width:100%;">

                    <div style="cursor:pointer;"
                         @onclick="() => OpenDetails(session.Id)">
                        @if (session.PrimaryRun is not null)
                        {
                            <RunningSessionMiniCard Session="session.PrimaryRun" IsHighlighted="isNext" />
                        }
                        else
                        {
                            <MudPaper Elevation="0" Class="pa-3 pl-surface-card">
                                <MudText Typo="Typo.subtitle2">@session.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @session.Date.ToString("dd.MM.yyyy") · @($"{session.Workouts.Count} Workout(s)")
                                </MudText>
                            </MudPaper>
                        }
                    </div>

                </MudTimelineItem>
            }
        </MudTimeline>
    </div>
}
@if (_detailsOpen)
{
    <div class="pl-overlay"
         @onclick="CloseDetails">
    </div>
}

<div style="
     position:fixed;
     left:0; right:0; bottom:0;
     z-index:1301;
     transform: translateY(@(_detailsOpen ? "0" : "105%"));
     transition: transform 180ms ease;
     pointer-events:@(_detailsOpen ? "auto" : "none");
">
    <MudPaper Elevation="12"
              Class="pl-bottom-sheet">

        <div style="padding:12px 16px;">
            <div class="pl-bottom-sheet-handle"></div>

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                <MudText Typo="Typo.h6">@(_selectedTrainingSession?.Name ?? _resolved?.Name ?? L["Session"])</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseDetails" />
            </MudStack>

            @if (_selectedTrainingSession is not null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @_selectedTrainingSession.Date.ToString("dd.MM.yyyy")
                    @if (_resolved is not null)
                    {
                        @(" · ")
                        @($"{_resolved.TotalDistance / 1000.0:0.0} km")
                    }
                    @if (_selectedTrainingSession.Workouts.Count > 0)
                    {
                        @(" · ")
                        @($"{_selectedTrainingSession.Workouts.Count} Workout(s)")
                    }
                </MudText>
            }
        </div>

        <MudDivider />

        <div style="height: calc(100% - 78px); overflow:auto; padding:12px 16px;">
            @if (_selectedTrainingSession is null)
            {
                <MudText Color="Color.Secondary">@L["NoDetails"]</MudText>
            }
            else
            {
                <MudStack Spacing="2">
                    @if (_selectedTrainingSession.Workouts.Count > 0)
                    {
                        @foreach (var workout in _selectedTrainingSession.Workouts)
                        {
                            <MudPaper Elevation="0" Class="pa-3 pl-bottom-sheet-item">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2">@(!string.IsNullOrWhiteSpace(workout.Name) ? workout.Name : workout.WorkoutId)</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @($"{workout.Sets} Set(s) · {workout.Rounds} Round(s)")
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        }
                    }

                    @if (_resolved is not null)
                    {
                        @foreach (var rs in _resolved.Segments)
                        {
                            var paceZoneClass = GetPaceZoneClass(rs.Segment.PaceKey);
                            var paceZoneCode = GetPaceZoneCode(rs.Segment.PaceKey);

                            <MudPaper Elevation="0" Class="@($"pa-3 pl-bottom-sheet-item {paceZoneClass}")">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    @if (!string.IsNullOrEmpty(paceZoneCode))
                                    {
                                        <div class="pl-pace-zone-mark pl-pace-zone-mark-small" aria-hidden="true">
                                            @paceZoneCode
                                        </div>
                                    }

                                    <MudStack Spacing="1" Style="min-width:0;">
                                        <MudText Typo="Typo.subtitle2">@rs.Segment.Type</MudText>

                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @(rs.Segment.Distance > 0 ? $"{rs.Segment.Distance} m" : "-")
                                            @(" · ")
                                            @(rs.Pace is null ? "-" : $"{rs.Pace:mm\\:ss}/km")
                                        </MudText>

                                        @if (rs.SegmentTime is not null || rs.LapTime is not null)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @(rs.SegmentTime is null ? "" : $"Segment: {rs.SegmentTime:hh\\:mm\\:ss}".Trim())
                                                @(rs.SegmentTime is not null && rs.LapTime is not null ? " · " : "")
                                                @(rs.LapTime is null ? "" : $"Lap: {rs.LapTime:mm\\:ss}")
                                            </MudText>
                                        }
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                    }
                </MudStack>
            }
        </div>
    </MudPaper>
</div>

</MudContainer>

@code {
    private TrainingPlan? Plan;
    private string? _nextSessionId;
    private AthleteModel? _athlete;
    private string? _userId;

    private bool _detailsOpen;
    private ResolvedRunningSession? _resolved;
    private TrainingSession? _selectedTrainingSession;

    private PaceModel _paceModel = default!;

    private List<TrainingPlan> _plans = new();
    private string? _selectedPlanId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // athlete laden
            var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
            var userID = authState.User.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value;

            if (!string.IsNullOrEmpty(userID))
            {
                _userId = userID;
                _athlete = await AthleteData.GetAthlete(userID);

                if (_athlete?.PaceModel is not null)
                    _paceModel = _athlete.PaceModel;
            }

            _plans = (await TrainingPlanService.LoadTrainingPlansForUserAsync(userID)).ToList();

            // Auswahl: gespeicherter Plan wenn vorhanden (Server-Athlete.SelectedTrainingPlanId), sonst Browser localStorage, sonst nächster oder erster Plan
            string? storedPlan = null;

            if (_athlete?.SelectedTrainingPlanId is not null && _plans.Any(p => p.Id == _athlete.SelectedTrainingPlanId))
            {
                _selectedPlanId = _athlete.SelectedTrainingPlanId;
            }
            else
            {
                if (!string.IsNullOrEmpty(userID))
                {
                    try
                    {
                        var key = $"selectedPlan_{userID}";
                        storedPlan = await JS.InvokeAsync<string>("localStorage.getItem", key);
                    }
                    catch
                    {
                        // ignore JS/localStorage errors
                    }
                }

                if (!string.IsNullOrEmpty(storedPlan) && _plans.Any(p => p.Id == storedPlan))
                {
                    _selectedPlanId = storedPlan;
                }
                else
                {
                    // nächster Plan finden
                    var today = DateTime.Today;
                    var next = _plans
                        .Where(p => p.Sessions.Any())
                        .SelectMany(p => p.Sessions.Select(s => (Plan: p, Session: s)))
                        .Where(x => x.Session.Date.Date >= today)
                        .OrderBy(x => x.Session.Date)
                        .FirstOrDefault();

                    if (next != default)
                        _selectedPlanId = next.Plan.Id;
                    else
                        _selectedPlanId = _plans.FirstOrDefault()?.Id;
                }
            }

            // Setze aktuell gewählten Plan
            Plan = _plans.FirstOrDefault(p => p.Id == _selectedPlanId);

            if (Plan is not null)
            {
                var today = DateTime.Today;
                _nextSessionId = Plan.Sessions
                    .Where(s => s.Date.Date >= today)
                    .OrderBy(s => s.Date)
                    .Select(s => s.Id)
                    .FirstOrDefault();
            }
        }
        catch
        {
            await dialogService.ShowInformationAsync(
                L["Error_Title"],
                L["Error_LoadData"],
                Icons.Material.Filled.Error);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _nextSessionId != null)
            await JS.InvokeVoidAsync("scrollToNextSession");
    }

    private void OpenDetails(string sessionId)
    {
        if (Plan is null) return;
        var session = Plan.Sessions.FirstOrDefault(s => s.Id == sessionId);
        if (session is null) return;

        _selectedTrainingSession = session;
        var run = session.PrimaryRun;
        _resolved = run is null ? null : RunningSessionResolver.Resolve(run, _paceModel);
        _detailsOpen = true;
    }

    private void CloseDetails()
    {
        _detailsOpen = false;
    }

    private static string GetPaceZoneClass(string? paceKey)
    {
        return paceKey switch
        {
            PaceKeys.Free => "pl-pace-zone-free",
            PaceKeys.Recovery => "pl-pace-zone-recovery",
            PaceKeys.Easy => "pl-pace-zone-easy",
            PaceKeys.Marathon => "pl-pace-zone-marathon",
            PaceKeys.Threshold => "pl-pace-zone-threshold",
            PaceKeys.Intervall => "pl-pace-zone-intervall",
            PaceKeys.Repetition => "pl-pace-zone-repetition",
            _ => string.Empty
        };
    }

    private static string GetPaceZoneCode(string? paceKey)
    {
        return paceKey switch
        {
            PaceKeys.Free => "Free",
            PaceKeys.Recovery => "Rec",
            PaceKeys.Easy => "E",
            PaceKeys.Marathon => "M",
            PaceKeys.Threshold => "T",
            PaceKeys.Intervall => "I",
            PaceKeys.Repetition => "R",
            _ => string.Empty
        };
    }

    private async Task SaveSelectedPlanAsync()
    {
        if (_selectedPlanId == null) return;

        // local anwenden
        Plan = _plans.FirstOrDefault(p => p.Id == _selectedPlanId);

        var today = DateTime.Today;
        _nextSessionId = Plan?.Sessions
            .Where(s => s.Date.Date >= today)
            .OrderBy(s => s.Date)
            .Select(s => s.Id)
            .FirstOrDefault();
        try
        {
            if (!string.IsNullOrEmpty(_userId))
            {
                var key = $"selectedPlan_{_userId}";
                await JS.InvokeVoidAsync("localStorage.setItem", key, _selectedPlanId);
            }
        }
        catch
        {
            await dialogService.ShowInformationAsync(L["Error_SaveBrowser_Title"], L["Error_SaveBrowser"], Icons.Material.Filled.Error);
        }

        StateHasChanged();
    }

    private async Task OnPlanChanged(string id)
    {
        _selectedPlanId = id;
        // apply immediately
        Plan = _plans.FirstOrDefault(p => p.Id == _selectedPlanId);

        var today = DateTime.Today;
        _nextSessionId = Plan?.Sessions
            .Where(s => s.Date.Date >= today)
            .OrderBy(s => s.Date)
            .Select(s => s.Id)
            .FirstOrDefault();

        // persist on server if athlete loaded
        if (_athlete is not null)
        {
            try
            {
                // ensure AthleteModel has SelectedTrainingPlanId property
                _athlete.SelectedTrainingPlanId = _selectedPlanId;
                await AthleteData.UpdateAthlete(_athlete);
            }
            catch
            {
                await dialogService.ShowInformationAsync(L["Error_SaveServer_Title"], L["Error_SaveServer"], Icons.Material.Filled.Error);
            }
        }

        StateHasChanged();
    }
}
