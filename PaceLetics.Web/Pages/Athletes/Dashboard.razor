@page "/"
@using AthleteDataAccessLibrary.Contracts
@using PaceLetics.AthleteModule.CodeBase.Models
@using PaceLetics.TrainingPlanModule.CodeBase.Models
@using PaceLetics.Web.Services.Calendar
@inject IAthleteData AthleteData
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ITrainingPlanService TrainingPlanService
@inject ITrainingCalendarService CalendarService
@inject IAchievementService AchievementService
@inject ITrainingFeedbackService FeedbackService
@inject LoadingStateService Loading
@inject NavigationManager Navigation
@inject IStringLocalizer<Dashboard> L

<PageTitle>@L["TodayPageTitle"]</PageTitle>

<MudContainer Class="pl-section-page px-4 px-sm-6 pb-8 pl-today-page" MaxWidth="MaxWidth.Medium">
    <PageHeader Title="@GetGreeting()" Subtitle="@L["TodaySubtitle"]" />

    <MudStack Spacing="4" Class="pt-4">
        @if (_hasLoadError)
        {
            <RetryAlert Message="@L["PartialLoadError"]" OnRetry="LoadDashboardAsync" />
        }

        <section class="@GetRecommendationClass()" aria-labelledby="daily-guidance-title">
            <span class="pl-guidance__icon"><MudIcon Icon="@GetRecommendationIcon()" /></span>
            <span>
                <MudText Typo="Typo.subtitle2" HtmlTag="h2" id="daily-guidance-title">@GetRecommendationTitle()</MudText>
                <MudText Typo="Typo.body2">@GetRecommendationDetail()</MudText>
            </span>
        </section>

        <section class="pl-today-hero" aria-labelledby="today-training-title">
            @if (NextSession is { } next)
            {
                <MudStack Spacing="3">
                    <div class="pl-today-hero__heading">
                        <span>
                            <MudText Typo="Typo.overline" Color="Color.Primary">@GetNextLabel(next.Session)</MudText>
                            <MudText Typo="Typo.h4" HtmlTag="h2" id="today-training-title">@next.Session.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@GetSessionDate(next.Session)</MudText>
                        </span>
                        <span class="pl-today-hero__duration">
                            <strong>@TrainingSessionPresentation.EstimateDurationMinutes(next.Session)</strong>
                            <small>@L["MinutesShort"]</small>
                        </span>
                    </div>

                    <TrainingSessionSummary Session="@next.Session" Compact="true" />

                    <MudButton Href="@GetSessionHref(next)"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.PlayArrow">
                        @L["StartTraining"]
                    </MudButton>
                </MudStack>
            }
            else
            {
                <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-4">
                    <span class="pl-today-hero__empty-icon"><MudIcon Icon="@Icons.Material.Filled.EventAvailable" Size="Size.Large" /></span>
                    <MudText Typo="Typo.h5" HtmlTag="h2" id="today-training-title" Align="Align.Center">@L["NoTrainingTitle"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">@L["NoTrainingDetail"]</MudText>
                    <MudButton Href="/Athletes/plan"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.CalendarMonth">
                        @L["OpenPlan"]
                    </MudButton>
                </MudStack>
            }
        </section>

        <section class="pl-today-section" aria-labelledby="week-title">
            <div class="pl-today-section__heading">
                <span>
                    <MudText Typo="Typo.h6" HtmlTag="h2" id="week-title">@L["ThisWeek"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@GetWeekProgressText()</MudText>
                </span>
                <a href="/Athletes/plan">@L["ViewPlan"]</a>
            </div>
            <div class="pl-today-week" aria-label="@GetWeekProgressText()">
                @foreach (var day in CurrentWeekDays)
                {
                    var state = GetDayState(day);
                    <a class="@GetWeekDayClass(day, state)" href="/Athletes/plan">
                        <small>@day.ToString("ddd")</small>
                        <strong>@day.Day</strong>
                        <span aria-hidden="true"></span>
                    </a>
                }
            </div>
        </section>

        <section class="pl-today-section" aria-labelledby="progress-title">
            <div class="pl-today-section__heading">
                <span>
                    <MudText Typo="Typo.h6" HtmlTag="h2" id="progress-title">@L["Progress"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["ProgressSubtitle"]</MudText>
                </span>
                <a href="/Athletes/data-analyses">@L["ViewProgress"]</a>
            </div>
            <div class="pl-today-stats">
                <div>
                    <small>@L["Vdot"]</small>
                    <strong>@GetVdot()</strong>
                </div>
                <div>
                    <small>@L["SessionsCompleted"]</small>
                    <strong>@_completions.Count</strong>
                </div>
                <div>
                    <small>@L["FeedbackLast28Days"]</small>
                    <strong>@_recentFeedbackCount</strong>
                </div>
            </div>
        </section>

        @if (NextNonTrainingItem is { } notice)
        {
            <section class="pl-today-section" aria-labelledby="notice-title">
                <div class="pl-today-section__heading">
                    <span>
                        <MudText Typo="Typo.h6" HtmlTag="h2" id="notice-title">@L["Notice"]</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["NextCourseDate"]</MudText>
                    </span>
                </div>
                <a class="pl-today-notice" href="/Athletes/plan">
                    <span class="pl-today-notice__date">
                        <strong>@notice.StartsAt.Day</strong>
                        <small>@notice.StartsAt.ToString("MMM")</small>
                    </span>
                    <span>
                        <strong>@notice.Title</strong>
                        <small>@GetNoticeMeta(notice)</small>
                    </span>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                </a>
            </section>
        }
    </MudStack>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "section")]
    public string? LegacySection { get; set; }

    private AthleteModel? _athlete;
    private string _name = string.Empty;
    private IReadOnlyList<TrainingPlan> _plans = Array.Empty<TrainingPlan>();
    private IReadOnlyList<TrainingCalendarItem> _calendarItems = Array.Empty<TrainingCalendarItem>();
    private IReadOnlyList<TrainingSessionCompletionDocument> _completions = Array.Empty<TrainingSessionCompletionDocument>();
    private TrainingRecommendation _recommendation = new(TrainingRecommendationKind.NoData, 0);
    private int _recentFeedbackCount;
    private bool _hasLoadError;

    private PlannedSession? NextSession
    {
        get
        {
            var completed = _completions
                .Select(item => CompletionKey(item.PlanId, item.SessionId))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            return _plans
                .SelectMany(plan => plan.Sessions.Select(session => new PlannedSession(plan.Id, session)))
                .Where(item => GetSessionStart(item.Session).Date >= DateTime.Today)
                .Where(item => !completed.Contains(CompletionKey(item.PlanId, item.Session.Id)))
                .OrderBy(item => item.Session.Appointment.StartsAt ?? item.Session.Date)
                .FirstOrDefault();
        }
    }

    private TrainingCalendarItem? NextNonTrainingItem => _calendarItems
        .Where(item => item.Kind != TrainingCalendarItemKinds.TrainingSession)
        .Where(item => item.StartsAt >= DateTime.Now)
        .OrderBy(item => item.StartsAt)
        .FirstOrDefault();

    private IEnumerable<DateTime> CurrentWeekDays
    {
        get
        {
            var offset = ((int)DateTime.Today.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
            var monday = DateTime.Today.AddDays(-offset);
            return Enumerable.Range(0, 7).Select(day => monday.AddDays(day));
        }
    }

    protected override void OnParametersSet()
    {
        if (string.Equals(LegacySection, "achievements", StringComparison.OrdinalIgnoreCase)
            || string.Equals(LegacySection, "awards", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/Athletes/achievements", replace: true);
        }
    }

    protected override async Task OnInitializedAsync() => await LoadDashboardAsync();

    private async Task LoadDashboardAsync()
    {
        _hasLoadError = false;
        await Loading.RunAsync(L["Loading"], async () =>
        {
            var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = state.User.FindFirst(claim =>
                claim.Type.Contains("nameidentifier", StringComparison.OrdinalIgnoreCase))?.Value;
            _name = state.User.Identity?.Name ?? string.Empty;
            if (string.IsNullOrWhiteSpace(userId))
                return;

            try
            {
                _athlete = await AthleteData.GetAthlete(userId);
                if (!string.IsNullOrWhiteSpace(_athlete?.Name))
                    _name = _athlete.Name;
            }
            catch
            {
                _athlete = null;
                _hasLoadError = true;
            }

            try
            {
                var plansTask = TrainingPlanService.LoadTrainingPlansForUserAsync(userId);
                var calendarTask = CalendarService.GetCalendarItemsForAthleteAsync(userId);
                var completionsTask = AchievementService.GetTrainingSessionCompletionsForAthleteAsync(userId);
                var feedbackTask = FeedbackService.GetRecentAsync(userId, 28);
                await Task.WhenAll(plansTask, calendarTask, completionsTask, feedbackTask);
                _plans = await plansTask;
                _calendarItems = await calendarTask;
                _completions = await completionsTask;
                _recentFeedbackCount = (await feedbackTask).Count;
                _recommendation = await FeedbackService.GetRecommendationAsync(userId, NextSession is not null);
            }
            catch
            {
                _plans = Array.Empty<TrainingPlan>();
                _calendarItems = Array.Empty<TrainingCalendarItem>();
                _completions = Array.Empty<TrainingSessionCompletionDocument>();
                _recommendation = new TrainingRecommendation(TrainingRecommendationKind.NoData, 0);
                _recentFeedbackCount = 0;
                _hasLoadError = true;
            }
        });
    }

    private string GetGreeting()
    {
        var greeting = DateTime.Now.Hour switch
        {
            < 11 => L["GoodMorning"].Value,
            < 18 => L["GoodDay"].Value,
            _ => L["GoodEvening"].Value
        };
        var firstName = _name.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        return string.IsNullOrWhiteSpace(firstName) ? greeting : $"{greeting}, {firstName}";
    }

    private string GetRecommendationClass() => _recommendation.Kind switch
    {
        TrainingRecommendationKind.PrioritizeRecovery => "pl-guidance pl-guidance--warning",
        TrainingRecommendationKind.TakeItEasy => "pl-guidance pl-guidance--info",
        _ => "pl-guidance pl-guidance--positive"
    };

    private string GetRecommendationIcon() => _recommendation.Kind switch
    {
        TrainingRecommendationKind.PrioritizeRecovery => Icons.Material.Filled.SelfImprovement,
        TrainingRecommendationKind.TakeItEasy => Icons.Material.Filled.Bedtime,
        TrainingRecommendationKind.OnTrack => Icons.Material.Filled.CheckCircle,
        _ => Icons.Material.Filled.Lightbulb
    };

    private string GetRecommendationTitle() => _recommendation.Kind switch
    {
        TrainingRecommendationKind.PrioritizeRecovery => L["RecoveryTitle"],
        TrainingRecommendationKind.TakeItEasy => L["EasyTitle"],
        TrainingRecommendationKind.OnTrack => L["OnTrackTitle"],
        TrainingRecommendationKind.Upcoming => L["UpcomingTitle"],
        _ => L["NoDataTitle"]
    };

    private string GetRecommendationDetail() => _recommendation.Kind switch
    {
        TrainingRecommendationKind.PrioritizeRecovery => L["RecoveryDetail"],
        TrainingRecommendationKind.TakeItEasy => L["EasyDetail"],
        TrainingRecommendationKind.OnTrack => L["OnTrackDetail"],
        TrainingRecommendationKind.Upcoming => L["UpcomingDetail"],
        _ => L["NoDataDetail"]
    };

    private string GetNextLabel(TrainingSession session) => GetSessionStart(session).Date == DateTime.Today
        ? L["TodayTraining"]
        : L["NextTraining"];

    private static string GetSessionDate(TrainingSession session)
    {
        var date = GetSessionStart(session);
        return session.Appointment.StartsAt is null
            ? date.ToString("dddd, dd. MMMM")
            : date.ToString("dddd, dd. MMMM · HH:mm");
    }

    private string GetWeekProgressText()
    {
        var days = CurrentWeekDays.ToList();
        var start = days[0].Date;
        var end = days[^1].Date;
        var planned = _plans
            .SelectMany(plan => plan.Sessions.Select(session => new PlannedSession(plan.Id, session)))
            .Where(item => GetSessionStart(item.Session).Date >= start && GetSessionStart(item.Session).Date <= end)
            .ToList();
        var completedKeys = _completions.Select(item => CompletionKey(item.PlanId, item.SessionId))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var completed = planned.Count(item => completedKeys.Contains(CompletionKey(item.PlanId, item.Session.Id)));
        return planned.Count == 0 ? L["NoSessionsThisWeek"] : L["WeekProgress", completed, planned.Count];
    }

    private WeekDayState GetDayState(DateTime day)
    {
        var sessions = _plans
            .SelectMany(plan => plan.Sessions.Select(session => new PlannedSession(plan.Id, session)))
            .Where(item => GetSessionStart(item.Session).Date == day.Date)
            .ToList();
        if (sessions.Count == 0)
            return WeekDayState.Empty;
        var completedKeys = _completions.Select(item => CompletionKey(item.PlanId, item.SessionId))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        return sessions.All(item => completedKeys.Contains(CompletionKey(item.PlanId, item.Session.Id)))
            ? WeekDayState.Completed
            : WeekDayState.Planned;
    }

    private static string GetWeekDayClass(DateTime day, WeekDayState state)
    {
        var classes = new List<string> { "pl-today-week__day" };
        if (day.Date == DateTime.Today)
            classes.Add("pl-today-week__day--today");
        if (state == WeekDayState.Planned)
            classes.Add("pl-today-week__day--planned");
        if (state == WeekDayState.Completed)
            classes.Add("pl-today-week__day--completed");
        return string.Join(" ", classes);
    }

    private string GetVdot() => _athlete?.Vdot > 0 ? _athlete.Vdot.ToString("0.0") : "–";

    private static string GetNoticeMeta(TrainingCalendarItem item)
    {
        var parts = new List<string> { item.StartsAt.ToString("HH:mm") };
        if (!string.IsNullOrWhiteSpace(item.Location))
            parts.Add(item.Location);
        if (!string.IsNullOrWhiteSpace(item.CourseName))
            parts.Add(item.CourseName);
        return string.Join(" · ", parts);
    }

    private static string CompletionKey(string planId, string sessionId) => $"{planId}:{sessionId}";
    private static DateTime GetSessionStart(TrainingSession session) => session.Appointment.StartsAt ?? session.Date;
    private static string GetSessionHref(PlannedSession item) =>
        $"/Athletes/session/{Uri.EscapeDataString(item.PlanId)}/{Uri.EscapeDataString(item.Session.Id)}";

    private enum WeekDayState { Empty, Planned, Completed }
    private sealed record PlannedSession(string PlanId, TrainingSession Session);
}
