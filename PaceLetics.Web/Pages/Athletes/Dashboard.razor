@page "/"
@page "/Athletes/dashboard"
@using AthleteDataAccessLibrary;
@using AthleteDataAccessLibrary.Contracts;

@using MudBlazor;
@using PaceLetics.AthleteModule.CodeBase.Models;
@using PaceLetics.CoreModule.Infrastructure.Models
@using PaceLetics.CoreModule.Infrastructure.Services
@using PaceLetics.TrainingPlanModule.CodeBase.Models
@using PaceLetics.Web.Services

@inject IAthleteData AthleteData
@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IStringLocalizer<Dashboard> L
@inject LoadingStateService Loading
@inject ITrainingPlanService TrainingPlanService

<PageTitle>@L["PageTitle"]</PageTitle>


<MudContainer Class="pt-6 px-6 pb-8" MaxWidth="MaxWidth.Small">

    <PageHeader Title="@L["Title"]" Subtitle="@L["WelcomeText", _name]" />

    <MudDivider Class="my-4" />

    <MudStack Spacing="4">

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" lg="4">
                <DashboardMetricTile Label="@L["Metric_Vdot"]"
                                     Value="@GetVdotValue()"
                                     Detail="@GetReferenceDetail()"
                                     Icon="@Icons.Material.Filled.Speed"
                                     Accent="blue"
                                     Href="/Athletes/trainingpaces" />
            </MudItem>

            <MudItem xs="12" sm="6" lg="4">
                <DashboardMetricTile Label="@L["Metric_NextSession"]"
                                     Value="@GetNextSessionValue()"
                                     Detail="@GetNextSessionDetail()"
                                     Icon="@Icons.Material.Filled.EventAvailable"
                                     Accent="green"
                                     Href="/Athletes/trainingplanpage" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="3">
            <MudItem xs="12">
                <DashboardNextTrainingSessionTile Session="_nextSession" />
            </MudItem>
        </MudGrid>
    </MudStack>

</MudContainer>

    


@code
{
    AthleteModel? Athlete;
    string _name = String.Empty;
    IReadOnlyList<TrainingPlan> _trainingPlans = Array.Empty<TrainingPlan>();
    TrainingPlan? _activePlan;
    TrainingSession? _nextSession;
    RaceResultModel? _referenceResult;

    protected override async Task OnInitializedAsync()
    {
        await Loading.RunAsync(L["Loading"], async () =>
        {
            var authstate = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
            var user = authstate.User;
            var id = user.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value;
            Athlete = string.IsNullOrWhiteSpace(id)
                ? null
                : await AthleteData.GetAthlete(id);
            _name = string.IsNullOrWhiteSpace(Athlete?.Name)
                ? user.Identity?.Name ?? string.Empty
                : Athlete.Name;
            try
            {
                _trainingPlans = await TrainingPlanService.LoadTrainingPlansForUserAsync(id);
            }
            catch
            {
                _trainingPlans = Array.Empty<TrainingPlan>();
            }
            _activePlan = ResolveActivePlan(_trainingPlans, Athlete);
            _nextSession = ResolveNextSession(_activePlan, _trainingPlans);
            _referenceResult = Athlete?.ActiveReferenceResult;
        });

        await base.OnInitializedAsync();
    }

    private static TrainingPlan? ResolveActivePlan(IReadOnlyList<TrainingPlan> trainingPlans, AthleteModel? athlete)
    {
        if (trainingPlans.Count == 0)
            return null;

        if (!string.IsNullOrWhiteSpace(athlete?.SelectedTrainingPlanId))
        {
            var selected = trainingPlans.FirstOrDefault(plan => plan.Id == athlete.SelectedTrainingPlanId);
            if (selected is not null)
                return selected;
        }

        return trainingPlans.FirstOrDefault(plan => plan.Sessions.Any(session => session.Date.Date >= DateTime.Today))
            ?? trainingPlans.FirstOrDefault();
    }

    private static TrainingSession? ResolveNextSession(TrainingPlan? activePlan, IReadOnlyList<TrainingPlan> trainingPlans)
    {
        if (activePlan is not null)
        {
            var selectedNext = activePlan.Sessions
                .Where(session => session.Date.Date >= DateTime.Today)
                .OrderBy(session => session.Date)
                .FirstOrDefault();

            if (selectedNext is not null)
                return selectedNext;
        }

        return trainingPlans
            .SelectMany(plan => plan.Sessions)
            .Where(session => session.Date.Date >= DateTime.Today)
            .OrderBy(session => session.Date)
            .FirstOrDefault();
    }

    private string GetVdotValue()
    {
        return Athlete?.Vdot > 0 ? Athlete.Vdot.ToString("0.0") : L["Metric_NotAvailable"];
    }

    private string GetReferenceDetail()
    {
        return _referenceResult is null
            ? L["Metric_ReferenceMissing"]
            : string.Format(L["Metric_ReferenceDate"], _referenceResult.Date);
    }

    private string GetNextSessionValue()
    {
        return _nextSession?.Date.ToString("dd.MM.") ?? L["Metric_NotAvailable"];
    }

    private string GetNextSessionDetail()
    {
        return _nextSession?.Name ?? L["Metric_NoSession"];
    }

    private string GetSessionComposition(TrainingSession session)
    {
        var parts = new List<string>();

        if (session.Runs.Count > 0)
            parts.Add(string.Format(L["SessionRuns"], session.Runs.Count));

        if (session.Workouts.Count > 0)
            parts.Add(string.Format(L["SessionWorkouts"], session.Workouts.Count));

        return parts.Count == 0 ? L["SessionEmpty"] : string.Join(" / ", parts);
    }

}
