@page "/"
@page "/Athletes/dashboard"
@using AthleteDataAccessLibrary;
@using AthleteDataAccessLibrary.Contracts;

@using MudBlazor;
@using PaceLetics.AthleteModule.CodeBase.Models;
@using PaceLetics.CoreModule.Infrastructure.Interfaces
@using PaceLetics.CoreModule.Infrastructure.Models
@using PaceLetics.CoreModule.Infrastructure.Services
@using PaceLetics.TrainingPlanModule.CodeBase.Models
@using PaceLetics.Web.Services
@using PaceLetics.Web.Services.Calendar

@inject IAthleteData AthleteData
@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IStringLocalizer<Dashboard> L
@inject LoadingStateService Loading
@inject ITrainingPlanService TrainingPlanService
@inject ICriticalSpeedService CriticalSpeedService
@inject ITrainingCalendarService CalendarService
@inject IAchievementService AchievementService
@inject NavigationManager Navigation

<PageTitle>@GetDocumentTitle()</PageTitle>


<MudContainer Class="pl-section-page px-4 px-sm-6 pb-8 pl-dashboard-page" MaxWidth="MaxWidth.Large">
    <PageHeader Title="@GetHeaderTitle()" Subtitle="@GetHeaderSubtitle()" />

    <nav class="pl-section-nav" aria-label="@L["Title"]">
        <button type="button"
                class="@GetSectionButtonClass(DashboardSection.Overview)"
                aria-pressed="@(_activeSection == DashboardSection.Overview)"
                @onclick="@(() => SelectSection(DashboardSection.Overview))">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" />
            <span>Uebersicht</span>
        </button>
        <button type="button"
                class="@GetSectionButtonClass(DashboardSection.Achievements)"
                aria-pressed="@(_activeSection == DashboardSection.Achievements)"
                @onclick="@(() => SelectSection(DashboardSection.Achievements))">
            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Small" />
            <span>Achievements</span>
        </button>
    </nav>

    <MudDivider Class="my-4" />

    @if (_activeSection == DashboardSection.Overview)
    {
        <MudStack Spacing="4">

            <MudGrid Spacing="3" Class="pl-dashboard-metrics">
                <MudItem xs="12">
                    <DashboardMetricTile Label="@L["Metric_TrainingCalendar"]"
                                         Value="@GetCalendarValue()"
                                         Detail="@GetCalendarDetail()"
                                         Icon="@Icons.Material.Filled.CalendarMonth"
                                         Accent="blue"
                                         Href="/Athletes/trainingcalendar"
                                         Tooltip="@L["Tooltip_TrainingCalendar"]">
                        <div class="pl-dashboard-calendar-days">
                            @foreach (var day in CalendarPreviewDays)
                            {
                                var items = GetCalendarItemsForDay(day).Take(3).ToList();
                                <div class="@GetCalendarPreviewDayClass(day, items.Count > 0)">
                                    <span class="pl-dashboard-calendar-weekday">@day.ToString("ddd")</span>
                                    <span class="pl-dashboard-calendar-date">@day.Day</span>
                                    <span class="pl-dashboard-calendar-dots" aria-hidden="true">
                                        @foreach (var item in items)
                                        {
                                            <span class="@GetCalendarDotClass(item)"></span>
                                        }
                                    </span>
                                </div>
                            }
                        </div>
                    </DashboardMetricTile>
                </MudItem>

                <MudItem xs="12">
                    <DashboardMetricTile Label="@L["Metric_NextSession"]"
                                         Value="@GetNextSessionValue()"
                                         Detail="@GetNextSessionDetail()"
                                         Icon="@Icons.Material.Filled.EventAvailable"
                                         Accent="green"
                                         Href="/Athletes/courses?section=plans"
                                         Tooltip="@L["Tooltip_NextSession"]">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pl-dashboard-session-preview">
                            <MudIcon Icon="@Icons.Material.Filled.Timeline"
                                     Color="Color.Primary" />

                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">
                                    @( _nextSession?.Name ?? L["Metric_NoSession"] )
                                </MudText>
                                <MudText Typo="Typo.body2" Class="pl-dashboard-muted">
                                    @( _nextSession is null ? L["Metric_NoSession"] : $"{_nextSession.Date:dd.MM.yyyy} / {GetSessionComposition(_nextSession)}" )
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </DashboardMetricTile>
                </MudItem>

                <MudItem xs="12">
                    <DashboardMetricTile Label="Achievements"
                                         Value="@GetAchievementValue()"
                                         Detail="Freigeschaltete Auszeichnungen"
                                         Icon="@Icons.Material.Filled.EmojiEvents"
                                         Accent="orange"
                                         Href="/Athletes/dashboard?section=achievements"
                                         Tooltip="Deine Achievements ansehen" />
                </MudItem>

                <MudItem xs="12">
                    <DashboardMetricTile Label="@L["Metric_Academy"]"
                                         Value="@L["Metric_AcademyValue"]"
                                         Detail="@L["Metric_AcademyDetail"]"
                                         Icon="@Icons.Material.Filled.AutoStories"
                                         Accent="orange"
                                         Href="/Athletes/academy"
                                         Tooltip="@L["Tooltip_Academy"]" />
                </MudItem>

                <MudItem xs="12">
                    <DashboardMetricTile Label="@L["Metric_WorkoutArea"]"
                                         Value="@L["Metric_WorkoutAreaValue"]"
                                         Detail="@L["Metric_WorkoutAreaDetail"]"
                                         Icon="@Icons.Material.Filled.FitnessCenter"
                                         Accent="red"
                                         Href="/Workouts/WorkoutArea"
                                         Tooltip="@L["Tooltip_WorkoutArea"]" />
                </MudItem>

                <MudItem xs="12">
                    <DashboardMetricTile Label="@L["Metric_VdotCs"]"
                                         Value="@GetCriticalSpeedValue()"
                                         Detail="@GetReferenceDetail()"
                                         Icon="@Icons.Material.Filled.Speed"
                                         Accent="blue"
                                         Href="/Athletes/pacezones"
                                         Tooltip="@L["Tooltip_VdotCs"]" />
                </MudItem>
            </MudGrid>
        </MudStack>
    }
    else
    {
        <AchievementGallery />
    }

</MudContainer>

@code
{
    private enum DashboardSection
    {
        Overview,
        Achievements
    }

    [SupplyParameterFromQuery(Name = "section")]
    public string? SectionQuery { get; set; }

    AthleteModel? Athlete;
    string _name = String.Empty;
    IReadOnlyList<TrainingPlan> _trainingPlans = Array.Empty<TrainingPlan>();
    IReadOnlyList<TrainingCalendarItem> _calendarItems = Array.Empty<TrainingCalendarItem>();
    int _achievementCount;
    TrainingPlan? _activePlan;
    TrainingSession? _nextSession;
    RaceResultModel? _referenceResult;
    CriticalSpeedModel _criticalSpeed = new();
    private DashboardSection _activeSection = DashboardSection.Overview;
    private string? _appliedSectionQuery;

    protected override void OnParametersSet()
    {
        if (string.Equals(_appliedSectionQuery, SectionQuery, StringComparison.OrdinalIgnoreCase))
            return;

        _appliedSectionQuery = SectionQuery;
        _activeSection = ParseSectionQuery(SectionQuery);
    }

    protected override async Task OnInitializedAsync()
    {
        await Loading.RunAsync(L["Loading"], async () =>
        {
            var authstate = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
            var user = authstate.User;
            var id = user.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value;
            Athlete = string.IsNullOrWhiteSpace(id)
                ? null
                : await AthleteData.GetAthlete(id);
            _name = string.IsNullOrWhiteSpace(Athlete?.Name)
                ? user.Identity?.Name ?? string.Empty
                : Athlete.Name;
            try
            {
                _trainingPlans = await TrainingPlanService.LoadTrainingPlansForUserAsync(id);
            }
            catch
            {
                _trainingPlans = Array.Empty<TrainingPlan>();
            }
            try
            {
                _calendarItems = string.IsNullOrWhiteSpace(id)
                    ? Array.Empty<TrainingCalendarItem>()
                    : await CalendarService.GetCalendarItemsForAthleteAsync(id);
            }
            catch
            {
                _calendarItems = Array.Empty<TrainingCalendarItem>();
            }
            try
            {
                _achievementCount = string.IsNullOrWhiteSpace(id)
                    ? 0
                    : (await AchievementService.GetAwardsForAthleteAsync(id)).Count;
            }
            catch
            {
                _achievementCount = 0;
            }
            _activePlan = ResolveActivePlan(_trainingPlans, Athlete);
            _nextSession = ResolveNextSession(_activePlan, _trainingPlans);
            _referenceResult = Athlete?.ActiveReferenceResult;
            _criticalSpeed = CriticalSpeedService.Estimate(GetCriticalSpeedResults(Athlete));
        });

        await base.OnInitializedAsync();
    }

    private void SelectSection(DashboardSection section)
    {
        _activeSection = section;
        Navigation.NavigateTo(GetSectionUri(section), replace: true);
    }

    private string GetSectionButtonClass(DashboardSection section)
    {
        return _activeSection == section
            ? "pl-section-nav__item pl-section-nav__item--active"
            : "pl-section-nav__item";
    }

    private string GetDocumentTitle()
    {
        return _activeSection == DashboardSection.Achievements
            ? "Achievements"
            : L["PageTitle"].Value;
    }

    private string GetHeaderTitle()
    {
        return _activeSection == DashboardSection.Achievements
            ? "Achievements"
            : L["Title"].Value;
    }

    private string GetHeaderSubtitle()
    {
        return _activeSection == DashboardSection.Achievements
            ? "Deine dauerhaft freigeschalteten Auszeichnungen."
            : L["WelcomeText", _name].Value;
    }

    private static DashboardSection ParseSectionQuery(string? section)
    {
        return section?.Trim().ToLowerInvariant() switch
        {
            "achievements" or "awards" => DashboardSection.Achievements,
            _ => DashboardSection.Overview
        };
    }

    private static string GetSectionUri(DashboardSection section)
    {
        return section switch
        {
            DashboardSection.Achievements => "/Athletes/dashboard?section=achievements",
            _ => "/Athletes/dashboard"
        };
    }

    private static TrainingPlan? ResolveActivePlan(IReadOnlyList<TrainingPlan> trainingPlans, AthleteModel? athlete)
    {
        if (trainingPlans.Count == 0)
            return null;

        if (!string.IsNullOrWhiteSpace(athlete?.SelectedTrainingPlanId))
        {
            var selected = trainingPlans.FirstOrDefault(plan => plan.Id == athlete.SelectedTrainingPlanId);
            if (selected is not null)
                return selected;
        }

        return trainingPlans.FirstOrDefault(plan => plan.Sessions.Any(session => session.Date.Date >= DateTime.Today))
            ?? trainingPlans.FirstOrDefault();
    }

    private static TrainingSession? ResolveNextSession(TrainingPlan? activePlan, IReadOnlyList<TrainingPlan> trainingPlans)
    {
        if (activePlan is not null)
        {
            var selectedNext = activePlan.Sessions
                .Where(session => session.Date.Date >= DateTime.Today)
                .OrderBy(session => session.Date)
                .FirstOrDefault();

            if (selectedNext is not null)
                return selectedNext;
        }

        return trainingPlans
            .SelectMany(plan => plan.Sessions)
            .Where(session => session.Date.Date >= DateTime.Today)
            .OrderBy(session => session.Date)
            .FirstOrDefault();
    }

    private string GetCriticalSpeedValue()
    {
        return _criticalSpeed.IsValid
            ? $"{_criticalSpeed.CriticalSpeedMps:0.00} m/s"
            : L["Metric_NotAvailable"].Value;
    }

    private static IEnumerable<RaceResultModel> GetCriticalSpeedResults(AthleteModel? athlete)
    {
        if (athlete?.ActiveReferenceResult is null)
            return Enumerable.Empty<RaceResultModel>();

        var results = new List<RaceResultModel>();

        if (athlete.RaceResults is not null)
            results.AddRange(athlete.RaceResults);

        if (athlete.ActiveReferenceResult is not null && !results.Any(result => IsSameRaceResult(result, athlete.ActiveReferenceResult)))
            results.Add(athlete.ActiveReferenceResult);

        return results;
    }

    private static bool IsSameRaceResult(RaceResultModel left, RaceResultModel right)
    {
        return left.DistanceM == right.DistanceM
            && left.Time == right.Time
            && left.Date.Date == right.Date.Date
            && string.Equals(left.Id, right.Id, StringComparison.OrdinalIgnoreCase);
    }

    private string GetReferenceDetail()
    {
        return _referenceResult is null
            ? L["Metric_ReferenceMissing"]
            : string.Format(L["Metric_ReferenceDate"], _referenceResult.Date);
    }

    private string GetNextSessionValue()
    {
        return _nextSession?.Date.ToString("dd.MM.") ?? L["Metric_NotAvailable"];
    }

    private string GetNextSessionDetail()
    {
        return _nextSession is null
            ? L["Metric_NoSession"]
            : GetSessionComposition(_nextSession);
    }

    private string GetCalendarValue()
    {
        var upcomingCount = UpcomingCalendarItems.Count;
        return upcomingCount == 0
            ? L["Metric_NotAvailable"]
            : string.Format(L["CalendarUpcomingCount"], upcomingCount);
    }

    private string GetCalendarDetail()
    {
        var nextItem = UpcomingCalendarItems.FirstOrDefault();
        return nextItem is null
            ? L["CalendarNoUpcoming"]
            : $"{nextItem.StartsAt:dd.MM.} / {nextItem.Title}";
    }

    private string GetAchievementValue()
    {
        return _achievementCount == 0 ? "Noch keine" : _achievementCount.ToString();
    }

    private IReadOnlyList<TrainingCalendarItem> UpcomingCalendarItems => _calendarItems
        .Where(item => item.StartsAt.Date >= DateTime.Today)
        .OrderBy(item => item.StartsAt)
        .ThenBy(item => item.Kind)
        .ThenBy(item => item.Title)
        .Take(5)
        .ToList();

    private IEnumerable<DateTime> CalendarPreviewDays
    {
        get
        {
            for (var i = 0; i < 7; i++)
                yield return DateTime.Today.AddDays(i);
        }
    }

    private IEnumerable<TrainingCalendarItem> GetCalendarItemsForDay(DateTime day)
    {
        return _calendarItems
            .Where(item => item.StartsAt.Date == day.Date)
            .OrderBy(item => item.StartsAt)
            .ThenBy(item => item.Kind)
            .ThenBy(item => item.Title);
    }

    private static string GetCalendarPreviewDayClass(DateTime day, bool hasItems)
    {
        var classes = new List<string> { "pl-dashboard-calendar-day" };
        if (day.Date == DateTime.Today)
            classes.Add("pl-dashboard-calendar-day-today");
        if (hasItems)
            classes.Add("pl-dashboard-calendar-day-active");
        return string.Join(" ", classes);
    }

    private static string GetCalendarDotClass(TrainingCalendarItem item)
    {
        return item.Kind switch
        {
            TrainingCalendarItemKinds.TrainingSession => "pl-dashboard-calendar-dot pl-calendar-kind-training",
            TrainingCalendarItemKinds.CourseDate => "pl-dashboard-calendar-dot pl-calendar-kind-course-date",
            TrainingCalendarItemKinds.CourseEvent => "pl-dashboard-calendar-dot pl-calendar-kind-event",
            _ => "pl-dashboard-calendar-dot"
        };
    }

    private string GetSessionComposition(TrainingSession session)
    {
        var parts = new List<string>();

        if (session.Runs.Count > 0)
            parts.Add(string.Format(L["SessionRuns"], session.Runs.Count));

        if (session.Workouts.Count > 0)
            parts.Add(string.Format(L["SessionWorkouts"], session.Workouts.Count));

        return parts.Count == 0 ? L["SessionEmpty"] : string.Join(" / ", parts);
    }

}
