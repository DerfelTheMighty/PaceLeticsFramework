@page "/Athletes/more"
@attribute [Authorize]
@inject IStringLocalizer<More> L

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pl-section-page px-4 px-sm-6 pb-8" MaxWidth="MaxWidth.Small">
    <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />
    <nav class="pl-more-list pt-3" aria-label="@L["Title"]">
        @foreach (var item in Items)
        {
            <a class="pl-more-list__item" href="@item.Href">
                <span>
                    <strong>@item.Title</strong>
                    <small>@item.Detail</small>
                </span>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
            </a>
        }
    </nav>
</MudContainer>

@code {
    private IReadOnlyList<MoreItem> Items =>
    [
        new(L["Courses"], L["CoursesDetail"], "/Athletes/courses"),
        new(L["Teams"], L["TeamsDetail"], "/Athletes/teams"),
        new(L["Academy"], L["AcademyDetail"], "/Athletes/academy"),
        new(L["Achievements"], L["AchievementsDetail"], "/Athletes/achievements"),
        new(L["Integrations"], L["IntegrationsDetail"], "/Athletes/integrations"),
        new(L["Settings"], L["SettingsDetail"], "/Athletes/settings"),
        new(L["About"], L["AboutDetail"], "/impressum")
    ];

    private sealed record MoreItem(string Title, string Detail, string Href);
}
