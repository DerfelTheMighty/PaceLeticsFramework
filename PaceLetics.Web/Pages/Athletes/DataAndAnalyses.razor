@page "/Athletes/data-analyses"
@attribute [Authorize]
@using System.Security.Claims
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Interfaces
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Models
@using PaceLetics.RunningAnalysisModule.Components
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IRunningAnalysisService RunningAnalysisService
@inject ITrainingFeedbackService FeedbackService
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LoadingStateService Loading
@inject IStringLocalizer<DataAndAnalyses> L
@inject NavigationManager Navigation

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pl-section-page px-6 pb-8" MaxWidth="MaxWidth.Small">
    <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

    <SectionNav Items="@SectionItems"
                ActiveKey="@GetSectionKey(_activeSection)"
                OnSelect="SelectSectionByKey"
                AriaLabel="@L["Title"]" />

    <SwipeSection OnSwipeLeft="SelectNextSection" OnSwipeRight="SelectPreviousSection">
        @if (_activeSection == DataAnalysesSection.Development)
        {
            <MudDivider Class="my-4" />
            <RacePaces Embedded="true" EmbeddedSection="racedata" />
        }
        else if (_activeSection == DataAnalysesSection.Load)
        {
            <section class="pl-data-load mt-4" aria-labelledby="load-title">
                <MudText Typo="Typo.h6" HtmlTag="h2" id="load-title">@L["LoadTitle"]</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["LoadSubtitle"]</MudText>

                @if (!string.IsNullOrWhiteSpace(_feedbackErrorMessage))
                {
                    <RetryAlert Message="@_feedbackErrorMessage" OnRetry="LoadAsync" />
                }
                else if (_feedback.Count == 0)
                {
                    <ActionableEmptyState Title="@L["NoLoadTitle"]"
                                          Detail="@L["NoLoadDetail"]"
                                          ActionText="@L["OpenPlan"]"
                                          Href="/Athletes/plan" />
                }
                else
                {
                    <div class="pl-data-load__summary">
                        <div><small>@L["Sessions7Days"]</small><strong>@CurrentWeekFeedback.Count</strong></div>
                        <div><small>@L["LoadPoints"]</small><strong>@CurrentWeekFeedback.Sum(item => item.Effort)</strong></div>
                        <div><small>@L["AverageEffort"]</small><strong>@GetAverageEffort()</strong></div>
                    </div>
                    <MudText Typo="Typo.body2" Class="@GetLoadTrendClass()">@GetLoadTrendText()</MudText>
                    <div class="pl-data-load__history">
                        @foreach (var item in _feedback.Take(5))
                        {
                            <div class="pl-list-row">
                                <span><strong>@item.TrainingName</strong><small>@item.CompletedAt.ToLocalTime().ToString("dd.MM. · HH:mm")</small></span>
                                <span class="pl-effort-value">@item.Effort/10</span>
                            </div>
                        }
                    </div>
                }
            </section>
        }
        else if (_activeSection == DataAnalysesSection.PaceZones)
        {
            <MudDivider Class="my-4" />
            <RacePaces Embedded="true" EmbeddedSection="pacezones" />
        }
        else if (_activeSection == DataAnalysesSection.RunningForm)
        {
            <section class="pt-4" aria-labelledby="running-form-title">
                <MudStack Spacing="3">
                    <div>
                            <MudText Typo="Typo.h6" HtmlTag="h2" id="running-form-title">@L["RunningAnalysesTitle"]</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["RunningAnalysesSubtitle"]</MudText>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <RetryAlert Message="@_errorMessage" OnRetry="LoadAsync" />
                    }
                    else
                    {
                        <RunningAnalysisLinks Items="_analyses"
                                              EmptyText="@L["NoRunningAnalyses"]"
                                              RecordingText="@L["Recording"]"
                                              EvaluationText="@L["Evaluation"]"
                                              NoRecordingText="@L["NoRecording"]"
                                              NoResultText="@L["NoResult"]"
                                              OpenSideRecordingText="@L["OpenSideRecording"]"
                                              OpenRearRecordingText="@L["OpenRearRecording"]"
                                              OpenResultText="@L["OpenResult"]"
                                              StatusStartedText="@L["StatusStarted"]"
                                              StatusInProgressText="@L["StatusInProgress"]"
                                              StatusFinishedText="@L["StatusFinished"]"
                                              DeleteText="@L["RemoveAnalysis"]"
                                              OnDelete="RemoveAnalysisAsync" />
                    }
                </MudStack>
            </section>
        }
    </SwipeSection>
</MudContainer>

@code {
    private static readonly DataAnalysesSection[] Sections =
    [
        DataAnalysesSection.Development,
        DataAnalysesSection.Load,
        DataAnalysesSection.PaceZones,
        DataAnalysesSection.RunningForm
    ];

    private enum DataAnalysesSection
    {
        Development,
        Load,
        PaceZones,
        RunningForm
    }

    private string? _userId;
    private string? _errorMessage;
    private string? _feedbackErrorMessage;
    private IReadOnlyList<RunningAnalysisLink> _analyses = Array.Empty<RunningAnalysisLink>();
    private IReadOnlyList<TrainingFeedbackDocument> _feedback = Array.Empty<TrainingFeedbackDocument>();
    private DataAnalysesSection _activeSection = DataAnalysesSection.Development;

    private IReadOnlyList<SectionNavEntry> SectionItems =>
    [
        new("development", L["TabDevelopment"]),
        new("load", L["TabLoad"]),
        new("pacezones", L["TabPaceZones"]),
        new("running-form", L["TabRunningForm"])
    ];

    private IReadOnlyList<TrainingFeedbackDocument> CurrentWeekFeedback => _feedback
        .Where(item => item.CompletedAt >= DateTime.UtcNow.AddDays(-7))
        .ToList();

    [Parameter]
    [SupplyParameterFromQuery(Name = "section")]
    public string? Section { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override void OnParametersSet()
    {
        if (TryParseSection(Section, out var section))
            _activeSection = section;
    }

    private async Task LoadAsync()
    {
        await Loading.RunAsync(L["Loading"], async () =>
        {
            try
            {
                _errorMessage = null;
                _feedbackErrorMessage = null;
                _analyses = Array.Empty<RunningAnalysisLink>();

                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                    ?? authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier", StringComparison.OrdinalIgnoreCase))?.Value;

                if (string.IsNullOrWhiteSpace(_userId))
                    throw new InvalidOperationException(L["AthleteNotResolved"]);

                await LoadAnalysesAsync();
                try
                {
                    _feedback = await FeedbackService.GetRecentAsync(_userId, 28);
                }
                catch (Exception ex)
                {
                    _feedback = Array.Empty<TrainingFeedbackDocument>();
                    _feedbackErrorMessage = UiErrorMessages.From(ex);
                }
            }
            catch (Exception ex)
            {
                _errorMessage = UiErrorMessages.From(ex);
                _analyses = Array.Empty<RunningAnalysisLink>();
                _feedback = Array.Empty<TrainingFeedbackDocument>();
            }
        });
    }

    private async Task LoadAnalysesAsync()
    {
        if (string.IsNullOrWhiteSpace(_userId))
            return;

        _analyses = await RunningAnalysisService.GetAnalysesForAthleteAsync(_userId);
    }

    private void SelectSection(DataAnalysesSection section)
    {
        _activeSection = section;
        Navigation.NavigateTo(GetSectionUri(section), replace: true);
    }

    private void SelectNextSection()
    {
        SelectSection(GetAdjacentSection(1));
    }

    private void SelectPreviousSection()
    {
        SelectSection(GetAdjacentSection(-1));
    }

    private DataAnalysesSection GetAdjacentSection(int offset)
    {
        var index = Array.IndexOf(Sections, _activeSection);
        if (index < 0)
            return Sections[0];

        var nextIndex = Math.Clamp(index + offset, 0, Sections.Length - 1);
        return Sections[nextIndex];
    }

    private static bool TryParseSection(string? value, out DataAnalysesSection section)
    {
        section = DataAnalysesSection.Development;

        if (string.IsNullOrWhiteSpace(value))
            return false;

        var normalized = value.Trim().ToLowerInvariant();
        section = normalized switch
        {
            "development" or "entwicklung" or "running-data" or "racedata" or "laufdaten" => DataAnalysesSection.Development,
            "load" or "belastung" => DataAnalysesSection.Load,
            "pace-zones" or "pacezones" or "pacebereiche" => DataAnalysesSection.PaceZones,
            "running-form" or "lauftechnik" or "recordings" or "aufnahmen" => DataAnalysesSection.RunningForm,
            "analyses" or "analysis" or "analysen" => DataAnalysesSection.RunningForm,
            _ => DataAnalysesSection.Development
        };

        return normalized is "development"
            or "entwicklung"
            or "running-data"
            or "racedata"
            or "laufdaten"
            or "load"
            or "belastung"
            or "pace-zones"
            or "pacezones"
            or "pacebereiche"
            or "running-form"
            or "lauftechnik"
            or "recordings"
            or "aufnahmen"
            or "analyses"
            or "analysis"
            or "analysen";
    }

    private static string GetSectionUri(DataAnalysesSection section)
    {
        return section switch
        {
            DataAnalysesSection.Load => "/Athletes/data-analyses?section=load",
            DataAnalysesSection.PaceZones => "/Athletes/data-analyses?section=pacezones",
            DataAnalysesSection.RunningForm => "/Athletes/data-analyses?section=running-form",
            _ => "/Athletes/data-analyses"
        };
    }

    private static string GetSectionKey(DataAnalysesSection section) => section switch
    {
        DataAnalysesSection.Load => "load",
        DataAnalysesSection.PaceZones => "pacezones",
        DataAnalysesSection.RunningForm => "running-form",
        _ => "development"
    };

    private void SelectSectionByKey(string key)
    {
        if (TryParseSection(key, out var section)) SelectSection(section);
    }

    private string GetAverageEffort() => CurrentWeekFeedback.Count == 0
        ? "–"
        : CurrentWeekFeedback.Average(item => item.Effort).ToString("0.0");

    private int PreviousWeekLoad => _feedback
        .Where(item => item.CompletedAt < DateTime.UtcNow.AddDays(-7) && item.CompletedAt >= DateTime.UtcNow.AddDays(-14))
        .Sum(item => item.Effort);

    private string GetLoadTrendText()
    {
        var current = CurrentWeekFeedback.Sum(item => item.Effort);
        if (PreviousWeekLoad == 0) return L["LoadTrendNoComparison"];
        var change = (current - PreviousWeekLoad) * 100 / PreviousWeekLoad;
        return L["LoadTrend", change];
    }

    private string GetLoadTrendClass()
    {
        var current = CurrentWeekFeedback.Sum(item => item.Effort);
        return PreviousWeekLoad > 0 && current > PreviousWeekLoad * 1.35
            ? "pl-status-warning"
            : "pl-status-positive";
    }

    private async Task RemoveAnalysisAsync(RunningAnalysisLink analysis)
    {
        if (string.IsNullOrWhiteSpace(_userId))
            return;

        var confirmed = await UiConfirmation.AskAsync(
            DialogService,
            string.Format(L["RemoveAnalysisConfirm"], analysis.Title));
        if (!confirmed)
            return;

        try
        {
            await RunningAnalysisService.DeleteAnalysisForAthleteAsync(_userId, analysis.AnalysisEventId);
            _analyses = _analyses
                .Where(existing => existing.AnalysisEventId != analysis.AnalysisEventId)
                .ToList();
            Snackbar.Add(L["RemoveAnalysisSuccess"], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
    }
}
