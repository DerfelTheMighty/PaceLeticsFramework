@page "/Athletes/data-analyses"
@attribute [Authorize]
@using System.Security.Claims
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Interfaces
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Models
@using PaceLetics.RunningAnalysisModule.Components
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IRunningAnalysisService RunningAnalysisService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject LoadingStateService Loading
@inject IStringLocalizer<DataAndAnalyses> L
@inject NavigationManager Navigation

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pl-section-page px-6 pb-8" MaxWidth="MaxWidth.Small">
    <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

    <nav class="pl-section-nav" aria-label="@L["Title"]">
        <button type="button"
                class="@GetSectionButtonClass(DataAnalysesSection.RunningData)"
                aria-pressed="@(_activeSection == DataAnalysesSection.RunningData)"
                @onclick="@(() => SelectSection(DataAnalysesSection.RunningData))">
            <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" />
            <span>@L["TabRunningData"]</span>
        </button>
        <button type="button"
                class="@GetSectionButtonClass(DataAnalysesSection.PaceZones)"
                aria-pressed="@(_activeSection == DataAnalysesSection.PaceZones)"
                @onclick="@(() => SelectSection(DataAnalysesSection.PaceZones))">
            <MudIcon Icon="@Icons.Material.Filled.QueryStats" Size="Size.Small" />
            <span>@L["TabPaceZones"]</span>
        </button>
        <button type="button"
                class="@GetSectionButtonClass(DataAnalysesSection.Analyses)"
                aria-pressed="@(_activeSection == DataAnalysesSection.Analyses)"
                @onclick="@(() => SelectSection(DataAnalysesSection.Analyses))">
            <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" />
            <span>@L["TabAnalyses"]</span>
        </button>
    </nav>

    <SwipeSection OnSwipeLeft="SelectNextSection" OnSwipeRight="SelectPreviousSection">
        @if (_activeSection == DataAnalysesSection.RunningData)
        {
            <MudDivider Class="my-4" />
            <RacePaces Embedded="true" EmbeddedSection="racedata" />
        }
        else if (_activeSection == DataAnalysesSection.PaceZones)
        {
            <MudDivider Class="my-4" />
            <RacePaces Embedded="true" EmbeddedSection="pacezones" />
        }
        else if (_activeSection == DataAnalysesSection.Analyses)
        {
            <MudPaper Elevation="0" Class="pa-4 pl-course-detail mt-4">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="gap:12px;">
                    <MudIcon Icon="@Icons.Material.Filled.Assessment" Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.subtitle2">@L["CompletedAnalysesTitle"]</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["CompletedAnalysesSubtitle"]</MudText>
                    </div>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_errorMessage</MudAlert>
                }
                else
                {
                    <AthleteAnalysisOverview Items="_analyses" OnDelete="RemoveAnalysisAsync" />
                }
            </MudStack>
            </MudPaper>

            <MudPaper Elevation="0" Class="pa-4 pl-course-detail mt-4">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="gap:12px;">
                        <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Color="Color.Primary" />
                        <div>
                            <MudText Typo="Typo.subtitle2">@L["RecordingsTitle"]</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["RecordingsSubtitle"]</MudText>
                        </div>
                    </MudStack>

                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_errorMessage</MudAlert>
                    }
                    else
                    {
                        <RunningAnalysisLinks Items="_analyses"
                                              EmptyText="@L["NoRecordings"]"
                                              OpenSideRecordingText="@L["OpenSideRecording"]"
                                              OpenRearRecordingText="@L["OpenRearRecording"]"
                                              DeleteText="@L["RemoveAnalysis"]"
                                              OnDelete="RemoveAnalysisAsync" />
                    }
                </MudStack>
            </MudPaper>
        }
    </SwipeSection>
</MudContainer>

@code {
    private static readonly DataAnalysesSection[] Sections =
    [
        DataAnalysesSection.RunningData,
        DataAnalysesSection.PaceZones,
        DataAnalysesSection.Analyses
    ];

    private enum DataAnalysesSection
    {
        RunningData,
        PaceZones,
        Analyses
    }

    private string? _userId;
    private string? _errorMessage;
    private IReadOnlyList<RunningAnalysisLink> _analyses = Array.Empty<RunningAnalysisLink>();
    private DataAnalysesSection _activeSection = DataAnalysesSection.RunningData;

    [Parameter]
    [SupplyParameterFromQuery(Name = "section")]
    public string? Section { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override void OnParametersSet()
    {
        if (TryParseSection(Section, out var section))
            _activeSection = section;
    }

    private async Task LoadAsync()
    {
        await Loading.RunAsync(L["Loading"], async () =>
        {
            try
            {
                _errorMessage = null;
                _analyses = Array.Empty<RunningAnalysisLink>();

                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                    ?? authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier", StringComparison.OrdinalIgnoreCase))?.Value;

                if (string.IsNullOrWhiteSpace(_userId))
                    throw new InvalidOperationException(L["AthleteNotResolved"]);

                await LoadAnalysesAsync();
            }
            catch (Exception ex)
            {
                _errorMessage = ex.Message;
                _analyses = Array.Empty<RunningAnalysisLink>();
            }
        });
    }

    private async Task LoadAnalysesAsync()
    {
        if (string.IsNullOrWhiteSpace(_userId))
            return;

        _analyses = await RunningAnalysisService.GetAnalysesForAthleteAsync(_userId);
    }

    private void SelectSection(DataAnalysesSection section)
    {
        _activeSection = section;
        Navigation.NavigateTo(GetSectionUri(section), replace: true);
    }

    private void SelectNextSection()
    {
        SelectSection(GetAdjacentSection(1));
    }

    private void SelectPreviousSection()
    {
        SelectSection(GetAdjacentSection(-1));
    }

    private DataAnalysesSection GetAdjacentSection(int offset)
    {
        var index = Array.IndexOf(Sections, _activeSection);
        if (index < 0)
            return Sections[0];

        var nextIndex = Math.Clamp(index + offset, 0, Sections.Length - 1);
        return Sections[nextIndex];
    }

    private static bool TryParseSection(string? value, out DataAnalysesSection section)
    {
        section = DataAnalysesSection.RunningData;

        if (string.IsNullOrWhiteSpace(value))
            return false;

        var normalized = value.Trim().ToLowerInvariant();
        section = normalized switch
        {
            "running-data" or "racedata" or "laufdaten" => DataAnalysesSection.RunningData,
            "pace-zones" or "pacezones" or "pacebereiche" => DataAnalysesSection.PaceZones,
            "recordings" or "aufnahmen" => DataAnalysesSection.Analyses,
            "analyses" or "analysis" or "analysen" => DataAnalysesSection.Analyses,
            _ => DataAnalysesSection.RunningData
        };

        return normalized is "running-data"
            or "racedata"
            or "laufdaten"
            or "pace-zones"
            or "pacezones"
            or "pacebereiche"
            or "recordings"
            or "aufnahmen"
            or "analyses"
            or "analysis"
            or "analysen";
    }

    private static string GetSectionUri(DataAnalysesSection section)
    {
        return section switch
        {
            DataAnalysesSection.PaceZones => "/Athletes/data-analyses?section=pacezones",
            DataAnalysesSection.Analyses => "/Athletes/data-analyses?section=analyses",
            _ => "/Athletes/data-analyses"
        };
    }

    private string GetSectionButtonClass(DataAnalysesSection section)
    {
        return _activeSection == section
            ? "pl-section-nav__item pl-section-nav__item--active"
            : "pl-section-nav__item";
    }

    private async Task RemoveAnalysisAsync(RunningAnalysisLink analysis)
    {
        if (string.IsNullOrWhiteSpace(_userId))
            return;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            string.Format(L["RemoveAnalysisConfirm"], analysis.Title));
        if (!confirmed)
            return;

        try
        {
            await RunningAnalysisService.DeleteAnalysisForAthleteAsync(_userId, analysis.AnalysisEventId);
            _analyses = _analyses
                .Where(existing => existing.AnalysisEventId != analysis.AnalysisEventId)
                .ToList();
            Snackbar.Add(L["RemoveAnalysisSuccess"], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
