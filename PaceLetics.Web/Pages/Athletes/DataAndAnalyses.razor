@page "/Athletes/data-analyses"
@attribute [Authorize]
@using System.Security.Claims
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Interfaces
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Models
@using PaceLetics.RunningAnalysisModule.CodeBase.RunningAnalysis.Storage
@using PaceLetics.RunningAnalysisModule.Components
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IRunningAnalysisService RunningAnalysisService
@inject IUserDriveFolderService UserDriveFolderService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject LoadingStateService Loading
@inject IStringLocalizer<DataAndAnalyses> L

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pl-section-page px-6 pb-8" MaxWidth="MaxWidth.Small">
    <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

    <nav class="pl-section-nav" aria-label="@L["Title"]">
        <button type="button"
                class="@GetSectionButtonClass(DataAnalysesSection.Recordings)"
                aria-pressed="@(_activeSection == DataAnalysesSection.Recordings)"
                @onclick="@(() => SelectSection(DataAnalysesSection.Recordings))">
            <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Size="Size.Small" />
            <span>@L["TabRecordings"]</span>
        </button>
        <button type="button"
                class="@GetSectionButtonClass(DataAnalysesSection.Analyses)"
                aria-pressed="@(_activeSection == DataAnalysesSection.Analyses)"
                @onclick="@(() => SelectSection(DataAnalysesSection.Analyses))">
            <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" />
            <span>@L["TabAnalyses"]</span>
        </button>
        <button type="button"
                class="@GetSectionButtonClass(DataAnalysesSection.Info)"
                aria-pressed="@(_activeSection == DataAnalysesSection.Info)"
                @onclick="@(() => SelectSection(DataAnalysesSection.Info))">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
            <span>@L["TabInfo"]</span>
        </button>
    </nav>

    @if (_activeSection == DataAnalysesSection.Recordings)
    {
        <MudPaper Elevation="0" Class="pa-4 pl-panel mt-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap:12px; flex-wrap:wrap;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="gap:12px; min-width:0; flex:1 1 260px;">
                    <MudIcon Icon="@GetDriveIcon()" Color="@GetDriveIconColor()" />
                    <div style="min-width:0;">
                        <MudText Typo="Typo.subtitle2">@L["DriveTitle"]</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@GetDriveDescription()</MudText>
                        @if (_folder is not null)
                        {
                            <MudLink Href="@_folder.Url" Target="_blank" Typo="Typo.caption">@L["OpenFolder"]</MudLink>
                        }
                    </div>
                </MudStack>

                @if (_folder is null)
                {
                    <MudTooltip Text="@L["CreateFolder"]">
                        <MudIconButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Icon="@Icons.Material.Filled.CreateNewFolder"
                                       Disabled="_isBusy || string.IsNullOrWhiteSpace(_userId)"
                                       OnClick="CreateFolderAsync"
                                       aria-label="@L["CreateFolder"]" />
                    </MudTooltip>
                }
                else
                {
                    <MudStack Row="true" Style="gap:8px; flex-wrap:wrap;">
                        <MudTooltip Text="@L["OpenFolder"]">
                            <MudIconButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Icon="@Icons.Material.Filled.OpenInNew"
                                           Disabled="_isBusy"
                                           OnClick="OpenFolderAsync"
                                           aria-label="@L["OpenFolder"]" />
                        </MudTooltip>
                        <MudTooltip Text="@L["DeleteFolder"]">
                            <MudIconButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Icon="@Icons.Material.Filled.Delete"
                                           Disabled="_isBusy"
                                           OnClick="DeleteFolderAsync"
                                           aria-label="@L["DeleteFolder"]" />
                        </MudTooltip>
                    </MudStack>
                }
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-4 pl-course-detail mt-4">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="gap:12px;">
                    <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.subtitle2">@L["AnalysesTitle"]</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["AnalysesSubtitle"]</MudText>
                    </div>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_errorMessage</MudAlert>
                }
                else if (_folder is null)
                {
                    <MudAlert Severity="Severity.Info"
                              Variant="Variant.Outlined"
                              Icon="@Icons.Material.Filled.FolderOff">
                        @L["DriveRequiredForAnalyses"]
                    </MudAlert>
                }
                else
                {
                    <RunningAnalysisLinks Items="_analyses"
                                          EmptyText="@L["NoAnalyses"]"
                                          OpenText="@L["OpenFolder"]"
                                          DeleteText="@L["RemoveAnalysis"]"
                                          OnDelete="RemoveAnalysisAsync" />
                }
            </MudStack>
        </MudPaper>
    }
    else if (_activeSection == DataAnalysesSection.Analyses)
    {
        <MudPaper Elevation="0" Class="pa-4 pl-course-detail mt-4">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="gap:12px;">
                    <MudIcon Icon="@Icons.Material.Filled.Assessment" Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.subtitle2">@L["CompletedAnalysesTitle"]</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["CompletedAnalysesSubtitle"]</MudText>
                    </div>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_errorMessage</MudAlert>
                }
                else
                {
                    <AthleteAnalysisOverview Items="_analyses" OnDelete="RemoveAnalysisAsync" />
                }
            </MudStack>
        </MudPaper>
    }
    else
    {
        <RunningAnalysisInterventionGuidance />
        <AcademyArticleLinks />
    }
</MudContainer>

@code {
    private enum DataAnalysesSection
    {
        Recordings,
        Analyses,
        Info
    }

    private string? _userId;
    private string? _email;
    private string? _errorMessage;
    private DriveFolderReference? _folder;
    private IReadOnlyList<RunningAnalysisLink> _analyses = Array.Empty<RunningAnalysisLink>();
    private DataAnalysesSection _activeSection = DataAnalysesSection.Recordings;
    private bool _isBusy;

    [Parameter]
    [SupplyParameterFromQuery(Name = "section")]
    public string? Section { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override void OnParametersSet()
    {
        if (TryParseSection(Section, out var section))
            _activeSection = section;
    }

    private async Task LoadAsync()
    {
        await Loading.RunAsync(L["Loading"], async () =>
        {
            try
            {
                _errorMessage = null;
                _analyses = Array.Empty<RunningAnalysisLink>();

                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                    ?? authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier", StringComparison.OrdinalIgnoreCase))?.Value;
                _email = authState.User.FindFirst(ClaimTypes.Email)?.Value
                    ?? authState.User.FindFirst("email")?.Value
                    ?? authState.User.Identity?.Name;

                if (string.IsNullOrWhiteSpace(_userId))
                    throw new InvalidOperationException(L["AthleteNotResolved"]);

                _folder = await UserDriveFolderService.GetFolderAsync(_userId);
                await LoadAnalysesAsync();
            }
            catch (Exception ex)
            {
                _errorMessage = ex.Message;
                _folder = null;
                _analyses = Array.Empty<RunningAnalysisLink>();
            }
        });
    }

    private async Task LoadAnalysesAsync()
    {
        if (string.IsNullOrWhiteSpace(_userId))
            return;

        _analyses = await RunningAnalysisService.GetAnalysesForAthleteAsync(_userId);
    }

    private void SelectSection(DataAnalysesSection section)
    {
        _activeSection = section;
    }

    private static bool TryParseSection(string? value, out DataAnalysesSection section)
    {
        section = DataAnalysesSection.Recordings;

        if (string.IsNullOrWhiteSpace(value))
            return false;

        var normalized = value.Trim().ToLowerInvariant();
        section = normalized switch
        {
            "recordings" or "aufnahmen" => DataAnalysesSection.Recordings,
            "analyses" or "analysis" or "analysen" => DataAnalysesSection.Analyses,
            "info" or "infos" => DataAnalysesSection.Info,
            _ => DataAnalysesSection.Recordings
        };

        return normalized is "recordings"
            or "aufnahmen"
            or "analyses"
            or "analysis"
            or "analysen"
            or "info"
            or "infos";
    }

    private string GetSectionButtonClass(DataAnalysesSection section)
    {
        return _activeSection == section
            ? "pl-section-nav__item pl-section-nav__item--active"
            : "pl-section-nav__item";
    }

    private async Task CreateFolderAsync()
    {
        if (string.IsNullOrWhiteSpace(_userId))
            return;

        try
        {
            _isBusy = true;
            _folder = await UserDriveFolderService.CreateFolderAsync(
                new UserDriveFolderRequest(
                    _userId,
                    _email ?? string.Empty));
            await LoadAnalysesAsync();
            Snackbar.Add(L["CreateSuccess"], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteFolderAsync()
    {
        if (string.IsNullOrWhiteSpace(_userId))
            return;

        try
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", L["DeleteConfirm"].Value);
            if (!confirmed)
                return;

            _isBusy = true;
            await UserDriveFolderService.DeleteFolderAsync(_userId);
            _folder = null;
            await LoadAnalysesAsync();
            Snackbar.Add(L["DeleteSuccess"], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RemoveAnalysisAsync(RunningAnalysisLink analysis)
    {
        if (string.IsNullOrWhiteSpace(_userId))
            return;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            string.Format(L["RemoveAnalysisConfirm"], analysis.Title));
        if (!confirmed)
            return;

        try
        {
            await RunningAnalysisService.HideAnalysisForAthleteAsync(_userId, analysis.AnalysisEventId);
            _analyses = _analyses
                .Where(existing => existing.AnalysisEventId != analysis.AnalysisEventId)
                .ToList();
            Snackbar.Add(L["RemoveAnalysisSuccess"], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private Task OpenFolderAsync()
    {
        return _folder is null
            ? Task.CompletedTask
            : JS.InvokeVoidAsync("open", _folder.Url, "_blank").AsTask();
    }

    private string GetDriveIcon()
    {
        return _folder is null
            ? Icons.Material.Filled.FolderOff
            : Icons.Material.Filled.FolderOpen;
    }

    private Color GetDriveIconColor()
    {
        return _folder is null ? Color.Secondary : Color.Primary;
    }

    private string GetDriveDescription()
    {
        return _folder is null
            ? L["NoFolderText"]
            : L["FolderReadyText"];
    }
}
