@page "/Athletes/groups"
@attribute [Authorize]
@using PaceLetics.Web.Services.Courses
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IGroupService GroupService
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IStringLocalizer<MyGroups> L

@if (!Embedded)
{
    <PageTitle>@L["Title"]</PageTitle>
}

<MudContainer Class="@ContainerClass" MaxWidth="MaxWidth.Small">
    @if (!Embedded)
    {
        <PageHeader Title="@L["Title"]" Subtitle="@L["Subtitle"]" />

        <MudDivider Class="my-4" />
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <RetryAlert Message="@_errorMessage" OnRetry="LoadAsync" Class="mb-3" />
    }

    @if (_groups.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["NoGroups"]</MudText>
    }
    else
    {
        <MudStack Spacing="2">
            @foreach (var overview in _groups)
            {
                var group = overview.Group;
                <MudPaper Elevation="0" Class="pa-3 pl-group-card">
                    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Style="gap:12px;">
                        <MudStack Spacing="1" Style="min-width:0;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap:6px; flex-wrap:wrap;">
                                <MudText Typo="Typo.subtitle2">@group.Name</MudText>
                                @if (RequiresApproval(group))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                                        @L["Approval"]
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">@L["Open"]</MudChip>
                                }
                                @if (overview.IsJoined)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">@L["Joined"]</MudChip>
                                }
                                else if (overview.IsPending)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@L["Requested"]</MudChip>
                                }
                            </MudStack>
                            @if (!string.IsNullOrWhiteSpace(group.Description))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@group.Description</MudText>
                            }
                        </MudStack>

                        @if (overview.IsJoined)
                        {
                            <MudTooltip Text="@L["Leave"]">
                                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                                               Color="Color.Default"
                                               OnClick="@(() => LeaveGroupAsync(group))"
                                               aria-label="@L["Leave"]" />
                            </MudTooltip>
                        }
                        else if (overview.IsPending)
                        {
                            <MudTooltip Text="@L["Withdraw"]">
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Color="Color.Default"
                                               OnClick="@(() => LeaveGroupAsync(group))"
                                               aria-label="@L["Withdraw"]" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="@L["Join"]">
                                <MudIconButton Icon="@(RequiresApproval(group) ? Icons.Material.Filled.LockOpen : Icons.Material.Filled.HowToReg)"
                                               Color="Color.Primary"
                                               Variant="Variant.Filled"
                                               OnClick="@(() => JoinGroupAsync(group))"
                                               aria-label="@L["Join"]" />
                            </MudTooltip>
                        }
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>

<style>
    .pl-group-card {
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
    }
</style>

@code {
    [Parameter]
    public bool Embedded { get; set; }

    private string? _userId;
    private IReadOnlyList<GroupOverview> _groups = Array.Empty<GroupOverview>();
    private string? _errorMessage;

    private string ContainerClass => Embedded
        ? "pa-0"
        : "pt-6 px-6 pb-8";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier"))?.Value;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _errorMessage = null;
        try
        {
            _groups = await GroupService.GetGroupsForAthleteAsync(_userId ?? string.Empty);
        }
        catch (Exception ex)
        {
            _errorMessage = UiErrorMessages.From(ex);
        }
    }

    private async Task JoinGroupAsync(GroupDocument group)
    {
        try
        {
            var membership = await GroupService.JoinGroupAsync(group.Id, _userId ?? string.Empty);
            Snackbar.Add(IsPending(membership) ? L["JoinRequested"] : L["JoinSuccess"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
    }

    private async Task LeaveGroupAsync(GroupDocument group)
    {
        var confirmed = await UiConfirmation.AskAsync(DialogService, string.Format(L["LeaveConfirm"], group.Name), destructive: false);
        if (!confirmed)
            return;

        try
        {
            await GroupService.LeaveGroupAsync(group.Id, _userId ?? string.Empty);
            Snackbar.Add(L["LeaveSuccess"], Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(UiErrorMessages.From(ex), Severity.Error);
        }
    }

    private static bool RequiresApproval(GroupDocument group)
    {
        return string.Equals(group.JoinMode, GroupJoinModes.ApprovalRequired, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsPending(GroupMembershipDocument membership)
    {
        return string.Equals(membership.Status, GroupMembershipStatus.Pending, StringComparison.OrdinalIgnoreCase);
    }
}
