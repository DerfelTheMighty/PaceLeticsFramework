@page "/Workouts/SelectDifficulty"
@using MudBlazor
@using PaceLetics.WorkoutModule.CodeBase.Enums
@using System.ComponentModel.DataAnnotations
@inject SelectDifficultyViewModel ViewModel
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SelectDifficulty> L

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer Class="pt-6 px-6 pb-8" MaxWidth="MaxWidth.Medium">
    <MudPaper Class="p-6" Elevation="2">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h4">@L["Title"]</MudText>
                <MudButton Variant="Variant.Text" StartIcon="Icons.Material.Filled.ArrowBack" OnClick="@Back">@L["Back"]</MudButton>
            </MudStack>

            <MudDivider />

            @if (!ViewModel.Variants.Any())
            {
                <MudText>@L["NoVariants"]</MudText>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-2" Style="display:flex;align-items:center;justify-content:center;">
                            <MudImage Src="@ViewModel.PreviewImage" Alt="@Name" Style="width:100%;height:180px;object-fit:cover;border-radius:4px;" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudText Typo="Typo.h6">@Name</MudText>
                        <MudText Typo="Typo.body2" Style="opacity:.8">@ViewModel.PreviewDescription</MudText>

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudNumericField Label="@L["SetsPerExercise"]" @bind-Value="ViewModel.Sets" Min="1" Max="20" Style="width:150px" />
                            <MudNumericField Label="@L["Rounds"]" @bind-Value="ViewModel.Rounds" Min="1" Max="20" Style="width:150px" />
                        </MudStack>

                        <MudText Typo="Typo.subtitle1" Class="mt-4">@L["AvailableLevels"]</MudText>
                        <MudStack Spacing="2" Class="mt-2">
                            @foreach(var v in ViewModel.Variants)
                            {
                                var level = ViewModel.GetLevel(v);
                                <MudButton FullWidth="true" Variant="Variant.Filled" Color="@GetColor(level)" OnClick="() => OpenVariant(v)">
                                    @GetDisplayName(level)
                                </MudButton>
                            }
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "name")]
    public string Name { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        ViewModel.Initialize(Name);
    }

    private void OpenVariant(string id)
    {
        ViewModel.StartWorkout(id);
        NavigationManager.NavigateTo("/Workouts/WorkoutRoom");
    }

    private void Back()
    {
        NavigationManager.NavigateTo("/Workouts/workoutarea");
    }

    private Color GetColor(Level level)
    {
        return level switch
        {
            Level.Easy => Color.Info,
            Level.Moderate => Color.Success,
            Level.Advanced => Color.Warning,
            Level.Epic => Color.Error,
            _ => Color.Default,
        };
    }

    private string GetDisplayName(Level level) => L[$"Level_{level}"];
}
