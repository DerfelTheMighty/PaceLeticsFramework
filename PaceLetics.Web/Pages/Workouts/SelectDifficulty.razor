@page "/Workouts/SelectDifficulty"
@using PaceLetics.WorkoutModule.CodeBase.Interfaces
@using MudBlazor
@using PaceLetics.WorkoutModule.CodeBase.Models
@using PaceLetics.WorkoutModule.CodeBase.Enums
@using System.ComponentModel.DataAnnotations
@inject IWorkoutProvider woProvider
@inject NavigationManager NavigationManager

<PageTitle>Schwierigkeit wählen</PageTitle>

<MudContainer Class="pt-6 px-6 pb-8" MaxWidth="MaxWidth.Medium">
    <MudPaper Class="p-6" Elevation="2">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" JustifyContent="Justify.SpaceBetween">
                <MudText Typo="Typo.h4">Schwierigkeit wählen</MudText>
                <MudButton Variant="Variant.Text" StartIcon="Icons.Material.Filled.ArrowBack" OnClick="@Back">Zurück</MudButton>
            </MudStack>

            <MudDivider />

            @if (_variants is null || !_variants.Any())
            {
                <MudText>Keine Varianten gefunden.</MudText>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-2" Style="display:flex;align-items:center;justify-content:center;">
                            <MudImage Src="@_previewImage" Alt="@name" Style="width:100%;height:180px;object-fit:cover;border-radius:4px;" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudText Typo="Typo.h6">@name</MudText>
                        <MudText Typo="Typo.body2" Style="opacity:.8">@_previewDescription</MudText>

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudNumericField Label="Wdh. pro Übung" @bind-Value="_sets" Min="1" Max="20" Style="width:150px" />
                            <MudNumericField Label="Rundenzahl" @bind-Value="_rounds" Min="1" Max="20" Style="width:150px" />
                        </MudStack>

                        <MudText Typo="Typo.subtitle1" Class="mt-4">Verfügbare Schwierigkeitsstufen</MudText>
                        <MudStack Spacing="2" Class="mt-2">
                            @foreach(var v in _variants)
                            {
                                var pv = woProvider.GetWorkoutPreview(v);
                                var level = pv?.Level ?? Level.None;
                                <MudButton FullWidth="true" Variant="Variant.Filled" Color="@GetColor(level)" OnClick="() => OpenVariant(v)">
                                    @GetDisplayName(level)
                                </MudButton>
                            }
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string name { get; set; }

    private List<string> _variants;
    private string _previewImage = "images/exercises/no_image.png";
    private string _previewDescription = string.Empty;
    private int _sets = 1;
    private int _rounds = 1;

    protected override void OnInitialized()
    {
        _variants = woProvider.GetWorkoutIdsByName(name) ?? new List<string>();
        if (_variants.Any())
        {
            var p = woProvider.GetWorkoutPreview(_variants.First());
            _previewDescription = p?.Description ?? string.Empty;
            var img = p?.Exercises?.FirstOrDefault()?.Imagefile;
            if (!string.IsNullOrEmpty(img)) _previewImage = "images/exercises/" + img;
        }
    }

    private void OpenVariant(string id)
    {
        woProvider.SetActiveWorkout(id, _sets, _rounds);
        NavigationManager.NavigateTo("/Workouts/WorkoutRoom");
    }

    private void Back()
    {
        NavigationManager.NavigateTo("/Workouts/workoutarea");
    }

    private string GetLevelFromId(string id)
    {
        if (string.IsNullOrEmpty(id)) return string.Empty;
        var parts = id.Split(' ');
        return parts.Last();
    }

    private Color GetColor(Level level)
    {
        return level switch
        {
            Level.Easy => Color.Info,
            Level.Moderate => Color.Success,
            Level.Advanced => Color.Warning,
            Level.Epic => Color.Error,
            _ => Color.Default,
        };
    }

    private string GetDisplayName(Level level)
    {
        var type = typeof(Level);
        var mem = type.GetMember(level.ToString());
        if (mem != null && mem.Length > 0)
        {
            var attrs = mem[0].GetCustomAttributes(typeof(DisplayAttribute), false);
            if (attrs != null && attrs.Length > 0)
                return ((DisplayAttribute)attrs[0]).GetName() ?? level.ToString();
        }
        return level.ToString();
    }
}
