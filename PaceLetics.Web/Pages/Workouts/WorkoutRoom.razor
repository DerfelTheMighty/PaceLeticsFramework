@page "/Workouts/workoutroom"
@implements IDisposable
@using PaceLetics.TrainingModule.CodeBase.Workouts.Enums
@using PaceLetics.TrainingModule.Components.Workouts

@inject WorkoutRoomViewModel ViewModel
@inject IDialogService dialogService
@inject NavigationManager navManager
@inject IStringLocalizer<WorkoutRoom> L
@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IAchievementService AchievementService
@inject ITrainingFeedbackService FeedbackService
@inject ISnackbar Snackbar

<PageTitle>@(ViewModel.Workout?.Name ?? L["WorkoutTitle"])</PageTitle>

<MudContainer Class="pl-workout-room px-4" MaxWidth="MaxWidth.Medium">

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="pt-3">
        <MudButton Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Close" OnClick="ExitWorkoutAsync">
            @L["ExitWorkout"]
        </MudButton>
    </MudStack>

    @if (ViewModel.Workout is null)
    {
        <MudText Typo="Typo.h5" HtmlTag="h1">@L["NoWorkout"]</MudText>
        <MudButton Href="/Workouts/workoutarea" StartIcon="@Icons.Material.Filled.ArrowBack">@L["BackToWorkouts"]</MudButton>
    }
    else
    {
        <h1 class="pl-visually-hidden">@ViewModel.Workout.Name</h1>
        <MudStack Spacing="3">
            <WorkoutView Workout="@ViewModel.Workout" />
        </MudStack>
    }

</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "planId")]
    public string? PlanId { get; set; }

    [SupplyParameterFromQuery(Name = "sessionId")]
    public string? SessionId { get; set; }

    private IDisposable? _navigationRegistration;
    private bool _allowNavigation;

    protected override void OnInitialized()
    {
        ViewModel.Initialize();
        if (ViewModel.Workout is not null)
            ViewModel.Workout.WorkoutFinishedEvent += OnWorkoutFinished;
        _navigationRegistration = navManager.RegisterLocationChangingHandler(LocationChangingHandler);
        base.OnInitialized();
    }

    private void OnWorkoutFinished()
    {
        _ = InvokeAsync(HandleWorkoutFinishedAsync);
    }

    private async Task HandleWorkoutFinishedAsync()
    {
        var userId = await GetUserIdAsync();
        await RecordWorkoutAchievementAsync(userId);
        await RecordPlannedSessionCompletionAsync(userId);
        var options = new DialogOptions { CloseOnEscapeKey = true, FullWidth = true, MaxWidth = MaxWidth.ExtraSmall };
        var parameters = new DialogParameters<TrainingFeedbackDialog>
        {
            { dialog => dialog.TrainingName, ViewModel.Workout?.Name ?? string.Empty }
        };
        var dialog = await dialogService.ShowAsync<TrainingFeedbackDialog>(
            L["WorkoutCompleted"],
            parameters,
            options);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: TrainingFeedbackInput input }
            && !string.IsNullOrWhiteSpace(userId))
        {
            try
            {
                await FeedbackService.SaveAsync(
                    userId,
                    input,
                    ViewModel.Workout?.Name ?? L["WorkoutTitle"],
                    "workout",
                    PlanId ?? string.Empty,
                    SessionId ?? string.Empty,
                    ViewModel.Workout?.Id ?? string.Empty);
                Snackbar.Add(L["FeedbackSaved"], Severity.Success);
            }
            catch
            {
                Snackbar.Add(L["FeedbackSaveFailed"], Severity.Warning);
            }
        }
        _allowNavigation = true;
        navManager.NavigateTo("/");
    }

    private async Task<string?> GetUserIdAsync()
    {
        var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
        return authState.User.FindFirst(claim =>
            claim.Type.Contains("nameidentifier", StringComparison.OrdinalIgnoreCase))?.Value;
    }

    private async Task RecordWorkoutAchievementAsync(string? userId)
    {
        if (ViewModel.Workout is null || string.IsNullOrWhiteSpace(userId))
            return;

        try
        {
            var result = await AchievementService.RecordWorkoutCompletedAsync(
                userId,
                ViewModel.Workout.Id,
                ViewModel.Workout.Name);

            foreach (var award in result.Awarded)
                Snackbar.Add($"Achievement freigeschaltet: {award.TitleSnapshot}", Severity.Success);
        }
        catch
        {
            Snackbar.Add(L["AchievementUpdateFailed"], Severity.Warning);
        }
    }

    private async Task RecordPlannedSessionCompletionAsync(string? userId)
    {
        if (string.IsNullOrWhiteSpace(userId)
            || string.IsNullOrWhiteSpace(PlanId)
            || string.IsNullOrWhiteSpace(SessionId))
        {
            return;
        }

        try
        {
            await AchievementService.SetTrainingSessionCompletionAsync(userId, PlanId, SessionId, true);
        }
        catch
        {
            Snackbar.Add(L["PlannedSessionUpdateFailed"], Severity.Warning);
        }
    }

    private async Task ExitWorkoutAsync()
    {
        if (!await ConfirmLeaveAsync())
            return;

        _allowNavigation = true;
        ViewModel.StopAndReset();
        navManager.NavigateTo("/Workouts/workoutarea");
    }

    private async ValueTask LocationChangingHandler(LocationChangingContext context)
    {
        if (_allowNavigation || !HasWorkoutInProgress())
        {
            ViewModel.StopAndReset();
            return;
        }

        context.PreventNavigation();
        if (!await ConfirmLeaveAsync())
            return;

        _allowNavigation = true;
        ViewModel.StopAndReset();
        navManager.NavigateTo(context.TargetLocation);
    }

    private bool HasWorkoutInProgress() =>
        ViewModel.Workout?.State is WorkoutState.Running or WorkoutState.Pause;

    private Task<bool> ConfirmLeaveAsync() => HasWorkoutInProgress()
        ? UiConfirmation.AskAsync(dialogService, L["LeaveWorkoutConfirm"], destructive: false)
        : Task.FromResult(true);

    public void Dispose()
    {
        _navigationRegistration?.Dispose();
        if (ViewModel.Workout is not null)
            ViewModel.Workout.WorkoutFinishedEvent -= OnWorkoutFinished;
    }
}
