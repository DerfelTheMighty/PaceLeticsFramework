@page "/Workouts/workoutroom"
@using PaceLetics.WorkoutModule.CodeBase.Enums
@using PaceLetics.WorkoutModule.Components

@inject WorkoutRoomViewModel ViewModel
@inject IDialogService dialogService
@inject NavigationManager navManager
@inject IStringLocalizer<WorkoutRoom> L

<MudContainer Class="mt-16 px-8" MaxWidth="MaxWidth.Small">

    @if (ViewModel.Workout is null)
    {
        <MudText>@L["NoWorkout"]</MudText>
    }
    else
    {
        <MudStack Spacing="3">
            <WorkoutView Workout="@ViewModel.Workout" />
        </MudStack>
    }

</MudContainer>

@code {
    protected override void OnInitialized()
    {
        ViewModel.Initialize();
        if (ViewModel.Workout is not null)
            ViewModel.Workout.WorkoutFinishedEvent += OnWorkoutFinished;
        navManager.RegisterLocationChangingHandler(LocationChangingHandler);
        base.OnInitialized();
    }

    private async void OnWorkoutFinished()
    {
        await InvokeAsync(async () =>
        {
            var options = new DialogOptions { CloseOnEscapeKey = true };
            await dialogService.ShowAsync<WorkoutFinishedDialog>(
                L["WorkoutCompleted"],
                options);
        });
    }

    private ValueTask LocationChangingHandler(LocationChangingContext arg)
    {
        ViewModel.StopAndReset();
        return ValueTask.CompletedTask;
    }
}
