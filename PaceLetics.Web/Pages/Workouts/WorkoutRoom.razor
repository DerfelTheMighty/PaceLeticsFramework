@page "/Workouts/workoutroom"
@using PaceLetics.TrainingModule.CodeBase.Workouts.Enums
@using PaceLetics.TrainingModule.Components.Workouts

@inject WorkoutRoomViewModel ViewModel
@inject IDialogService dialogService
@inject NavigationManager navManager
@inject IStringLocalizer<WorkoutRoom> L
@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IAchievementService AchievementService
@inject ISnackbar Snackbar

<MudContainer Class="mt-16 px-8" MaxWidth="MaxWidth.Small">

    @if (ViewModel.Workout is null)
    {
        <MudText>@L["NoWorkout"]</MudText>
    }
    else
    {
        <MudStack Spacing="3">
            <WorkoutView Workout="@ViewModel.Workout" />
        </MudStack>
    }

</MudContainer>

@code {
    protected override void OnInitialized()
    {
        ViewModel.Initialize();
        if (ViewModel.Workout is not null)
            ViewModel.Workout.WorkoutFinishedEvent += OnWorkoutFinished;
        navManager.RegisterLocationChangingHandler(LocationChangingHandler);
        base.OnInitialized();
    }

    private async void OnWorkoutFinished()
    {
        await InvokeAsync(async () =>
        {
            await RecordWorkoutAchievementAsync();
            var options = new DialogOptions { CloseOnEscapeKey = true };
            await dialogService.ShowAsync<WorkoutFinishedDialog>(
                L["WorkoutCompleted"],
                options);
        });
    }

    private async Task RecordWorkoutAchievementAsync()
    {
        if (ViewModel.Workout is null)
            return;

        try
        {
            var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(claim => claim.Type.Contains("nameidentifier"))?.Value;
            if (string.IsNullOrWhiteSpace(userId))
                return;

            var result = await AchievementService.RecordWorkoutCompletedAsync(
                userId,
                ViewModel.Workout.Id,
                ViewModel.Workout.Name);

            foreach (var award in result.Awarded)
                Snackbar.Add($"Achievement freigeschaltet: {award.TitleSnapshot}", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Das Workout wurde abgeschlossen, aber Achievements konnten nicht aktualisiert werden.", Severity.Warning);
        }
    }

    private ValueTask LocationChangingHandler(LocationChangingContext arg)
    {
        ViewModel.StopAndReset();
        return ValueTask.CompletedTask;
    }
}
