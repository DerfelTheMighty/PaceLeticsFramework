@page
@model LoginModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="mud-paper mud-elevation-4 pa-6 rounded-lg">
    <h1 class="mud-typography mud-typography-h5 mb-2">@Localizer["WelcomeTitle"]</h1>
    <p class="mud-typography mud-typography-body2 mb-4" style="opacity:.7;">@Localizer["WelcomeText"]</p>

    <div class="mud-divider my-4"></div>

    <div class="mud-typography mud-typography-h6 mb-1">@Localizer["Title"]</div>
    <p class="mud-typography mud-typography-body2 mb-4" style="opacity:.65;">@Localizer["LoginPrompt"]</p>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
        <div class="form-floating mb-3">
            <input asp-for="Input.UserNameOrEmail" class="form-control" autocomplete="username" aria-required="true" required placeholder="@Localizer["UserNameOrEmail"]" />
            <label asp-for="Input.UserNameOrEmail" class="form-label">@Localizer["UserNameOrEmail"]</label>
            <span asp-validation-for="Input.UserNameOrEmail" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3 pl-password-field">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" required placeholder="@Localizer["Password"]" />
            <label asp-for="Input.Password" class="form-label">@Localizer["Password"]</label>
            <button type="button" class="pl-password-toggle" data-password-toggle="Input_Password" aria-label="@Localizer["ShowPassword"]">
                <span aria-hidden="true">&#128065;</span>
            </button>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="form-check mb-4">
            <input class="form-check-input" asp-for="Input.RememberMe" />
            <label asp-for="Input.RememberMe" class="form-check-label">
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>
        </div>
        <button id="login-submit" type="submit" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-filled-size-large mud-ripple-button w-100 mb-3">
            <span class="mud-button-label">@Localizer["LoginButton"]</span>
        </button>
        <div class="d-flex flex-column gap-2 mt-2">
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="mud-typography mud-typography-body2">@Localizer["RegisterNewUser"]</a>
            <a id="forgot-password" asp-page="./ForgotPassword" class="mud-typography mud-typography-body2">@Localizer["ForgotPassword"]</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
