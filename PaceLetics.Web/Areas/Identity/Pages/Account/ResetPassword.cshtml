@page
@model ResetPasswordModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="mud-paper mud-elevation-4 pa-6 rounded-lg">
    <h1 class="mud-typography mud-typography-h5 mb-2">@Localizer["Title"]</h1>
    <p class="mud-typography mud-typography-body2 mb-4" style="opacity:.75;">@Localizer["Intro"]</p>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
        <input asp-for="Input.Code" type="hidden" />
        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" required placeholder="name@example.com" />
            <label asp-for="Input.Email">@Localizer["Email"]</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3 pl-password-field">
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" required minlength="6" placeholder="@Localizer["Password"]" />
            <label asp-for="Input.Password">@Localizer["Password"]</label>
            <button type="button" class="pl-password-toggle" data-password-toggle="Input_Password" aria-label="@Localizer["ShowPassword"]"><span aria-hidden="true">&#128065;</span></button>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3 pl-password-field">
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" required minlength="6" placeholder="@Localizer["ConfirmPassword"]" />
            <label asp-for="Input.ConfirmPassword">@Localizer["ConfirmPassword"]</label>
            <button type="button" class="pl-password-toggle" data-password-toggle="Input_ConfirmPassword" aria-label="@Localizer["ShowPassword"]"><span aria-hidden="true">&#128065;</span></button>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>
        <button type="submit" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-filled-size-large mud-ripple-button w-100">
            <span class="mud-button-label">@Localizer["Submit"]</span>
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
