@page
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<h2>@Localizer["Title"]</h2>

<p>@Localizer["Intro"]</p>

<section class="mb-4">
    <h3>@Localizer["ResponsibleHeading"]</h3>
    <p>@Localizer["ResponsibleText"] @ImModel.Name, @ImModel.Street, @ImModel.PostalCode @ImModel.City, @Localizer["Country"].</p>
</section>

<section class="mb-4">
    <h3>@Localizer["TaxHeading"]</h3>
    <p>@Localizer["VatId"]: @Localizer["VatIdNotProvided"]</p>
    <p>@Localizer["RegisterEntry"]: @Localizer["RegisterEntryNotProvided"]</p>
</section>

<section class="mb-4">
    <h3>@Localizer["DisputeHeading"]</h3>
    <p>@Localizer["DisputeText"]</p>
</section>

<section class="mb-4">
    <h3>@Localizer["LiabilityHeading"]</h3>
    <p>@Localizer["LiabilityOwnContent"]</p>
    <p>@Localizer["LiabilityLinks"]</p>
</section>

<section class="mb-4">
    <h3>@Localizer["CopyrightHeading"]</h3>
    <p>@Localizer["CopyrightText"]</p>
</section>

<section class="mb-4">
    <h3>@Localizer["PrivacyHeading"]</h3>
    <p>@Localizer["PrivacyText"]</p>
</section>

<section class="mb-4">
    <h3>@Localizer["ProviderHeading"]</h3>
    <address>
        <strong>@ImModel.Name</strong><br />
        @ImModel.Street<br />
        @ImModel.PostalCode @ImModel.City<br />
        @Localizer["Country"]
    </address>

    <p>
        @Localizer["Phone"]: @ImModel.PhoneNumber<br />
        @Localizer["EmailLabel"]: <a href="mailto:@ImModel.Email">@ImModel.Email</a>
    </p>
</section>

@functions {
    public class ImpressumModel
    {
        public string Name { get; set; } = "Christoph Otte";
        public string Street { get; set; } = "Effengrube 7";
        public string PostalCode { get; set; } = "23552";
        public string City { get; set; } = "L\u00fcbeck";
        public string PhoneNumber { get; set; } = "0162 6057269";
        public string Email { get; set; } = "mail@caotte.de";
    }

    private ImpressumModel ImModel = new ImpressumModel();
}
