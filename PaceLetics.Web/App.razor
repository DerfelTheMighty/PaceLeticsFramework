@using System.Globalization
@using PaceLetics.Web.Services.Localization
@inject IStringLocalizer<App> L
@inject AppCultureService AppCulture

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>@L["NotFoundTitle"]</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudContainer MaxWidth="MaxWidth.Small" Class="pt-8 px-4">
                    <MudPaper Elevation="0" Class="pa-6 pl-panel" role="alert">
                        <MudStack Spacing="3" AlignItems="AlignItems.Start">
                            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h5" HtmlTag="h1">@L["NotFoundTitle"]</MudText>
                            <MudText Typo="Typo.body1" Color="Color.Secondary">@L["NotFoundMessage"]</MudText>
                            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Home">
                                @L["GoToDashboard"]
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudContainer>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    [Parameter] public string? InitialCulture { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(InitialCulture))
        {
            var culture = new CultureInfo(InitialCulture);
            CultureInfo.CurrentCulture = culture;
            CultureInfo.CurrentUICulture = culture;
            AppCulture.SetCulture(culture);
        }
    }
}
