@namespace PaceLetics.RunningAnalysisModule.Components
@inject IStringLocalizer<RunningAnalysisResources> L

<MudStack Spacing="3" Class="mt-4">
    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["InterventionGuidance_Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @L["InterventionGuidance_Subtitle"]
            </MudText>
        </MudStack>
    </MudPaper>

    @if (Compact)
    {
        <MudPaper Class="pa-4" Elevation="0">
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                @L["InterventionGuidance_CompactIntro"]
            </MudAlert>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudGrid Spacing="2">
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2">@L["InterventionGuidance_TalkTitle"]</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem>@L["InterventionGuidance_CompactTalk_1"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_CompactTalk_2"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_CompactTalk_3"]</MudListItem>
                    </MudList>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2">@L["InterventionGuidance_ReviewTitle"]</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem>@L["InterventionGuidance_CompactReview_1"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_CompactReview_2"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_CompactReview_3"]</MudListItem>
                    </MudList>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["InterventionGuidance_SystemUnderstandingTitle"]</MudText>

                <MudText Typo="Typo.body2">
                    @L["InterventionGuidance_SystemUnderstandingText"]
                    <a href="@Sources[3].Url" target="_blank" rel="noopener noreferrer">[4]</a>.
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                @L["InterventionGuidance_FunctioningSystemAlert"]
            </MudAlert>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["InterventionGuidance_SideEffectsTitle"]</MudText>

                <MudText Typo="Typo.body2">
                    @L["InterventionGuidance_SideEffectsIntro"]
                    <a href="@Sources[2].Url" target="_blank" rel="noopener noreferrer">[3]</a>,
                    <a href="@Sources[5].Url" target="_blank" rel="noopener noreferrer">[6]</a>,
                    <a href="@Sources[6].Url" target="_blank" rel="noopener noreferrer">[7]</a>.
                    @L["InterventionGuidance_SideEffectsIndicationIntro"]
                </MudText>

                <MudList T="string" Dense="true">
                    <MudListItem>@L["InterventionGuidance_SideEffectsIndication_1"]</MudListItem>
                    <MudListItem>@L["InterventionGuidance_SideEffectsIndication_2"]</MudListItem>
                </MudList>

                <MudText Typo="Typo.body2">
                    @L["InterventionGuidance_SideEffectsConclusion"]
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["InterventionGuidance_ConsentPowerDynamicsTitle"]</MudText>

                <MudText Typo="Typo.body2">
                    @L["InterventionGuidance_ConsentPowerDynamicsText"]
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["InterventionGuidance_ControlIllusionTitle"]</MudText>

                <MudText Typo="Typo.body2">
                    @L["InterventionGuidance_ControlIllusionText"]
                    <a href="@Sources[0].Url" target="_blank" rel="noopener noreferrer">[1]</a>,
                    <a href="@Sources[1].Url" target="_blank" rel="noopener noreferrer">[2]</a>,
                    <a href="@Sources[4].Url" target="_blank" rel="noopener noreferrer">[5]</a>.
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudGrid Spacing="2">
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2">@L["InterventionGuidance_TalkTitle"]</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem>@L["InterventionGuidance_Talk_1"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_Talk_2"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_Talk_3"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_Talk_4"]</MudListItem>
                    </MudList>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2">@L["InterventionGuidance_RelevanceTitle"]</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem>@L["InterventionGuidance_Relevance_1"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_Relevance_2"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_Relevance_3"]</MudListItem>
                        <MudListItem>@L["InterventionGuidance_Relevance_4"]</MudListItem>
                    </MudList>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["InterventionGuidance_EvidenceTitle"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @L["InterventionGuidance_EvidenceSubtitle"]
            </MudText>

            <MudTable Items="EvidenceRows" Dense="true" Hover="false" Elevation="0" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>@TableFeatureLabel</MudTh>
                    <MudTh>@TableEvidenceLabel</MudTh>
                    <MudTh>@TableScoreLabel</MudTh>
                    <MudTh>@TableBenefitLabel</MudTh>
                    <MudTh>@TableRelevantWhenLabel</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@TableFeatureLabel">
                        <span style="display:inline-block; padding:4px 8px; border-radius:999px; font-weight:700; color:var(--mud-palette-primary); background:var(--mud-palette-primary-hover);">
                            @L[context.FeatureKey]
                        </span>
                    </MudTd>
                    <MudTd DataLabel="@TableEvidenceLabel">@context.Evidence</MudTd>
                    <MudTd DataLabel="@TableScoreLabel">@context.Score</MudTd>
                    <MudTd DataLabel="@TableBenefitLabel">@L[context.InjuryPreventionBenefitKey]</MudTd>
                    <MudTd DataLabel="@TableRelevantWhenLabel">@L[context.ActionThresholdKey]</MudTd>
                </RowTemplate>
            </MudTable>
        </MudStack>
    </MudPaper>

    @if (!Compact)
    {
        <MudPaper Class="pa-4" Elevation="0">
            <MudStack Spacing="1">
                <MudText Typo="Typo.subtitle2">@L["InterventionGuidance_SourcesTitle"]</MudText>
                @foreach (var source in Sources)
                {
                    <MudText Typo="Typo.caption">
                        [@source.Number]
                        <a href="@source.Url" target="_blank" rel="noopener noreferrer">@L[source.TitleKey]</a>
                    </MudText>
                }
            </MudStack>
        </MudPaper>
    }
</MudStack>

@code {
    [Parameter] public bool Compact { get; set; }

    private string TableFeatureLabel => L["InterventionGuidance_TableFeature"];
    private string TableEvidenceLabel => L["InterventionGuidance_TableEvidence"];
    private string TableScoreLabel => L["InterventionGuidance_TableScore"];
    private string TableBenefitLabel => L["InterventionGuidance_TableBenefit"];
    private string TableRelevantWhenLabel => L["InterventionGuidance_TableRelevantWhen"];

    private static readonly EvidenceRow[] EvidenceRows =
    {
        new("InterventionGuidance_FeatureHipDrop", "B", 8, "InterventionGuidance_BenefitHigh", "InterventionGuidance_ThresholdHipDrop"),
        new("InterventionGuidance_FeatureLegInternalRotation", "B", 8, "InterventionGuidance_BenefitHigh", "InterventionGuidance_ThresholdLegInternalRotation"),
        new("InterventionGuidance_FeatureOverstride", "C", 7, "InterventionGuidance_BenefitMedium", "InterventionGuidance_ThresholdOverstride"),
        new("InterventionGuidance_FeatureForwardLean", "C", 5, "InterventionGuidance_BenefitLow", "InterventionGuidance_ThresholdForwardLean"),
        new("InterventionGuidance_FeatureHipExtension", "D", 4, "InterventionGuidance_BenefitLow", "InterventionGuidance_ThresholdHipExtension"),
        new("InterventionGuidance_FeatureLordosis", "D", 3, "InterventionGuidance_BenefitVeryLow", "InterventionGuidance_ThresholdLordosis"),
        new("InterventionGuidance_FeatureTrunkRotation", "D", 3, "InterventionGuidance_BenefitVeryLow", "InterventionGuidance_ThresholdTrunkRotation"),
        new("InterventionGuidance_FeatureArmAngle", "D", 1, "InterventionGuidance_BenefitNone", "InterventionGuidance_ThresholdArmAngle")
    };

    private static readonly SourceRow[] Sources =
    {
        new("1", "InterventionGuidance_SourceCeyssens", "https://pubmed.ncbi.nlm.nih.gov/31028658/"),
        new("2", "InterventionGuidance_SourceWillwacher", "https://pubmed.ncbi.nlm.nih.gov/35247202/"),
        new("3", "InterventionGuidance_SourceAndersonStepRate", "https://link.springer.com/article/10.1186/s40798-022-00504-0"),
        new("4", "InterventionGuidance_SourceMoore", "https://link.springer.com/article/10.1007/s40279-016-0474-4"),
        new("5", "InterventionGuidance_SourceNigg", "https://bjsm.bmj.com/content/49/20/1290"),
        new("6", "InterventionGuidance_SourceGaitRetraining", "https://pmc.ncbi.nlm.nih.gov/articles/PMC9655004/"),
        new("7", "InterventionGuidance_SourceRidge", "https://pubmed.ncbi.nlm.nih.gov/23439417/"),
        new("8", "InterventionGuidance_SourceChristopher", "https://pubmed.ncbi.nlm.nih.gov/30805204/")
    };

    private sealed record EvidenceRow(
        string FeatureKey,
        string Evidence,
        int Score,
        string InjuryPreventionBenefitKey,
        string ActionThresholdKey);

    private sealed record SourceRow(
        string Number,
        string TitleKey,
        string Url);
}
