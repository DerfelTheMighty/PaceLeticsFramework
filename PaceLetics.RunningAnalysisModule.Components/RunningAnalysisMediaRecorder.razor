@namespace PaceLetics.RunningAnalysisModule.Components
@implements IAsyncDisposable
@inject IJSRuntime JS

<MudStack Spacing="2">
    <div class="running-analysis-media-recorder">
        <video @ref="_videoElement" autoplay muted playsinline></video>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_errorMessage</MudAlert>
    }

    @if (ShowControls)
    {
        <MudStack Row="true" Justify="Justify.Center" Style="gap:8px; flex-wrap:wrap;">
            @if (!_isRecording)
            {
                <MudTooltip Text="Start">
                    <MudIconButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Disabled="@(!CanRecord)"
                                   Icon="@Icons.Material.Filled.FiberManualRecord"
                                   OnClick="StartAsync"
                                   aria-label="Start" />
                </MudTooltip>
            }
            else
            {
                <MudTooltip Text="Stop">
                    <MudIconButton Color="Color.Error"
                                   Variant="Variant.Filled"
                                   Icon="@Icons.Material.Filled.Stop"
                                   OnClick="StopAsync"
                                   aria-label="Stop" />
                </MudTooltip>
            }
        </MudStack>
    }
</MudStack>

<style>
    .running-analysis-media-recorder {
        aspect-ratio: 16 / 9;
        width: 100%;
        background: #111;
        border-radius: 8px;
        overflow: hidden;
    }

    .running-analysis-media-recorder video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
</style>

@code {
    private ElementReference _videoElement;
    private IJSObjectReference? _module;
    private bool _isRecording;
    private string? _errorMessage;

    [Parameter] public string CaptureSessionId { get; set; } = string.Empty;
    [Parameter] public string CaptureExternalEventId { get; set; } = string.Empty;
    [Parameter] public string CourseId { get; set; } = string.Empty;
    [Parameter] public string CaptureTitle { get; set; } = string.Empty;
    [Parameter] public DateTime? CaptureStartsAt { get; set; }
    [Parameter] public string AnalysisEventId { get; set; } = string.Empty;
    [Parameter] public string AnalysisExternalEventId { get; set; } = string.Empty;
    [Parameter] public string AnalysisTitle { get; set; } = string.Empty;
    [Parameter] public DateTime? AnalysisStartsAt { get; set; }
    [Parameter] public string ParticipantId { get; set; } = string.Empty;
    [Parameter] public string AthleteUserId { get; set; } = string.Empty;
    [Parameter] public string AthleteEmail { get; set; } = string.Empty;
    [Parameter] public string ParticipantName { get; set; } = string.Empty;
    [Parameter] public string FileNamePrefix { get; set; } = string.Empty;
    [Parameter] public RunningAnalysisPerspective Perspective { get; set; } = RunningAnalysisPerspective.Side;
    [Parameter] public bool CanRecord { get; set; } = true;
    [Parameter] public bool ShowControls { get; set; } = true;
    [Parameter] public EventCallback<RunningAnalysisRecordedVideo> OnRecorded { get; set; }
    [Parameter] public EventCallback<bool> IsRecordingChanged { get; set; }

    private string EffectiveCaptureSessionId => string.IsNullOrWhiteSpace(CaptureSessionId) ? AnalysisEventId : CaptureSessionId;
    private string EffectiveCaptureExternalEventId => string.IsNullOrWhiteSpace(CaptureExternalEventId) ? AnalysisExternalEventId : CaptureExternalEventId;
    private string EffectiveCaptureTitle => string.IsNullOrWhiteSpace(CaptureTitle) ? AnalysisTitle : CaptureTitle;
    private DateTime? EffectiveCaptureStartsAt => CaptureStartsAt ?? AnalysisStartsAt;
    private string PerspectiveToken => RunningAnalysisPerspectiveFormatting.ToFileNameToken(Perspective);

    public async Task StartAsync()
    {
        if (!CanRecord)
            return;

        try
        {
            _errorMessage = null;
            var module = await GetModuleAsync();
            await module.InvokeVoidAsync(
                "startRecording",
                _videoElement,
                new RecordingMetadata(
                    EffectiveCaptureSessionId,
                    EffectiveCaptureExternalEventId,
                    CourseId,
                    EffectiveCaptureTitle,
                    EffectiveCaptureStartsAt,
                    ParticipantId,
                    AthleteUserId,
                    AthleteEmail,
                    ParticipantName,
                    FileNamePrefix,
                    PerspectiveToken));
            _isRecording = true;
            await IsRecordingChanged.InvokeAsync(true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _isRecording = false;
            await IsRecordingChanged.InvokeAsync(false);
        }
    }

    public async Task StopAsync()
    {
        if (!_isRecording)
            return;

        try
        {
            var module = await GetModuleAsync();
            var payload = await module.InvokeAsync<RecordedVideoPayload>(
                "stopRecording",
                _videoElement);
            _isRecording = false;
            await IsRecordingChanged.InvokeAsync(false);
            await OnRecorded.InvokeAsync(new RunningAnalysisRecordedVideo(
                payload.LocalId,
                payload.EffectiveCaptureSessionId,
                payload.EffectiveCaptureExternalEventId,
                payload.CourseId,
                payload.EffectiveCaptureTitle,
                payload.EffectiveCaptureStartsAt,
                payload.ParticipantId,
                payload.AthleteUserId,
                payload.AthleteEmail,
                payload.ParticipantName,
                payload.FileName,
                payload.ContentType,
                payload.FileExtension,
                payload.Size,
                payload.RecordedAt,
                payload.StorageLocation,
                payload.UploadStatus,
                payload.UploadAttempts,
                payload.LastUploadAt,
                payload.LastError,
                payload.DriveFileUrl,
                payload.EffectiveCaptureSessionId,
                payload.EffectiveCaptureExternalEventId,
                payload.EffectiveCaptureTitle,
                payload.EffectiveCaptureStartsAt,
                payload.Perspective,
                payload.StorageMode));
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _isRecording = false;
            await IsRecordingChanged.InvokeAsync(false);
        }
    }

    private async Task<IJSObjectReference> GetModuleAsync()
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/PaceLetics.RunningAnalysisModule.Components/runningAnalysisMediaRecorder.js?v=20260716.1");

        return _module;
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is null)
            return;

        try
        {
            await _module.InvokeVoidAsync("disposeRecorder", _videoElement);
            await _module.DisposeAsync();
        }
        catch
        {
            // Best-effort cleanup during component disposal.
        }
    }

    private sealed record RecordingMetadata(
        string CaptureSessionId,
        string CaptureExternalEventId,
        string CourseId,
        string CaptureTitle,
        DateTime? CaptureStartsAt,
        string ParticipantId,
        string AthleteUserId,
        string AthleteEmail,
        string ParticipantName,
        string FileNamePrefix,
        string Perspective);

    private sealed class RecordedVideoPayload
    {
        public string LocalId { get; set; } = string.Empty;
        public string CaptureSessionId { get; set; } = string.Empty;
        public string CaptureExternalEventId { get; set; } = string.Empty;
        public string AnalysisEventId { get; set; } = string.Empty;
        public string AnalysisExternalEventId { get; set; } = string.Empty;
        public string CourseId { get; set; } = string.Empty;
        public string CaptureTitle { get; set; } = string.Empty;
        public DateTime? CaptureStartsAt { get; set; }
        public string AnalysisTitle { get; set; } = string.Empty;
        public DateTime? AnalysisStartsAt { get; set; }
        public string ParticipantId { get; set; } = string.Empty;
        public string AthleteUserId { get; set; } = string.Empty;
        public string AthleteEmail { get; set; } = string.Empty;
        public string ParticipantName { get; set; } = string.Empty;
        public string FileName { get; set; } = string.Empty;
        public string ContentType { get; set; } = "video/webm";
        public string FileExtension { get; set; } = "webm";
        public long Size { get; set; }
        public DateTime RecordedAt { get; set; }
        public string StorageLocation { get; set; } = string.Empty;
        public string UploadStatus { get; set; } = "queued";
        public int UploadAttempts { get; set; }
        public DateTime? LastUploadAt { get; set; }
        public string? LastError { get; set; }
        public string? DriveFileUrl { get; set; }
        public string Perspective { get; set; } = "side";
        public string StorageMode { get; set; } = string.Empty;
        public string EffectiveCaptureSessionId => string.IsNullOrWhiteSpace(CaptureSessionId) ? AnalysisEventId : CaptureSessionId;
        public string EffectiveCaptureExternalEventId => string.IsNullOrWhiteSpace(CaptureExternalEventId) ? AnalysisExternalEventId : CaptureExternalEventId;
        public string EffectiveCaptureTitle => string.IsNullOrWhiteSpace(CaptureTitle) ? AnalysisTitle : CaptureTitle;
        public DateTime? EffectiveCaptureStartsAt => CaptureStartsAt ?? AnalysisStartsAt;
    }
}
