@namespace PaceLetics.RunningAnalysisModule.Components
@implements IAsyncDisposable
@inject IJSRuntime JS

<MudPaper Elevation="1" Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@GetStepTitle()</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">@GetStepInstruction()</MudText>
        </MudStack>

        @if (_wizardStep == CaptureWizardStep.Roster)
        {
            <MudStack Spacing="2">
                @if (OrderedParticipants.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        Es sind keine Teilnehmer:innen registriert.
                    </MudAlert>
                }
                else
                {
                    @foreach (var participant in OrderedParticipants)
                    {
                        <MudPaper Elevation="0" Class="pa-3" Style="border:1px solid var(--mud-palette-lines-default);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap:12px;">
                                <MudStack Spacing="0" Style="min-width:0;">
                                    <MudText Typo="Typo.body1">@participant.DisplayName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetParticipantRecordingText(participant)</MudText>
                                </MudStack>
                                <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
                            </MudStack>
                        </MudPaper>
                    }
                }
            </MudStack>
        }
        else if (_wizardStep == CaptureWizardStep.Storage)
        {
            <MudStack Spacing="3">
                @if (IsStorageReady)
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                        Erfolgreicher Ordnerzugriff. Die Videos werden direkt im gewählten Ordner gespeichert.
                    </MudAlert>
                }
                else if (!SupportsDeviceFolderStorage || _folderChoiceAttempted)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        Oh, das klappt leider nicht. Wir speichern jedes Video einzeln nach der Aufnahme.
                    </MudAlert>
                }

                @if (ShowStorageStatusDetails)
                {
                    <MudPaper Elevation="0" Class="pa-3" Style="border:1px solid var(--mud-palette-lines-default);">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle1">@GetStorageStatusTitle()</MudText>
                            <MudText Typo="Typo.body2" Color="@StorageTextColor" Style="word-break:break-word;">
                                @StorageText
                            </MudText>
                        </MudStack>
                    </MudPaper>
                }

                @if (CanChooseStorageFolder)
                {
                    <div class="running-analysis-storage-action">
                        <MudTooltip Text="Ordner wählen">
                            <MudIconButton Class="running-analysis-storage-button"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Icon="@Icons.Material.Filled.FolderOpen"
                                           Disabled="@_isChoosingStorage"
                                           OnClick="ChooseStorageAsync"
                                           aria-label="Ordner wählen" />
                        </MudTooltip>
                    </div>
                }
            </MudStack>
        }
        else if (_wizardStep == CaptureWizardStep.Perspective)
        {
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <div role="button" tabindex="0" style="cursor:pointer;" @onclick="@(() => SelectPerspective(RunningAnalysisPerspective.Side))">
                        <MudPaper Elevation="0"
                                  Class="pa-4 running-analysis-choice"
                                  Style="@GetPerspectiveStyle(RunningAnalysisPerspective.Side)">
                            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.DirectionsRun" Size="Size.Large" Color="@GetPerspectiveIconColor(RunningAnalysisPerspective.Side)" />
                                <MudText Typo="Typo.h6">Seite</MudText>
                                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                                    Der Lauf wird von der Seite aufgenommen.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <div role="button" tabindex="0" style="cursor:pointer;" @onclick="@(() => SelectPerspective(RunningAnalysisPerspective.Rear))">
                        <MudPaper Elevation="0"
                                  Class="pa-4 running-analysis-choice"
                                  Style="@GetPerspectiveStyle(RunningAnalysisPerspective.Rear)">
                            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.AssistantDirection" Size="Size.Large" Color="@GetPerspectiveIconColor(RunningAnalysisPerspective.Rear)" />
                                <MudText Typo="Typo.h6">Hinten</MudText>
                                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                                    Der Lauf wird von hinten aufgenommen.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </div>
                </MudItem>
            </MudGrid>
        }
        else if (_wizardStep == CaptureWizardStep.Recording)
        {
            <MudStack Spacing="3">
                @if (!string.IsNullOrWhiteSpace(_statusMessage))
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">@_statusMessage</MudAlert>
                }

                <MudPaper Elevation="0" Class="pa-3" Style="border:1px solid var(--mud-palette-primary);">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap:12px; flex-wrap:wrap;">
                        <MudStack Spacing="0" Style="min-width:0;">
                            <MudText Typo="Typo.h6">@ActiveParticipantName</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @RunningAnalysisPerspectiveFormatting.ToDisplayName(_selectedPerspective) - Teilnehmer:in @GetCurrentParticipantNumber() von @OrderedParticipants.Count
                            </MudText>
                        </MudStack>

                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(IsOnline ? Color.Success : Color.Error)"
                                 Variant="Variant.Outlined">
                            @(IsOnline ? "Online" : "Offline")
                        </MudChip>
                    </MudStack>
                </MudPaper>

                <div class="running-analysis-camera-frame">
                    @if (ChildContent is not null)
                    {
                        @ChildContent
                    }
                    else
                    {
                        <RunningAnalysisMediaRecorder @ref="_mediaRecorder"
                                                      CaptureSessionId="@EffectiveCaptureSessionId"
                                                      CaptureExternalEventId="@EffectiveCaptureExternalEventId"
                                                      CourseId="@CourseId"
                                                      CaptureTitle="@EffectiveCaptureTitle"
                                                      CaptureStartsAt="@EffectiveCaptureStartsAt"
                                                      ParticipantId="@ActiveParticipantId"
                                                      AthleteUserId="@ActiveAthleteUserId"
                                                      AthleteEmail="@ActiveAthleteEmail"
                                                      ParticipantName="@ActiveParticipantName"
                                                      FileNamePrefix="@ActiveFileNamePrefix"
                                                      Perspective="@_selectedPerspective"
                                                      CanRecord="CanUseRecorder"
                                                      ShowControls="false"
                                                      OnRecorded="OnRecorderRecordedAsync"
                                                      IsRecordingChanged="OnRecorderStateChangedAsync" />
                    }
                </div>

                @if (!CanUseRecorder)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        Der lokale Speicher ist noch nicht bereit.
                    </MudAlert>
                }

                <MudStack Row="true" Justify="Justify.Center" Style="gap:8px; flex-wrap:wrap;">
                    @if (!IsRecordingActive)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.FiberManualRecord"
                                   Disabled="@(!CanUseRecorder)"
                                   OnClick="StartRecordingAsync">
                            Record
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Stop"
                                   OnClick="StopRecordingAsync">
                            Stop
                        </MudButton>
                    }

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               Disabled="@IsRecordingActive"
                               OnClick="NextRecordingParticipantAsync">
                        Next
                    </MudButton>
                </MudStack>
            </MudStack>
        }
        else if (_wizardStep == CaptureWizardStep.ManualSave)
        {
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    Speichere jetzt das Video von @ActiveParticipantName. Danach geht es automatisch mit der nächsten Person weiter.
                </MudAlert>

                @if (!string.IsNullOrWhiteSpace(_saveError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_saveError</MudAlert>
                }
            </MudStack>
        }
        else if (_wizardStep == CaptureWizardStep.Complete)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                Alle registrierten Teilnehmer:innen wurden für diese Perspektive durchlaufen.
            </MudAlert>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="gap:8px; flex-wrap:wrap;">
            <MudButton Variant="Variant.Text"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Close"
                       Disabled="@IsNavigationBusy"
                       OnClick="CancelAsync">
                Cancel
            </MudButton>

            <MudStack Row="true" Style="gap:8px; flex-wrap:wrap;">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Disabled="@IsBackDisabled"
                           OnClick="BackAsync">
                    Zurück
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           Disabled="@IsForwardDisabled"
                           OnClick="ContinueAsync">
                    Weiter
                </MudButton>
            </MudStack>
        </MudStack>
    </MudStack>
</MudPaper>

<style>
    .running-analysis-camera-frame {
        aspect-ratio: 16 / 9;
        width: 100%;
        min-height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--mud-palette-background-grey);
        color: var(--mud-palette-text-secondary);
        border-radius: 8px;
        overflow: hidden;
    }

    .running-analysis-choice {
        min-height: 170px;
        border: 1px solid var(--mud-palette-lines-default);
        cursor: pointer;
        transition: border-color 120ms ease, background-color 120ms ease;
    }

    .running-analysis-choice:hover {
        border-color: var(--mud-palette-primary);
    }

    .running-analysis-storage-action {
        min-height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .running-analysis-storage-button {
        width: 92px;
        height: 92px;
        border-radius: 16px;
    }

    .running-analysis-storage-button .mud-icon-root {
        font-size: 3rem;
    }
</style>

@code {
    private enum CaptureWizardStep
    {
        Roster,
        Storage,
        Perspective,
        Recording,
        ManualSave,
        Complete
    }

    private RunningAnalysisMediaRecorder? _mediaRecorder;
    private IJSObjectReference? _recorderModule;
    private CaptureWizardStep _wizardStep;
    private bool _recorderIsRecording;
    private bool _isChoosingStorage;
    private bool _isSavingExport;
    private bool _folderChoiceAttempted;
    private string? _saveError;
    private string? _statusMessage;
    private string? _activeParticipantId;
    private RunningAnalysisRecordedVideo? _recordedVideo;
    private RunningAnalysisPerspective _selectedPerspective = RunningAnalysisPerspective.Side;

    [Parameter] public string CaptureSessionId { get; set; } = string.Empty;
    [Parameter] public string CaptureExternalEventId { get; set; } = string.Empty;
    [Parameter] public string CourseId { get; set; } = string.Empty;
    [Parameter] public string CaptureTitle { get; set; } = string.Empty;
    [Parameter] public DateTime? CaptureStartsAt { get; set; }
    [Parameter] public string AnalysisEventId { get; set; } = string.Empty;
    [Parameter] public string AnalysisExternalEventId { get; set; } = string.Empty;
    [Parameter] public string AnalysisTitle { get; set; } = string.Empty;
    [Parameter] public DateTime? AnalysisStartsAt { get; set; }
    [Parameter] public IReadOnlyList<RunningAnalysisRosterItem> Participants { get; set; } = Array.Empty<RunningAnalysisRosterItem>();
    [Parameter] public string? SelectedParticipantId { get; set; }
    [Parameter] public EventCallback<string> SelectedParticipantIdChanged { get; set; }
    [Parameter] public string ParticipantId { get; set; } = string.Empty;
    [Parameter] public string AthleteUserId { get; set; } = string.Empty;
    [Parameter] public string AthleteEmail { get; set; } = string.Empty;
    [Parameter] public string ParticipantName { get; set; } = string.Empty;
    [Parameter] public string FileNamePrefix { get; set; } = string.Empty;
    [Parameter] public bool IsOnline { get; set; } = true;
    [Parameter] public bool CanRecord { get; set; } = true;
    [Parameter] public bool IsRecording { get; set; }
    [Parameter] public bool SupportsDeviceFolderStorage { get; set; }
    [Parameter] public bool IsStorageReady { get; set; }
    [Parameter] public string StorageText { get; set; } = string.Empty;
    [Parameter] public Color StorageTextColor { get; set; } = Color.Secondary;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnChooseStorage { get; set; }
    [Parameter] public EventCallback OnStartRecording { get; set; }
    [Parameter] public EventCallback OnStopRecording { get; set; }
    [Parameter] public EventCallback<RunningAnalysisRecordedVideo> OnRecorded { get; set; }
    [Parameter] public EventCallback<bool> IsRecordingChanged { get; set; }
    [Parameter] public EventCallback OnRetake { get; set; }
    [Parameter] public EventCallback OnBackToRoster { get; set; }

    private bool IsRecordingActive => IsRecording || _recorderIsRecording;
    private bool IsNavigationBusy => IsRecordingActive || _isChoosingStorage || _isSavingExport;
    private bool IsBackDisabled => IsNavigationBusy || _wizardStep == CaptureWizardStep.Roster;
    private bool IsForwardDisabled =>
        IsNavigationBusy
        || _wizardStep == CaptureWizardStep.Complete
        || (_wizardStep == CaptureWizardStep.Roster && OrderedParticipants.Count == 0)
        || (_wizardStep == CaptureWizardStep.Storage && !IsStorageDecisionReady)
        || (_wizardStep == CaptureWizardStep.ManualSave && _recordedVideo is null)
        || _wizardStep == CaptureWizardStep.Recording;
    private bool CanChooseStorageFolder => SupportsDeviceFolderStorage;
    private bool IsStorageDecisionReady =>
        IsStorageReady || !SupportsDeviceFolderStorage || _folderChoiceAttempted;
    private bool ShowStorageStatusDetails =>
        IsStorageReady || !SupportsDeviceFolderStorage || _folderChoiceAttempted;
    private bool CanUseRecorder => CanRecord || !SupportsDeviceFolderStorage || _folderChoiceAttempted;
    private RunningAnalysisRosterItem? ActiveParticipant =>
        OrderedParticipants.FirstOrDefault(participant => participant.ParticipantId == _activeParticipantId)
        ?? OrderedParticipants.FirstOrDefault(participant => participant.ParticipantId == SelectedParticipantId)
        ?? OrderedParticipants.FirstOrDefault();

    private string ActiveParticipantId => ActiveParticipant?.ParticipantId ?? ParticipantId;
    private string ActiveAthleteUserId => ActiveParticipant?.AthleteUserId ?? AthleteUserId;
    private string ActiveAthleteEmail => ActiveParticipant?.AthleteEmail ?? AthleteEmail;
    private string ActiveParticipantName => ActiveParticipant?.DisplayName ?? ParticipantName;
    private string ActiveFileNamePrefix => ActiveParticipant is null
        ? FileNamePrefix
        : BuildFileNamePrefix(ActiveParticipant);

    private IReadOnlyList<RunningAnalysisRosterItem> OrderedParticipants =>
        Participants
            .OrderBy(participant => participant.SortOrder)
            .ThenBy(participant => participant.DisplayName)
            .ToList();

    private string EffectiveCaptureSessionId => string.IsNullOrWhiteSpace(CaptureSessionId) ? AnalysisEventId : CaptureSessionId;
    private string EffectiveCaptureExternalEventId => string.IsNullOrWhiteSpace(CaptureExternalEventId) ? AnalysisExternalEventId : CaptureExternalEventId;
    private string EffectiveCaptureTitle => string.IsNullOrWhiteSpace(CaptureTitle) ? AnalysisTitle : CaptureTitle;
    private DateTime? EffectiveCaptureStartsAt => CaptureStartsAt ?? AnalysisStartsAt;

    protected override void OnParametersSet()
    {
        if (OrderedParticipants.Count == 0)
        {
            _activeParticipantId = null;
            return;
        }

        if (!string.IsNullOrWhiteSpace(_activeParticipantId)
            && OrderedParticipants.Any(participant => participant.ParticipantId == _activeParticipantId))
        {
            return;
        }

        _activeParticipantId = !string.IsNullOrWhiteSpace(SelectedParticipantId)
            ? SelectedParticipantId
            : OrderedParticipants.First().ParticipantId;
    }

    private async Task ChooseStorageAsync()
    {
        if (!OnChooseStorage.HasDelegate)
            return;

        _isChoosingStorage = true;
        _folderChoiceAttempted = true;

        try
        {
            await OnChooseStorage.InvokeAsync();
        }
        finally
        {
            _isChoosingStorage = false;
        }
    }

    private void SelectPerspective(RunningAnalysisPerspective perspective)
    {
        if (IsRecordingActive)
            return;

        _selectedPerspective = perspective == RunningAnalysisPerspective.Rear
            ? RunningAnalysisPerspective.Rear
            : RunningAnalysisPerspective.Side;
        _statusMessage = null;
    }

    private async Task ContinueAsync()
    {
        if (IsForwardDisabled)
            return;

        switch (_wizardStep)
        {
            case CaptureWizardStep.Roster:
                await SelectFirstParticipantAsync();
                _wizardStep = CaptureWizardStep.Storage;
                break;
            case CaptureWizardStep.Storage:
                _wizardStep = CaptureWizardStep.Perspective;
                break;
            case CaptureWizardStep.Perspective:
                await SelectFirstParticipantAsync();
                _statusMessage = null;
                _wizardStep = CaptureWizardStep.Recording;
                break;
            case CaptureWizardStep.ManualSave:
                await ExportRecordingAsync();
                break;
        }
    }

    private async Task BackAsync()
    {
        if (IsBackDisabled)
            return;

        _statusMessage = null;

        _wizardStep = _wizardStep switch
        {
            CaptureWizardStep.Storage => CaptureWizardStep.Roster,
            CaptureWizardStep.Perspective => CaptureWizardStep.Storage,
            CaptureWizardStep.Recording => CaptureWizardStep.Perspective,
            CaptureWizardStep.ManualSave => CaptureWizardStep.Recording,
            CaptureWizardStep.Complete => CaptureWizardStep.Recording,
            _ => _wizardStep
        };

        await Task.CompletedTask;
    }

    private async Task CancelAsync()
    {
        if (IsRecordingActive)
            return;

        await OnBackToRoster.InvokeAsync();
    }

    private async Task SelectFirstParticipantAsync()
    {
        var firstParticipant = OrderedParticipants.FirstOrDefault();
        if (firstParticipant is null)
        {
            _wizardStep = CaptureWizardStep.Complete;
            return;
        }

        _activeParticipantId = firstParticipant.ParticipantId;
        await SelectedParticipantIdChanged.InvokeAsync(firstParticipant.ParticipantId);
    }

    private async Task NextRecordingParticipantAsync()
    {
        if (IsRecordingActive)
            return;

        await MoveToNextParticipantAsync(null);
    }

    private async Task MoveToNextParticipantAsync(string? statusMessage)
    {
        var nextParticipant = GetNextParticipant();
        if (nextParticipant is null)
        {
            _statusMessage = statusMessage;
            _wizardStep = CaptureWizardStep.Complete;
            return;
        }

        ResetRecordingState();
        _statusMessage = statusMessage;
        _activeParticipantId = nextParticipant.ParticipantId;
        await SelectedParticipantIdChanged.InvokeAsync(nextParticipant.ParticipantId);
        _wizardStep = CaptureWizardStep.Recording;
    }

    private RunningAnalysisRosterItem? GetNextParticipant()
    {
        var participants = OrderedParticipants;
        var currentParticipantId = _activeParticipantId ?? SelectedParticipantId;
        var currentIndex = participants.ToList().FindIndex(participant => participant.ParticipantId == currentParticipantId);
        if (currentIndex < 0)
            return participants.FirstOrDefault();

        return currentIndex < participants.Count - 1
            ? participants[currentIndex + 1]
            : null;
    }

    private async Task StartRecordingAsync()
    {
        if (!CanUseRecorder)
            return;

        ResetRecordingState();
        _statusMessage = null;
        await OnStartRecording.InvokeAsync();

        if (_mediaRecorder is not null)
        {
            await _mediaRecorder.StartAsync();
            return;
        }

        await OnRecorderStateChangedAsync(true);
    }

    private async Task StopRecordingAsync()
    {
        if (!IsRecordingActive)
            return;

        if (_mediaRecorder is not null)
        {
            await _mediaRecorder.StopAsync();
        }
        else
        {
            await OnRecorderStateChangedAsync(false);
        }

        await OnStopRecording.InvokeAsync();
    }

    private async Task OnRecorderRecordedAsync(RunningAnalysisRecordedVideo video)
    {
        _recordedVideo = video;
        _saveError = null;

        if (IsExportRequired(video))
        {
            _wizardStep = CaptureWizardStep.ManualSave;
            return;
        }

        await MoveToNextParticipantAsync($"{video.ParticipantName} wurde erfolgreich gespeichert.");
        await OnRecorded.InvokeAsync(video);
    }

    private async Task ExportRecordingAsync()
    {
        if (_recordedVideo is null)
            return;

        _isSavingExport = true;
        _saveError = null;

        try
        {
            var module = await GetRecorderModuleAsync();
            var recordedVideo = _recordedVideo;
            await module.InvokeAsync<object>("exportSavedRecording", recordedVideo.LocalId);
            await MoveToNextParticipantAsync($"{recordedVideo.ParticipantName} wurde erfolgreich gespeichert.");
            await OnRecorded.InvokeAsync(recordedVideo);
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSavingExport = false;
        }
    }

    private async Task OnRecorderStateChangedAsync(bool isRecording)
    {
        _recorderIsRecording = isRecording;
        await IsRecordingChanged.InvokeAsync(isRecording);
    }

    private void ResetRecordingState()
    {
        _recordedVideo = null;
        _saveError = null;
    }

    private async Task<IJSObjectReference> GetRecorderModuleAsync()
    {
        _recorderModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/PaceLetics.RunningAnalysisModule.Components/runningAnalysisMediaRecorder.js");

        return _recorderModule;
    }

    private string GetStepTitle()
    {
        return _wizardStep switch
        {
            CaptureWizardStep.Roster => "Registrierte Teilnehmer:innen",
            CaptureWizardStep.Storage => "Speicher vorbereiten",
            CaptureWizardStep.Perspective => "Perspektive wählen",
            CaptureWizardStep.Recording => $"Jetzt aufnehmen: {ActiveParticipantName}",
            CaptureWizardStep.ManualSave => "Video speichern",
            CaptureWizardStep.Complete => "Fertig",
            _ => string.Empty
        };
    }

    private string GetStepInstruction()
    {
        return _wizardStep switch
        {
            CaptureWizardStep.Roster => "Prüfe kurz, ob die Liste stimmt. Weiter führt zum Speicherort.",
            CaptureWizardStep.Storage => GetStorageInstruction(),
            CaptureWizardStep.Perspective => "Wähle genau eine Perspektive für diese Runde.",
            CaptureWizardStep.Recording => "Nimm die Person auf oder gehe mit Next zur nächsten Person.",
            CaptureWizardStep.ManualSave => "Der Browser braucht jetzt einen manuellen Speicherschritt. Weiter speichert das Video.",
            CaptureWizardStep.Complete => "Alle Personen sind für diese Perspektive durchlaufen.",
            _ => string.Empty
        };
    }

    private string GetStorageInstruction()
    {
        if (IsStorageReady)
            return "Speicherort bereit. Du kannst weitergehen oder ihn ändern.";

        return SupportsDeviceFolderStorage && !_folderChoiceAttempted
            ? "Wähle den Speicherort für die Aufnahmen."
            : "Weiter führt zur Perspektive; jedes Video wird einzeln gespeichert.";
    }

    private string GetStorageStatusTitle()
    {
        if (IsStorageReady)
            return "Ordnerzugriff erfolgreich";

        return SupportsDeviceFolderStorage && !_folderChoiceAttempted
            ? "Ordner noch nicht gewählt"
            : "Einzelspeicherung";
    }

    private int GetCurrentParticipantNumber()
    {
        var currentParticipantId = _activeParticipantId ?? SelectedParticipantId;
        var index = OrderedParticipants.ToList().FindIndex(participant => participant.ParticipantId == currentParticipantId);
        return index < 0 ? 1 : index + 1;
    }

    private static string BuildFileNamePrefix(RunningAnalysisRosterItem participant)
    {
        var safeName = new string(participant.DisplayName
            .Trim()
            .Select(character => char.IsLetterOrDigit(character) ? character : '-')
            .ToArray());

        safeName = string.IsNullOrWhiteSpace(safeName) ? participant.ParticipantId : safeName;

        return $"{DateTime.UtcNow:yyyyMMdd-HHmmss}-{safeName}";
    }

    private string GetParticipantRecordingText(RunningAnalysisRosterItem item)
    {
        if (item.RecordingCount == 0)
            return "Noch keine Aufnahme";

        var side = string.IsNullOrWhiteSpace(item.SideRecordingUrl) ? "Seite fehlt" : "Seite vorhanden";
        var rear = string.IsNullOrWhiteSpace(item.RearRecordingUrl) ? "Hinten fehlt" : "Hinten vorhanden";
        return $"{side}, {rear}";
    }

    private string GetPerspectiveStyle(RunningAnalysisPerspective perspective)
    {
        var selected = _selectedPerspective == perspective;
        var borderColor = selected ? "var(--mud-palette-primary)" : "var(--mud-palette-lines-default)";
        var background = selected ? "var(--mud-palette-primary-hover)" : "transparent";
        return $"border-color:{borderColor}; background:{background};";
    }

    private Color GetPerspectiveIconColor(RunningAnalysisPerspective perspective)
    {
        return _selectedPerspective == perspective ? Color.Primary : Color.Default;
    }

    private static bool IsExportRequired(RunningAnalysisRecordedVideo video)
    {
        return string.Equals(video.UploadStatus, "needs-export", StringComparison.OrdinalIgnoreCase);
    }

    public async ValueTask DisposeAsync()
    {
        if (_recorderModule is not null)
            await _recorderModule.DisposeAsync();
    }
}
